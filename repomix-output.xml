184:                 className="relative w-full h-[1px] overflow-hidden"
185:                 style={{ background: 'rgba(255,255,255,0.07)' }}
186:                 role="progressbar"
187:                 aria-valuenow={progress}
188:                 aria-valuemin={0}
189:                 aria-valuemax={100}
190:               >
191:                 <div
192:                   ref={barRef}
193:                   className="absolute top-0 left-0 h-full"
194:                   style={{
195:                     width: '0%',
196:                     background: 'linear-gradient(90deg, #fb923c, #f0f4ff)',
197:                     boxShadow: '0 0 8px rgba(251,146,60,0.6)',
198:                   }}
199:                 />
200:               </div>
201: 
202:               {/* Step label */}
203:               <div className="h-4 overflow-hidden">
204:                 <AnimatePresence mode="wait">
