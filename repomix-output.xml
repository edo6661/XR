<file path="src/components/ui/SplitTextReveal.tsx">
 1: import { motion, type Variants } from 'framer-motion';
 2: 
 3: interface SplitTextRevealProps {
 4:   text: string;
 5:   className?: string;
 6:   delay?: number;
 7: }
 8: 
 9: const SplitTextReveal = ({ text, className = '', delay = 0 }: SplitTextRevealProps) => {
10:   // Pecah teks menjadi array kata
11:   const words = text.split(' ');
12: 
13:   // Varian untuk Container (mengatur jeda antar kata)
14:   const container: Variants = {
15:     hidden: { opacity: 0 },
16:     visible: (i = 1) => ({
17:       opacity: 1,
18:       transition: {
19:         staggerChildren: 0.08,
20:         delayChildren: delay * i
21:       },
22:     }),
23:   };
24: 
25:   // Varian untuk setiap kata
26:   const child: Variants = {
27:     visible: {
28:       opacity: 1,
29:       y: 0,
30:       rotateX: 0,
31:       transition: {
32:         type: 'spring',
33:         damping: 14,
34:         stiffness: 100,
35:       },
36:     },
37:     hidden: {
38:       opacity: 0,
39:       y: 40,
40:       rotateX: -40,
41:     },
42:   };
43: 
44:   return (
45:     <motion.div
46:       style={{ overflow: 'hidden', display: 'flex', flexWrap: 'wrap' }}
47:       variants={container}
48:       initial="hidden"
49:       whileInView="visible"
50:       viewport={{ once: true, margin: "-10%" }}
51:       className={className}
52:     >
53:       {words.map((word, index) => (
54:         <motion.span
55:           variants={child}
56:           style={{ marginRight: '0.25em', display: 'inline-block', transformOrigin: 'bottom' }}
57:           key={index}
58:         >
59:           {word}
60:         </motion.span>
61:       ))}
62:     </motion.div>
63:   );
64: };
65: 
66: export default SplitTextReveal;
</file>

