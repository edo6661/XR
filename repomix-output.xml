  1: // src/components/ui/ScrollMarquee.tsx
  2: import { useEffect, useRef } from 'react';
  3: import gsap from 'gsap';
  4: import { ScrollTrigger } from 'gsap/ScrollTrigger';
  5: 
  6: gsap.registerPlugin(ScrollTrigger);
  7: 
  8: // ── Text block ─────────────────────────────────────────────────────────────
  9: const Word = ({ text, outline = false }: { text: string; outline?: boolean }) => (
 10:   <span
 11:     className="font-heading font-black tracking-[0.06em] uppercase flex-shrink-0"
 12:     style={{
 13:       fontSize: 'clamp(2.2rem, 6vw, 5rem)',
 14:       ...(outline
 15:         ? {
 16:           color: 'transparent',
 17:           WebkitTextStroke: '1px rgba(251,146,60,0.22)',
 18:         }
 19:         : {
 20:           color: 'rgba(240,244,255,0.07)',
 21:         }),
 22:     }}
 23:     aria-hidden="true"
 24:   >
 25:     {text}
 26:   </span>
 27: );
 28: 
 29: // ── Separator diamond ──────────────────────────────────────────────────────
 30: const Diamond = ({ color = 'rgba(251,146,60,0.3)' }: { color?: string }) => (
 31:   <span
 32:     className="flex-shrink-0 mx-8"
 33:     style={{
 34:       width: '5px',
 35:       height: '5px',
 36:       background: color,
 37:       transform: 'rotate(45deg)',
 38:       display: 'inline-block',
 39:       verticalAlign: 'middle',
 40:     }}
 41:     aria-hidden="true"
 42:   />
 43: );
 44: 
 45: // ── ScrollMarquee ──────────────────────────────────────────────────────────
 46: const ScrollMarquee = () => {
 47:   const containerRef = useRef<HTMLDivElement>(null);
 48:   const row1Ref = useRef<HTMLDivElement>(null);
 49:   const row2Ref = useRef<HTMLDivElement>(null);
 50: 
 51:   const row1Words = ['Future', 'Immersive', 'Spatial', 'Computing'];
 52:   const row2Words = ['AI', '×', 'XR', 'Innovation'];
 53: 
 54:   useEffect(() => {
 55:     const ctx = gsap.context(() => {
 56:       // Row 1 bergerak ke kiri
 57:       gsap.fromTo(row1Ref.current,
 58:         { x: 0 },
 59:         {
 60:           x: -320,
 61:           ease: "none",
 62:           scrollTrigger: {
 63:             trigger: containerRef.current,
 64:             start: "top bottom",
 65:             end: "bottom top",
 66:             scrub: 1.5, // Angka ini memberikan efek spring/smooth
 67:           }
 68:         }
 69:       );
 70: 
 71:       // Row 2 bergerak ke kanan
 72:       gsap.fromTo(row2Ref.current,
 73:         { x: -320 },
 74:         {
 75:           x: 0,
 76:           ease: "none",
 77:           scrollTrigger: {
 78:             trigger: containerRef.current,
 79:             start: "top bottom",
 80:             end: "bottom top",
 81:             scrub: 1.5,
 82:           }
 83:         }
 84:       );
 85:     }, containerRef);
 86: 
 87:     return () => ctx.revert();
 88:   }, []);
 89: 
 90:   return (
 91:     <section
 92:       ref={containerRef}
 93:       className="relative w-full overflow-hidden optimize-gpu"
 94:       style={{
 95:         paddingTop: '5rem',
 96:         paddingBottom: '5rem',
 97:         borderTop: '1px solid rgba(255,255,255,0.04)',
 98:         borderBottom: '1px solid rgba(255,255,255,0.04)',
 99:       }}
100:       aria-hidden="true"
101:     >
102:       {/* Subtle center glow */}
103:       <div
104:         className="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full pointer-events-none"
105:         style={{
106:           height: '200px',
107:           background: 'radial-gradient(ellipse, rgba(251,146,60,0.04) 0%, transparent 68%)',
108:         }}
109:       />
110: 
111:       <div
112:         className="flex flex-col gap-4"
113:         style={{ transform: 'rotate(-1.5deg) scale(1.06)', transformOrigin: 'center' }}
114:       >
115:         {/* Row 1 */}
116:         <div ref={row1Ref} className="flex items-center whitespace-nowrap will-change-transform">
117:           {[...Array(3)].map((_, gi) =>
118:             row1Words.map((word, wi) => (
119:               <div key={`r1-${gi}-${wi}`} className="flex items-center">
120:                 <div className="px-6">
121:                   <Word text={word} outline={wi % 2 === 0} />
122:                 </div>
123:                 <Diamond color={wi % 2 === 0 ? 'rgba(251,146,60,0.25)' : 'rgba(34,211,238,0.2)'} />
124:               </div>
125:             ))
126:           )}
127:         </div>
128: 
129:         {/* Row 2 */}
130:         <div ref={row2Ref} className="flex items-center whitespace-nowrap will-change-transform">
131:           {[...Array(3)].map((_, gi) =>
132:             row2Words.map((word, wi) => (
133:               <div key={`r2-${gi}-${wi}`} className="flex items-center">
134:                 <div className="px-6">
135:                   <Word text={word} outline={wi % 2 !== 0} />
136:                 </div>
137:                 <Diamond color={wi % 2 !== 0 ? 'rgba(167,139,250,0.22)' : 'rgba(251,146,60,0.2)'} />
138:               </div>
139:             ))
140:           )}
141:         </div>
142:       </div>
143:     </section>
144:   );
145: };
146: 
147: export default ScrollMarquee;
</file>

