 32: const HeroLogo = ({ showText = true }: { showText?: boolean }) => {
 33:   const placeholderRef = useRef<HTMLDivElement>(null);
 34:   const flyingRef = useRef<HTMLDivElement>(null);
 35:   const glowsRef = useRef<HTMLDivElement>(null);
