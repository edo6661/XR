142:               transition: 'border-color 0.4s ease, box-shadow 0.4s ease',
143:               boxShadow: isCenter
144:                 ? `0 0 48px ${accentColor}0e, 0 24px 48px rgba(0,0,0,0.35)`
145:                 : '0 12px 32px rgba(0,0,0,0.25)',
146:             }}
147:           >
148:             {/* TracerBorder wrapping content */}
