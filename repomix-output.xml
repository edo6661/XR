<file path="src/components/hero/GlobeCanvas.tsx">
  1: import { useEffect, useRef } from 'react';
  2: import * as THREE from 'three';
  3: 
  4: 
  5: const DEG = Math.PI / 180;
  6: const RADIUS = 2.05;
  7: 
  8: // Host / partner cities — the "global network" the arcs trace.
  9: const CITIES: { lat: number; lon: number; hub?: boolean }[] = [
 10:   { lat: 3.14, lon: 101.69, hub: true }, // Kuala Lumpur (flagship host)
 11:   { lat: 1.35, lon: 103.82 }, // Singapore
 12:   { lat: 35.68, lon: 139.69 }, // Tokyo
 13:   { lat: 37.57, lon: 126.98 }, // Seoul
 14:   { lat: 31.23, lon: 121.47 }, // Shanghai
 15:   { lat: 19.08, lon: 72.88 }, // Mumbai
 16:   { lat: 25.2, lon: 55.27 }, // Dubai
 17:   { lat: -33.87, lon: 151.21 }, // Sydney
 18:   { lat: 51.51, lon: -0.13 }, // London
 19:   { lat: 37.77, lon: -122.42 }, // San Francisco
 20: ];
 21: 
 22: // Routes radiate from the KL hub (0) + a couple of cross links.
 23: const ROUTES: [number, number][] = [
 24:   [0, 2],
 25:   [0, 6],
 26:   [0, 8],
 27:   [0, 9],
 28:   [0, 3],
 29:   [1, 5],
 30:   [4, 7],
 31: ];
 32: 
 33: const LAND_THRESHOLD = 0.07; // earth-dark.jpg: solid-black continents read darkest
 34: 
 35: function latLonToVec3(lat: number, lon: number, r: number) {
 36:   const phi = lat * DEG;
 37:   const lambda = lon * DEG;
 38:   return new THREE.Vector3(
 39:     r * Math.cos(phi) * Math.cos(lambda),
 40:     r * Math.sin(phi),
 41:     r * Math.cos(phi) * Math.sin(lambda),
 42:   );
 43: }
 44: 
 45: const GlobeCanvas = () => {
 46:   const mountRef = useRef<HTMLDivElement>(null);
 47: 
 48:   useEffect(() => {
 49:     const mount = mountRef.current;
 50:     if (!mount) return;
 51: 
 52:     const prefersReducedMotion = window.matchMedia(
 53:       '(prefers-reduced-motion: reduce)',
 54:     ).matches;
 55:     const isMobile = window.innerWidth < 768;
 56:     const PIXEL = Math.min(window.devicePixelRatio, 1.0);
 57: 
 58:     // ── 1. Scene · Camera · Renderer ───────────────────────────────────────
 59:     const scene = new THREE.Scene();
 60:     const camera = new THREE.PerspectiveCamera(
 61:       45,
 62:       mount.clientWidth / mount.clientHeight,
 63:       0.1,
 64:       100,
 65:     );
 66:     camera.position.set(0, 0, 6.2);
 67: 
 68:     const renderer = new THREE.WebGLRenderer({
 69:       antialias: true,
 70:       alpha: true,
 71:       powerPreference: 'high-performance',
 72:     });
 73:     renderer.setSize(mount.clientWidth, mount.clientHeight);
 74:     renderer.setPixelRatio(PIXEL);
 75:     mount.appendChild(renderer.domElement);
 76: 
 77:     // Brand-aligned palette
 78:     const COL_ATMO = new THREE.Color('#38bdf8'); // cyan atmosphere
 79:     const COL_DOT = new THREE.Color('#7dd3fc'); // light cyan land dots
 80:     const COL_ACCENT = new THREE.Color('#fb923c'); // warm brand orange
 81:     const COL_GRID = new THREE.Color('#2b6f9e');
 82: 
 83:     // Group lets us tilt + parallax everything together
 84:     const globe = new THREE.Group();
 85:     globe.rotation.z = 0.18; // gentle axial tilt
 86:     globe.position.y = -0.15;
 87:     scene.add(globe);
 88: 
 89:     const disposables: { dispose: () => void }[] = [];
 90: 
 91:     // ── 2. Solid planet body (dark fill + fresnel limb) ────────────────────
 92:     const bodyMat = new THREE.ShaderMaterial({
 93:       uniforms: {
 94:         uDark: { value: new THREE.Color('#040c1a') },
 95:         uRim: { value: COL_ATMO },
 96:       },
 97:       vertexShader: `
 98:         varying vec3 vNormal;
 99:         varying vec3 vView;
100:         void main() {
101:           vNormal = normalize(normalMatrix * normal);
102:           vec4 mv = modelViewMatrix * vec4(position, 1.0);
103:           vView = normalize(-mv.xyz);
104:           gl_Position = projectionMatrix * mv;
105:         }
106:       `,
107:       fragmentShader: `
108:         uniform vec3 uDark;
109:         uniform vec3 uRim;
110:         varying vec3 vNormal;
111:         varying vec3 vView;
112:         void main() {
113:           float fres = 1.0 - max(dot(vNormal, vView), 0.0);
114:           float limb = pow(fres, 2.6);
115:           vec3 col = mix(uDark, uRim * 0.55, limb);
116:           gl_FragColor = vec4(col, 1.0);
117:         }
118:       `,
119:     });
120:     const bodyGeo = new THREE.SphereGeometry(RADIUS, 64, 64);
121:     const body = new THREE.Mesh(bodyGeo, bodyMat);
122:     globe.add(body);
123:     disposables.push(bodyGeo, bodyMat);
124: 
125:     // ── 3. Atmospheric glow shell (back-side fresnel, additive) ────────────
126:     const atmoMat = new THREE.ShaderMaterial({
127:       uniforms: { uColor: { value: COL_ATMO } },
128:       vertexShader: `
129:         varying vec3 vNormal;
130:         varying vec3 vView;
131:         void main() {
132:           vNormal = normalize(normalMatrix * normal);
133:           vec4 mv = modelViewMatrix * vec4(position, 1.0);
134:           vView = normalize(-mv.xyz);
135:           gl_Position = projectionMatrix * mv;
136:         }
137:       `,
138:       fragmentShader: `
139:         uniform vec3 uColor;
140:         varying vec3 vNormal;
141:         varying vec3 vView;
142:         void main() {
143:           float fres = pow(1.0 - max(dot(vNormal, vView), 0.0), 3.2);
144:           gl_FragColor = vec4(uColor, fres * 0.9);
145:         }
146:       `,
147:       transparent: true,
148:       side: THREE.BackSide,
149:       blending: THREE.AdditiveBlending,
150:       depthWrite: false,
151:     });
152:     const atmoGeo = new THREE.SphereGeometry(RADIUS * 1.16, 64, 64);
153:     const atmosphere = new THREE.Mesh(atmoGeo, atmoMat);
154:     globe.add(atmosphere);
155:     disposables.push(atmoGeo, atmoMat);
156: 
157:     // ── 4. Holographic lat/long grid (kept very faint) ─────────────────────
158:     const gridGeo = new THREE.WireframeGeometry(
159:       new THREE.SphereGeometry(RADIUS * 1.002, 36, 18),
160:     );
161:     const gridMat = new THREE.LineBasicMaterial({
162:       color: COL_GRID,
163:       transparent: true,
164:       opacity: 0.07,
165:       depthWrite: false,
166:     });
167:     const grid = new THREE.LineSegments(gridGeo, gridMat);
168:     globe.add(grid);
169:     disposables.push(gridGeo, gridMat);
170: 
171:     // ── 5. Continent dot-field (sampled from a real world map) ─────────────
172:     // Built async after the land-mask image decodes; falls back to a uniform
173:     // shimmer if the texture cannot be read.
174:     const dotMat = new THREE.ShaderMaterial({
175:       uniforms: {
176:         uTime: { value: 0 },
177:         uColor: { value: COL_DOT },
178:         uAccent: { value: COL_ACCENT },
179:         uSize: { value: 7.0 * PIXEL },
180:       },
181:       vertexShader: `
182:         attribute float aRand;
183:         attribute float aAccent;
184:         uniform float uTime;
185:         uniform float uSize;
186:         varying float vTwinkle;
187:         varying float vAccent;
188:         void main() {
189:           vAccent = aAccent;
190:           vTwinkle = 0.5 + 0.5 * sin(uTime * 1.3 + aRand * 30.0);
191:           vec4 mv = modelViewMatrix * vec4(position, 1.0);
192:           gl_PointSize = uSize * (0.7 + 0.3 * vTwinkle) / -mv.z * 2.0;
193:           gl_Position = projectionMatrix * mv;
194:         }
195:       `,
196:       fragmentShader: `
197:         uniform vec3 uColor;
198:         uniform vec3 uAccent;
199:         varying float vTwinkle;
200:         varying float vAccent;
201:         void main() {
202:           float d = length(gl_PointCoord - vec2(0.5));
203:           if (d > 0.5) discard;
204:           float soft = smoothstep(0.5, 0.0, d);
205:           vec3 c = mix(uColor, uAccent, vAccent);
206:           gl_FragColor = vec4(c, soft * (0.55 + 0.45 * vTwinkle) * 0.9);
207:         }
208:       `,
209:       transparent: true,
210:       depthTest: true, // back-side dots are hidden behind the opaque body
211:       depthWrite: false,
212:       blending: THREE.AdditiveBlending,
213:     });
214:     disposables.push(dotMat);
215:     let dots: THREE.Points | null = null;
216: 
217:     const buildDots = (isLand: ((lat: number, lon: number) => boolean) | null) => {
218:       const SAMPLES = isMobile ? 11000 : 22000;
219:       const goldenPhi = Math.PI * (3 - Math.sqrt(5));
220:       const pos: number[] = [];
221:       const rand: number[] = [];
222:       const accent: number[] = [];
223: 
224:       for (let i = 0; i < SAMPLES; i++) {
225:         const uy = 1 - (i / (SAMPLES - 1)) * 2;
226:         const r = Math.sqrt(Math.max(0, 1 - uy * uy));
227:         const theta = goldenPhi * i;
228:         const ux = Math.cos(theta) * r;
229:         const uz = Math.sin(theta) * r;
230: 
231:         if (isLand) {
232:           const lat = Math.asin(uy) / DEG;
233:           const lon = Math.atan2(uz, ux) / DEG;
234:           if (!isLand(lat, lon)) continue;
235:         }
236: 
237:         pos.push(ux * RADIUS * 1.01, uy * RADIUS * 1.01, uz * RADIUS * 1.01);
238:         rand.push(Math.random());
239:         accent.push(Math.random() > 0.94 ? 1 : 0); // sparse warm nodes
240:       }
241: 
242:       const geo = new THREE.BufferGeometry();
243:       geo.setAttribute('position', new THREE.BufferAttribute(new Float32Array(pos), 3));
244:       geo.setAttribute('aRand', new THREE.BufferAttribute(new Float32Array(rand), 1));
245:       geo.setAttribute('aAccent', new THREE.BufferAttribute(new Float32Array(accent), 1));
246:       dots = new THREE.Points(geo, dotMat);
247:       globe.add(dots);
248:       disposables.push(geo);
249:     };
250: 
251:     const img = new Image();
252:     img.crossOrigin = 'anonymous';
253:     img.onload = () => {
254:       try {
255:         const TW = 1024;
256:         const TH = 512;
257:         const c = document.createElement('canvas');
258:         c.width = TW;
259:         c.height = TH;
260:         const ctx = c.getContext('2d', { willReadFrequently: true });
261:         if (!ctx) {
262:           buildDots(null);
263:           return;
264:         }
265:         ctx.drawImage(img, 0, 0, TW, TH);
266:         const data = ctx.getImageData(0, 0, TW, TH).data;
267:         const isLand = (lat: number, lon: number) => {
268:           let u = (lon + 180) / 360;
269:           u = ((u % 1) + 1) % 1;
270:           const v = Math.min(0.999, Math.max(0, (90 - lat) / 180));
271:           const px = Math.min(TW - 1, Math.floor(u * TW));
272:           const py = Math.min(TH - 1, Math.floor(v * TH));
273:           const idx = (py * TW + px) * 4;
274:           const lum =
275:             (data[idx] * 0.299 + data[idx + 1] * 0.587 + data[idx + 2] * 0.114) / 255;
276:           return lum < LAND_THRESHOLD;
277:         };
278:         buildDots(isLand);
279:       } catch {
280:         buildDots(null); // tainted canvas / read failure → graceful fallback
281:       }
282:     };
283:     img.onerror = () => buildDots(null);
284:     img.src = '/hero/earth-dark.jpg';
285: 
286:     // ── 6. City nodes (pulsing pins at each network endpoint) ──────────────
287:     const cityPos: number[] = [];
288:     const cityRand: number[] = [];
289:     const cityHub: number[] = [];
290:     CITIES.forEach((cty) => {
291:       const v = latLonToVec3(cty.lat, cty.lon, RADIUS * 1.012);
292:       cityPos.push(v.x, v.y, v.z);
293:       cityRand.push(Math.random());
294:       cityHub.push(cty.hub ? 1 : 0);
295:     });
296:     const cityGeo = new THREE.BufferGeometry();
297:     cityGeo.setAttribute('position', new THREE.BufferAttribute(new Float32Array(cityPos), 3));
298:     cityGeo.setAttribute('aRand', new THREE.BufferAttribute(new Float32Array(cityRand), 1));
299:     cityGeo.setAttribute('aHub', new THREE.BufferAttribute(new Float32Array(cityHub), 1));
300:     const cityMat = new THREE.ShaderMaterial({
301:       uniforms: {
302:         uTime: { value: 0 },
303:         uColor: { value: COL_DOT },
304:         uHub: { value: COL_ACCENT },
305:         uSize: { value: 9.0 * PIXEL },
306:       },
307:       vertexShader: `
308:         attribute float aRand;
309:         attribute float aHub;
310:         uniform float uTime;
311:         uniform float uSize;
312:         varying float vPulse;
313:         varying float vHub;
314:         void main() {
315:           vHub = aHub;
316:           vPulse = 0.6 + 0.4 * sin(uTime * 2.2 + aRand * 12.0);
317:           vec4 mv = modelViewMatrix * vec4(position, 1.0);
318:           gl_PointSize = uSize * (aHub > 0.5 ? 1.6 : 1.0) * vPulse / -mv.z * 2.0;
319:           gl_Position = projectionMatrix * mv;
320:         }
321:       `,
322:       fragmentShader: `
323:         uniform vec3 uColor;
324:         uniform vec3 uHub;
325:         varying float vPulse;
326:         varying float vHub;
327:         void main() {
328:           float d = length(gl_PointCoord - vec2(0.5));
329:           if (d > 0.5) discard;
330:           float core = smoothstep(0.5, 0.0, d);
331:           vec3 c = mix(uColor, uHub, vHub);
332:           gl_FragColor = vec4(c, core * vPulse);
333:         }
334:       `,
335:       transparent: true,
336:       depthTest: true,
337:       depthWrite: false,
338:       blending: THREE.AdditiveBlending,
339:     });
340:     const cities = new THREE.Points(cityGeo, cityMat);
341:     globe.add(cities);
342:     disposables.push(cityGeo, cityMat);
343: 
344:     // ── 7. Glowing great-circle arcs + travelling pulses ───────────────────
345:     const arcGroup = new THREE.Group();
346:     globe.add(arcGroup);
347:     const pulses: {
348:       curve: THREE.QuadraticBezierCurve3;
349:       mesh: THREE.Mesh;
350:       speed: number;
351:       offset: number;
352:     }[] = [];
353: 
354:     ROUTES.forEach(([a, b], i) => {
355:       const start = latLonToVec3(CITIES[a].lat, CITIES[a].lon, RADIUS * 1.014);
356:       const end = latLonToVec3(CITIES[b].lat, CITIES[b].lon, RADIUS * 1.014);
357:       const dist = start.distanceTo(end);
358:       const lift = 1 + 0.16 + (dist / (RADIUS * 2)) * 0.4;
359:       const ctrl = start
360:         .clone()
361:         .add(end)
362:         .multiplyScalar(0.5)
363:         .normalize()
364:         .multiplyScalar(RADIUS * lift);
365:       const curve = new THREE.QuadraticBezierCurve3(start, ctrl, end);
366: 
367:       const accentArc = i % 3 === 0;
368:       const color = accentArc ? COL_ACCENT : COL_DOT;
369: 
370:       const arcGeo = new THREE.BufferGeometry().setFromPoints(curve.getPoints(64));
371:       const arcMat = new THREE.LineBasicMaterial({
372:         color,
373:         transparent: true,
374:         opacity: accentArc ? 0.26 : 0.16,
375:         depthWrite: false,
376:       });
377:       arcGroup.add(new THREE.Line(arcGeo, arcMat));
378:       disposables.push(arcGeo, arcMat);
379: 
380:       const pulseGeo = new THREE.SphereGeometry(accentArc ? 0.03 : 0.024, 8, 8);
381:       const pulseMat = new THREE.MeshBasicMaterial({
382:         color,
383:         transparent: true,
384:         blending: THREE.AdditiveBlending,
385:         depthWrite: false,
386:       });
387:       const pulse = new THREE.Mesh(pulseGeo, pulseMat);
388:       arcGroup.add(pulse);
389:       disposables.push(pulseGeo, pulseMat);
390: 
391:       pulses.push({
392:         curve,
393:         mesh: pulse,
394:         speed: 0.1 + (i % 3) * 0.03,
395:         offset: (i / ROUTES.length) % 1,
396:       });
397:     });
398: 
399:     // ── 8. Inclined orbit rings + travelling satellites ────────────────────
400:     const orbits: { mat: THREE.LineBasicMaterial; sat: THREE.Mesh; speed: number; r: number }[] = [];
401:     const orbitConfigs = [
402:       { r: RADIUS * 1.45, tilt: 0.5, speed: 0.32, color: COL_ATMO },
403:       { r: RADIUS * 1.7, tilt: -0.9, speed: -0.22, color: COL_ACCENT },
404:       { r: RADIUS * 1.95, tilt: 1.35, speed: 0.16, color: COL_DOT },
405:     ];
406:     orbitConfigs.forEach(({ r, tilt, speed, color }) => {
407:       const segs = 128;
408:       const pts: number[] = [];
409:       for (let i = 0; i <= segs; i++) {
410:         const a = (i / segs) * Math.PI * 2;
411:         pts.push(Math.cos(a) * r, 0, Math.sin(a) * r);
412:       }
413:       const ringGeo = new THREE.BufferGeometry();
414:       ringGeo.setAttribute('position', new THREE.BufferAttribute(new Float32Array(pts), 3));
415:       const ringMat = new THREE.LineBasicMaterial({
416:         color,
417:         transparent: true,
418:         opacity: 0.1,
419:         depthWrite: false,
420:       });
421:       const ring = new THREE.Line(ringGeo, ringMat);
422:       ring.rotation.x = tilt;
423:       globe.add(ring);
424:       disposables.push(ringGeo, ringMat);
425: 
426:       const satGeo = new THREE.SphereGeometry(0.03, 12, 12);
427:       const satMat = new THREE.MeshBasicMaterial({ color });
428:       const sat = new THREE.Mesh(satGeo, satMat);
429:       ring.add(sat);
430:       disposables.push(satGeo, satMat);
431:       orbits.push({ mat: ringMat, sat, speed, r });
432:     });
433: 
434:     // ── 9. Deep starfield ──────────────────────────────────────────────────
435:     const starCount = isMobile ? 800 : 1400;
436:     const starPos = new Float32Array(starCount * 3);
437:     const starRand = new Float32Array(starCount);
438:     for (let i = 0; i < starCount; i++) {
439:       const i3 = i * 3;
440:       starPos[i3] = (Math.random() - 0.5) * 60;
441:       starPos[i3 + 1] = (Math.random() - 0.5) * 40;
442:       starPos[i3 + 2] = -10 - Math.random() * 30;
443:       starRand[i] = Math.random();
444:     }
445:     const starGeo = new THREE.BufferGeometry();
446:     starGeo.setAttribute('position', new THREE.BufferAttribute(starPos, 3));
447:     starGeo.setAttribute('aRand', new THREE.BufferAttribute(starRand, 1));
448:     const starMat = new THREE.ShaderMaterial({
449:       uniforms: { uTime: { value: 0 }, uPixel: { value: PIXEL } },
450:       vertexShader: `
451:         attribute float aRand;
452:         uniform float uTime;
453:         uniform float uPixel;
454:         varying float vT;
455:         void main() {
456:           vT = 0.4 + 0.6 * sin(uTime * 0.9 + aRand * 25.0);
457:           vec4 mv = modelViewMatrix * vec4(position, 1.0);
458:           gl_PointSize = (1.0 + aRand * 2.0) * uPixel;
459:           gl_Position = projectionMatrix * mv;
460:         }
461:       `,
462:       fragmentShader: `
463:         varying float vT;
464:         void main() {
465:           float d = length(gl_PointCoord - vec2(0.5));
466:           if (d > 0.5) discard;
467:           gl_FragColor = vec4(0.78, 0.86, 1.0, smoothstep(0.5, 0.0, d) * vT * 0.7);
468:         }
469:       `,
470:       transparent: true,
471:       depthWrite: false,
472:       blending: THREE.AdditiveBlending,
473:     });
474:     const stars = new THREE.Points(starGeo, starMat);
475:     scene.add(stars);
476:     disposables.push(starGeo, starMat);
477: 
478:     // ── 10. Mouse parallax ─────────────────────────────────────────────────
479:     let mouseX = 0;
480:     let mouseY = 0;
481:     const onMouseMove = (e: MouseEvent) => {
482:       mouseX = (e.clientX / window.innerWidth) * 2 - 1;
483:       mouseY = -(e.clientY / window.innerHeight) * 2 + 1;
484:     };
485:     window.addEventListener('mousemove', onMouseMove, { passive: true });
486: 
487:     // ── 11. Animation loop (pauses when offscreen / tab hidden) ────────────
488:     let animId = 0;
489:     let running = false;
490:     const clock = new THREE.Clock();
491:     const rotSpeed = prefersReducedMotion ? 0.01 : 0.04;
492:     const tmp = new THREE.Vector3();
493: 
494:     const animate = () => {
495:       const t = clock.getElapsedTime();
496: 
497:       dotMat.uniforms.uTime.value = t;
498:       cityMat.uniforms.uTime.value = t;
499:       starMat.uniforms.uTime.value = t;
500: 
501:       globe.rotation.y = t * rotSpeed;
502:       stars.rotation.y = t * 0.006;
503: 
504:       orbits.forEach(({ mat, sat, speed, r }) => {
505:         const a = t * speed;
506:         sat.position.set(Math.cos(a) * r, 0, Math.sin(a) * r);
507:         mat.opacity = 0.08 + 0.04 * Math.sin(t * 0.8 + r);
508:       });
509: 
510:       pulses.forEach(({ curve, mesh, speed, offset }) => {
511:         const tt = (t * speed + offset) % 1;
512:         curve.getPointAt(tt, tmp);
513:         mesh.position.copy(tmp);
514:         const fade = Math.sin(tt * Math.PI); // dim near the endpoints
515:         (mesh.material as THREE.MeshBasicMaterial).opacity = 0.25 + 0.75 * fade;
516:         const s = 0.7 + 0.5 * fade;
517:         mesh.scale.setScalar(s);
518:       });
519: 
520:       // smooth camera + group parallax (the depth illusion)
521:       const tx = mouseX * 0.5;
522:       const ty = mouseY * 0.32;
523:       camera.position.x += (tx - camera.position.x) * 0.04;
524:       camera.position.y += (ty + -0.15 - camera.position.y) * 0.04;
525:       camera.lookAt(0, -0.15, 0);
526: 
527:       globe.rotation.x += (mouseY * 0.12 - globe.rotation.x) * 0.04;
528: 
529:       renderer.render(scene, camera);
530:       animId = requestAnimationFrame(animate);
531:     };
532: 
533:     const start = () => {
534:       if (running) return;
535:       running = true;
536:       clock.getDelta(); // swallow the paused gap so rotation doesn't jump
537:       animId = requestAnimationFrame(animate);
538:     };
539:     const stop = () => {
540:       running = false;
541:       cancelAnimationFrame(animId);
542:     };
543: 
544:     // Pause render when the hero scrolls out of view.
545:     const io = new IntersectionObserver(
546:       ([entry]) => {
547:         if (entry.isIntersecting && !document.hidden) start();
548:         else stop();
549:       },
550:       { threshold: 0.01 },
551:     );
552:     io.observe(mount);
553: 
554:     const onVisibility = () => {
555:       if (document.hidden) stop();
556:       else start();
557:     };
558:     document.addEventListener('visibilitychange', onVisibility);
559: 
560:     start();
561: 
562:     // ── 12. Resize ─────────────────────────────────────────────────────────
563:     const onResize = () => {
564:       camera.aspect = mount.clientWidth / mount.clientHeight;
565:       camera.updateProjectionMatrix();
566:       renderer.setSize(mount.clientWidth, mount.clientHeight);
567:     };
568:     window.addEventListener('resize', onResize, { passive: true });
569: 
570:     // ── Cleanup ────────────────────────────────────────────────────────────
571:     return () => {
572:       stop();
573:       io.disconnect();
574:       document.removeEventListener('visibilitychange', onVisibility);
575:       window.removeEventListener('mousemove', onMouseMove);
576:       window.removeEventListener('resize', onResize);
577:       img.onload = null;
578:       img.onerror = null;
579:       disposables.forEach((d) => d.dispose());
580:       renderer.dispose();
581:       renderer.domElement.remove();
582:     };
583:   }, []);
584: 
585:   return (
586:     <div
587:       ref={mountRef}
588:       className="absolute inset-0 w-full h-full pointer-events-none"
589:       aria-hidden="true"
590:     />
591:   );
592: };
593: 
594: export default GlobeCanvas;
</file>

