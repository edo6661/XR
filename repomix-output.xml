 78: const TileCard = ({
 79:   tile,
 80:   index,
 81:   active,
 82:   isCenter,
 83:   reduce,
 84: }: {
 85:   tile: Tile;
 86:   index: number;
 87:   active: boolean;
 88:   isCenter: boolean;
 89:   reduce: boolean;
 90: }) => {
 91:   const [hovered, setHovered] = useState(false);
 92: 
 93:   // Mouse-reactive 3D tilt (premium, holographic depth).
 94:   const rx = useSpring(useMotionValue(0), { stiffness: 180, damping: 16 });
 95:   const ry = useSpring(useMotionValue(0), { stiffness: 180, damping: 16 });
 96: 
 97:   const handleTilt = useCallback(
 98:     (e: React.MouseEvent<HTMLAnchorElement>) => {
 99:       if (reduce) return;
100:       const r = e.currentTarget.getBoundingClientRect();
101:       const nx = (e.clientX - r.left) / r.width - 0.5;
102:       const ny = (e.clientY - r.top) / r.height - 0.5;
103:       ry.set(nx * 14);
104:       rx.set(-ny * 14);
105:     },
106:     [rx, ry, reduce],
107:   );
108:   const resetTilt = useCallback(() => {
109:     rx.set(0);
110:     ry.set(0);
111:   }, [rx, ry]);
112: 
113:   // Idle shake removed — infinite transform on backdrop-filter tiles was costly.
114:   const shake = { x: 0, y: 0, rotate: 0 };
115: 
116:   return (
117:     <motion.div
118:       // Boom-in entrance
119:       initial={{ opacity: 0, y: 44, scale: 0.82, filter: 'blur(10px)' }}
120:       animate={
121:         active
122:           ? { opacity: 1, y: isCenter ? -10 : 0, scale: isCenter ? 1.04 : 1, filter: 'blur(0px)' }
123:           : { opacity: 0, y: 44, scale: 0.82, filter: 'blur(10px)' }
124:       }
125:       transition={{
126:         delay: active ? 0.12 + index * 0.1 : 0,
127:         duration: 0.7,
128:         ease: [0.22, 1.4, 0.4, 1], // slight overshoot → the "boom"
129:       }}
130:       style={{ transformStyle: 'preserve-3d' }}
131:     >
132:       {/* Shake wrapper (separate so it composes with the entrance transform) */}
133:       <motion.div
134:         animate={shake}
135:         style={{ transformStyle: 'preserve-3d' }}
136:       >
137:         {/* Tilt wrapper */}
138:         <motion.div style={{ rotateX: rx, rotateY: ry, transformStyle: 'preserve-3d' }}>
139:           <Link
140:             to={tile.to}
141:             onMouseEnter={() => setHovered(true)}
142:             onMouseLeave={() => {
143:               setHovered(false);
144:               resetTilt();
145:             }}
146:             onMouseMove={handleTilt}
147:             onFocus={() => setHovered(true)}
148:             onBlur={() => setHovered(false)}
149:             className="group relative block cursor-none rounded-2xl overflow-hidden"
150:             style={{
151:               minHeight: isCenter ? 'clamp(150px, 22vh, 188px)' : 'clamp(140px, 20vh, 172px)',
152:               background: 'rgba(13, 27, 46, 0.42)',
153:               backdropFilter: 'blur(18px)',
154:               WebkitBackdropFilter: 'blur(18px)',
155:               border: `1px solid ${tile.accent}${hovered ? '5a' : '2e'}`,
156:               boxShadow: hovered
157:                 ? `0 0 44px ${tile.accent}26, 0 24px 50px rgba(0,0,0,0.5)`
158:                 : `0 12px 34px rgba(0,0,0,0.34)`,
159:               transition: 'border-color 0.4s ease, box-shadow 0.4s ease',
160:             }}
161:           >
162:             {/* Sheen sweep on hover */}
163:             <motion.div
164:               className="absolute inset-0 pointer-events-none"
165:               initial={{ x: '-130%' }}
166:               animate={hovered && !reduce ? { x: ['-130%', '230%'] } : { x: '-130%' }}
167:               transition={{ duration: 0.9, ease: 'easeInOut' }}
168:               style={{
169:                 background:
170:                   'linear-gradient(105deg, transparent 35%, rgba(255,255,255,0.12) 50%, transparent 65%)',
171:               }}
172:               aria-hidden="true"
173:             />
174:             {/* top accent line */}
175:             <div
176:               className="absolute top-0 inset-x-0 h-px"
177:               style={{
178:                 background: `linear-gradient(90deg, transparent, ${tile.accent}80, transparent)`,
179:               }}
180:               aria-hidden="true"
181:             />
182:             {/* glass sheen */}
183:             <div
184:               className="absolute inset-x-0 top-0 h-1/2 pointer-events-none"
185:               style={{ background: 'linear-gradient(to bottom, rgba(255,255,255,0.07), transparent)' }}
186:               aria-hidden="true"
187:             />
188:             {/* corner brackets */}
189:             <div
190:               className="absolute top-3 left-3 w-3.5 h-3.5 border-t border-l"
191:               style={{ borderColor: `${tile.accent}55` }}
192:               aria-hidden="true"
193:             />
194:             <div
195:               className="absolute bottom-3 right-3 w-3.5 h-3.5 border-b border-r"
196:               style={{ borderColor: `${tile.accent}55` }}
197:               aria-hidden="true"
198:             />
199: 
200:             <div className="relative z-10 flex flex-col h-full p-5">
201:               <span
202:                 className="self-start text-[0.52rem] font-bold tracking-[0.3em] uppercase px-2 py-1 rounded-sm mb-2"
203:                 style={{
