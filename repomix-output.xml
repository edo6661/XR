118:         x: [0, index % 2 === 0 ? 1.6 : -1.6, 0, index % 2 === 0 ? -1.2 : 1.2, 0],
119:         y: [0, -1.4, 1, -0.6, 0],
120:         rotate: [0, index % 2 === 0 ? 0.35 : -0.35, 0, index % 2 === 0 ? -0.25 : 0.25, 0],
