  2: import { createPortal } from 'react-dom';
  3: import { motion, AnimatePresence } from 'framer-motion';
  4: import { X } from 'lucide-react';
  5: import { lenisInstance } from '../../lib/lenisInstance';
  6: 
  7: type GatewayModalProps = {
  8:   open: boolean;
  9:   onClose: () => void;
 10:   title: string;
 11:   children: ReactNode;
 12:   accentColor?: string;
 13: };
 14: 
 15: const GatewayModal = ({ open, onClose, title, children, accentColor = '#fb923c' }: GatewayModalProps) => {
 16:   useEffect(() => {
 17:     if (!open) return;
 18: 
 19:     const onKey = (e: KeyboardEvent) => {
 20:       if (e.key === 'Escape') onClose();
 21:     };
 22: 
 23:     const lenis = lenisInstance.current;
 24:     lenis?.stop();
 25: 
 26:     const html = document.documentElement;
 27:     const { style: htmlStyle } = html;
 28:     const { style: bodyStyle } = document.body;
 29:     const prevHtmlOverflow = htmlStyle.overflow;
 30:     const prevBodyOverflow = bodyStyle.overflow;
 31: 
 32:     htmlStyle.overflow = 'hidden';
 33:     bodyStyle.overflow = 'hidden';
 34: 
 35:     window.addEventListener('keydown', onKey);
 36: 
 37:     return () => {
 38:       htmlStyle.overflow = prevHtmlOverflow;
 39:       bodyStyle.overflow = prevBodyOverflow;
 40:       lenis?.start();
 41:       window.removeEventListener('keydown', onKey);
 42:     };
 43:   }, [open, onClose]);
 44: 
 45:   return createPortal(
 46:     <AnimatePresence>
 47:       {open && (
 48:         <motion.div
 49:           initial={{ opacity: 0 }}
 50:           animate={{ opacity: 1 }}
 51:           exit={{ opacity: 0 }}
 52:           transition={{ duration: 0.25 }}
 53:           className="fixed inset-0 z-[99999] flex items-center justify-center p-4 sm:p-6 bg-[#050505]/90 backdrop-blur-sm overscroll-none"
 54:           role="dialog"
 55:           aria-modal="true"
 56:           aria-labelledby="gateway-modal-title"
 57:         >
 58:           <button
 59:             type="button"
 60:             className="absolute inset-0 bg-[#050b18]/85 backdrop-blur-md"
 61:             onClick={onClose}
 62:             aria-label="Close dialog"
 63:           />
 64: 
 65:           <motion.div
 66:             initial={{ opacity: 0, y: 24, scale: 0.98 }}
 67:             animate={{ opacity: 1, y: 0, scale: 1 }}
 68:             exit={{ opacity: 0, y: 16, scale: 0.98 }}
 69:             transition={{ duration: 0.35, ease: [0.16, 1, 0.3, 1] }}
 70:             className="relative z-10 w-full max-w-2xl max-h-[85vh] overflow-y-auto rounded-xl overscroll-contain"
 71:             style={{
 72:               background: 'linear-gradient(155deg, rgba(22,38,62,0.96) 0%, rgba(10,20,36,0.98) 100%)',
 73:               border: `1px solid ${accentColor}30`,
 74:               boxShadow: `0 0 48px ${accentColor}12, 0 32px 64px rgba(0,0,0,0.5)`,
 75:             }}
 76:           >
 77:             <div
 78:               className="absolute top-0 inset-x-0 h-px"
 79:               style={{
 80:                 background: `linear-gradient(90deg, transparent, ${accentColor}70, transparent)`,
 81:               }}
 82:               aria-hidden="true"
 83:             />
 84: 
 85:             <div className="flex items-center justify-between gap-4 p-6 pb-0">
 86:               <h2
 87:                 id="gateway-modal-title"
 88:                 className="font-heading font-bold text-foreground tracking-wide"
 89:                 style={{ fontSize: '1.05rem' }}
 90:               >
 91:                 {title}
 92:               </h2>
 93:               <button
 94:                 type="button"
 95:                 onClick={onClose}
 96:                 className="flex items-center justify-center w-9 h-9 rounded-sm text-foreground-muted hover:text-accent transition-colors"
 97:                 style={{ border: '1px solid rgba(255,255,255,0.08)' }}
 98:                 aria-label="Close"
 99:               >
100:                 <X size={16} />
101:               </button>
102:             </div>
103: 
104:             <div className="p-6 pt-5">{children}</div>
105:           </motion.div>
106:         </motion.div>
107:       )}
108:     </AnimatePresence>,
109:     document.body,
110:   );
111: };
