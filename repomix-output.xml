<file path="src/components/hero/GlobeCanvas.tsx">
  1: import { useEffect, useRef } from 'react';
  2: import * as THREE from 'three';
  3: 
  4: /**
  5:  * GlobeCanvas — an elegant, "digital Earth" for a Corporate + Next-Worldly read.
  6:  *
  7:  * Continents are rendered as a fine dot-field sampled from a real world map
  8:  * (so it unmistakably reads as Earth, not a generic data sphere), wrapped in a
  9:  * glowing cyan atmosphere over a deep starfield. A handful of luminous
 10:  * great-circle arcs connect the Asia-Pacific host cities — the visual language
 11:  * of a global B2B network. No bitmap astronaut; all depth comes from real 3D
 12:  * geometry + parallax.
 13:  */
 14: 
 15: const DEG = Math.PI / 180;
 16: const RADIUS = 2.05;
 17: 
 18: // Host / partner cities — the "global network" the arcs trace.
 19: const CITIES: { lat: number; lon: number; hub?: boolean }[] = [
 20:   { lat: 3.14, lon: 101.69, hub: true }, // Kuala Lumpur (flagship host)
 21:   { lat: 1.35, lon: 103.82 }, // Singapore
 22:   { lat: 35.68, lon: 139.69 }, // Tokyo
 23:   { lat: 37.57, lon: 126.98 }, // Seoul
 24:   { lat: 31.23, lon: 121.47 }, // Shanghai
 25:   { lat: 19.08, lon: 72.88 }, // Mumbai
 26:   { lat: 25.2, lon: 55.27 }, // Dubai
 27:   { lat: -33.87, lon: 151.21 }, // Sydney
 28:   { lat: 51.51, lon: -0.13 }, // London
 29:   { lat: 37.77, lon: -122.42 }, // San Francisco
 30: ];
 31: 
 32: // Routes radiate from the KL hub (0) + a couple of cross links.
 33: const ROUTES: [number, number][] = [
 34:   [0, 2],
 35:   [0, 6],
 36:   [0, 8],
 37:   [0, 9],
 38:   [0, 3],
 39:   [1, 5],
 40:   [4, 7],
 41: ];
 42: 
 43: const LAND_THRESHOLD = 0.07; // earth-dark.jpg: solid-black continents read darkest
 44: 
 45: function latLonToVec3(lat: number, lon: number, r: number) {
 46:   const phi = lat * DEG;
 47:   const lambda = lon * DEG;
 48:   return new THREE.Vector3(
 49:     r * Math.cos(phi) * Math.cos(lambda),
 50:     r * Math.sin(phi),
 51:     r * Math.cos(phi) * Math.sin(lambda),
 52:   );
 53: }
 54: 
 55: const GlobeCanvas = () => {
 56:   const mountRef = useRef<HTMLDivElement>(null);
 57: 
 58:   useEffect(() => {
 59:     const mount = mountRef.current;
 60:     if (!mount) return;
 61: 
 62:     const prefersReducedMotion = window.matchMedia(
 63:       '(prefers-reduced-motion: reduce)',
 64:     ).matches;
 65:     const isMobile = window.innerWidth < 768;
 66:     const PIXEL = Math.min(window.devicePixelRatio, 1.5);
 67: 
 68:     // ── 1. Scene · Camera · Renderer ───────────────────────────────────────
 69:     const scene = new THREE.Scene();
 70:     const camera = new THREE.PerspectiveCamera(
 71:       45,
 72:       mount.clientWidth / mount.clientHeight,
 73:       0.1,
 74:       100,
 75:     );
 76:     camera.position.set(0, 0, 6.2);
 77: 
 78:     const renderer = new THREE.WebGLRenderer({
 79:       antialias: true,
 80:       alpha: true,
 81:       powerPreference: 'high-performance',
 82:     });
 83:     renderer.setSize(mount.clientWidth, mount.clientHeight);
 84:     renderer.setPixelRatio(PIXEL);
 85:     mount.appendChild(renderer.domElement);
 86: 
 87:     // Brand-aligned palette
 88:     const COL_ATMO = new THREE.Color('#38bdf8'); // cyan atmosphere
 89:     const COL_DOT = new THREE.Color('#7dd3fc'); // light cyan land dots
 90:     const COL_ACCENT = new THREE.Color('#fb923c'); // warm brand orange
 91:     const COL_GRID = new THREE.Color('#2b6f9e');
 92: 
 93:     // Group lets us tilt + parallax everything together
 94:     const globe = new THREE.Group();
 95:     globe.rotation.z = 0.18; // gentle axial tilt
 96:     globe.position.y = -0.15;
 97:     scene.add(globe);
 98: 
 99:     const disposables: { dispose: () => void }[] = [];
100: 
101:     // ── 2. Solid planet body (dark fill + fresnel limb) ────────────────────
102:     const bodyMat = new THREE.ShaderMaterial({
103:       uniforms: {
104:         uDark: { value: new THREE.Color('#040c1a') },
105:         uRim: { value: COL_ATMO },
106:       },
107:       vertexShader: `
108:         varying vec3 vNormal;
109:         varying vec3 vView;
110:         void main() {
111:           vNormal = normalize(normalMatrix * normal);
112:           vec4 mv = modelViewMatrix * vec4(position, 1.0);
113:           vView = normalize(-mv.xyz);
114:           gl_Position = projectionMatrix * mv;
115:         }
116:       `,
117:       fragmentShader: `
118:         uniform vec3 uDark;
119:         uniform vec3 uRim;
120:         varying vec3 vNormal;
121:         varying vec3 vView;
122:         void main() {
123:           float fres = 1.0 - max(dot(vNormal, vView), 0.0);
124:           float limb = pow(fres, 2.6);
125:           vec3 col = mix(uDark, uRim * 0.55, limb);
126:           gl_FragColor = vec4(col, 1.0);
127:         }
128:       `,
129:     });
130:     const bodyGeo = new THREE.SphereGeometry(RADIUS, 64, 64);
131:     const body = new THREE.Mesh(bodyGeo, bodyMat);
132:     globe.add(body);
133:     disposables.push(bodyGeo, bodyMat);
134: 
135:     // ── 3. Atmospheric glow shell (back-side fresnel, additive) ────────────
136:     const atmoMat = new THREE.ShaderMaterial({
137:       uniforms: { uColor: { value: COL_ATMO } },
138:       vertexShader: `
139:         varying vec3 vNormal;
140:         varying vec3 vView;
141:         void main() {
142:           vNormal = normalize(normalMatrix * normal);
143:           vec4 mv = modelViewMatrix * vec4(position, 1.0);
144:           vView = normalize(-mv.xyz);
145:           gl_Position = projectionMatrix * mv;
146:         }
147:       `,
148:       fragmentShader: `
149:         uniform vec3 uColor;
150:         varying vec3 vNormal;
151:         varying vec3 vView;
152:         void main() {
153:           float fres = pow(1.0 - max(dot(vNormal, vView), 0.0), 3.2);
154:           gl_FragColor = vec4(uColor, fres * 0.9);
155:         }
156:       `,
157:       transparent: true,
158:       side: THREE.BackSide,
159:       blending: THREE.AdditiveBlending,
160:       depthWrite: false,
161:     });
162:     const atmoGeo = new THREE.SphereGeometry(RADIUS * 1.16, 64, 64);
163:     const atmosphere = new THREE.Mesh(atmoGeo, atmoMat);
164:     globe.add(atmosphere);
165:     disposables.push(atmoGeo, atmoMat);
166: 
167:     // ── 4. Holographic lat/long grid (kept very faint) ─────────────────────
168:     const gridGeo = new THREE.WireframeGeometry(
169:       new THREE.SphereGeometry(RADIUS * 1.002, 36, 18),
170:     );
171:     const gridMat = new THREE.LineBasicMaterial({
172:       color: COL_GRID,
173:       transparent: true,
174:       opacity: 0.07,
175:       depthWrite: false,
176:     });
177:     const grid = new THREE.LineSegments(gridGeo, gridMat);
178:     globe.add(grid);
179:     disposables.push(gridGeo, gridMat);
180: 
181:     // ── 5. Continent dot-field (sampled from a real world map) ─────────────
182:     // Built async after the land-mask image decodes; falls back to a uniform
183:     // shimmer if the texture cannot be read.
184:     const dotMat = new THREE.ShaderMaterial({
185:       uniforms: {
186:         uTime: { value: 0 },
187:         uColor: { value: COL_DOT },
188:         uAccent: { value: COL_ACCENT },
189:         uSize: { value: 7.0 * PIXEL },
190:       },
191:       vertexShader: `
192:         attribute float aRand;
193:         attribute float aAccent;
194:         uniform float uTime;
195:         uniform float uSize;
196:         varying float vTwinkle;
197:         varying float vAccent;
198:         void main() {
199:           vAccent = aAccent;
200:           vTwinkle = 0.5 + 0.5 * sin(uTime * 1.3 + aRand * 30.0);
201:           vec4 mv = modelViewMatrix * vec4(position, 1.0);
202:           gl_PointSize = uSize * (0.7 + 0.3 * vTwinkle) / -mv.z * 2.0;
203:           gl_Position = projectionMatrix * mv;
204:         }
205:       `,
206:       fragmentShader: `
207:         uniform vec3 uColor;
208:         uniform vec3 uAccent;
209:         varying float vTwinkle;
210:         varying float vAccent;
211:         void main() {
212:           float d = length(gl_PointCoord - vec2(0.5));
213:           if (d > 0.5) discard;
214:           float soft = smoothstep(0.5, 0.0, d);
215:           vec3 c = mix(uColor, uAccent, vAccent);
216:           gl_FragColor = vec4(c, soft * (0.55 + 0.45 * vTwinkle) * 0.9);
217:         }
218:       `,
219:       transparent: true,
220:       depthTest: true, // back-side dots are hidden behind the opaque body
221:       depthWrite: false,
222:       blending: THREE.AdditiveBlending,
223:     });
224:     disposables.push(dotMat);
225:     let dots: THREE.Points | null = null;
226: 
227:     const buildDots = (isLand: ((lat: number, lon: number) => boolean) | null) => {
228:       const SAMPLES = isMobile ? 11000 : 22000;
229:       const goldenPhi = Math.PI * (3 - Math.sqrt(5));
230:       const pos: number[] = [];
231:       const rand: number[] = [];
232:       const accent: number[] = [];
233: 
234:       for (let i = 0; i < SAMPLES; i++) {
235:         const uy = 1 - (i / (SAMPLES - 1)) * 2;
236:         const r = Math.sqrt(Math.max(0, 1 - uy * uy));
237:         const theta = goldenPhi * i;
238:         const ux = Math.cos(theta) * r;
239:         const uz = Math.sin(theta) * r;
240: 
241:         if (isLand) {
242:           const lat = Math.asin(uy) / DEG;
243:           const lon = Math.atan2(uz, ux) / DEG;
244:           if (!isLand(lat, lon)) continue;
245:         }
246: 
247:         pos.push(ux * RADIUS * 1.01, uy * RADIUS * 1.01, uz * RADIUS * 1.01);
248:         rand.push(Math.random());
249:         accent.push(Math.random() > 0.94 ? 1 : 0); // sparse warm nodes
250:       }
251: 
252:       const geo = new THREE.BufferGeometry();
253:       geo.setAttribute('position', new THREE.BufferAttribute(new Float32Array(pos), 3));
254:       geo.setAttribute('aRand', new THREE.BufferAttribute(new Float32Array(rand), 1));
255:       geo.setAttribute('aAccent', new THREE.BufferAttribute(new Float32Array(accent), 1));
256:       dots = new THREE.Points(geo, dotMat);
257:       globe.add(dots);
258:       disposables.push(geo);
259:     };
260: 
261:     const img = new Image();
262:     img.crossOrigin = 'anonymous';
263:     img.onload = () => {
264:       try {
265:         const TW = 1024;
266:         const TH = 512;
267:         const c = document.createElement('canvas');
268:         c.width = TW;
269:         c.height = TH;
270:         const ctx = c.getContext('2d', { willReadFrequently: true });
271:         if (!ctx) {
272:           buildDots(null);
273:           return;
274:         }
275:         ctx.drawImage(img, 0, 0, TW, TH);
276:         const data = ctx.getImageData(0, 0, TW, TH).data;
277:         const isLand = (lat: number, lon: number) => {
278:           let u = (lon + 180) / 360;
279:           u = ((u % 1) + 1) % 1;
280:           const v = Math.min(0.999, Math.max(0, (90 - lat) / 180));
281:           const px = Math.min(TW - 1, Math.floor(u * TW));
282:           const py = Math.min(TH - 1, Math.floor(v * TH));
283:           const idx = (py * TW + px) * 4;
284:           const lum =
285:             (data[idx] * 0.299 + data[idx + 1] * 0.587 + data[idx + 2] * 0.114) / 255;
286:           return lum < LAND_THRESHOLD;
287:         };
288:         buildDots(isLand);
289:       } catch {
290:         buildDots(null); // tainted canvas / read failure → graceful fallback
291:       }
292:     };
293:     img.onerror = () => buildDots(null);
294:     img.src = '/hero/earth-dark.jpg';
295: 
296:     // ── 6. City nodes (pulsing pins at each network endpoint) ──────────────
297:     const cityPos: number[] = [];
298:     const cityRand: number[] = [];
299:     const cityHub: number[] = [];
300:     CITIES.forEach((cty) => {
301:       const v = latLonToVec3(cty.lat, cty.lon, RADIUS * 1.012);
302:       cityPos.push(v.x, v.y, v.z);
303:       cityRand.push(Math.random());
304:       cityHub.push(cty.hub ? 1 : 0);
305:     });
306:     const cityGeo = new THREE.BufferGeometry();
307:     cityGeo.setAttribute('position', new THREE.BufferAttribute(new Float32Array(cityPos), 3));
308:     cityGeo.setAttribute('aRand', new THREE.BufferAttribute(new Float32Array(cityRand), 1));
309:     cityGeo.setAttribute('aHub', new THREE.BufferAttribute(new Float32Array(cityHub), 1));
310:     const cityMat = new THREE.ShaderMaterial({
311:       uniforms: {
312:         uTime: { value: 0 },
313:         uColor: { value: COL_DOT },
314:         uHub: { value: COL_ACCENT },
315:         uSize: { value: 9.0 * PIXEL },
316:       },
317:       vertexShader: `
318:         attribute float aRand;
319:         attribute float aHub;
320:         uniform float uTime;
321:         uniform float uSize;
322:         varying float vPulse;
323:         varying float vHub;
324:         void main() {
325:           vHub = aHub;
326:           vPulse = 0.6 + 0.4 * sin(uTime * 2.2 + aRand * 12.0);
327:           vec4 mv = modelViewMatrix * vec4(position, 1.0);
328:           gl_PointSize = uSize * (aHub > 0.5 ? 1.6 : 1.0) * vPulse / -mv.z * 2.0;
329:           gl_Position = projectionMatrix * mv;
330:         }
331:       `,
332:       fragmentShader: `
333:         uniform vec3 uColor;
334:         uniform vec3 uHub;
335:         varying float vPulse;
336:         varying float vHub;
337:         void main() {
338:           float d = length(gl_PointCoord - vec2(0.5));
339:           if (d > 0.5) discard;
340:           float core = smoothstep(0.5, 0.0, d);
341:           vec3 c = mix(uColor, uHub, vHub);
342:           gl_FragColor = vec4(c, core * vPulse);
343:         }
344:       `,
345:       transparent: true,
346:       depthTest: true,
347:       depthWrite: false,
348:       blending: THREE.AdditiveBlending,
349:     });
350:     const cities = new THREE.Points(cityGeo, cityMat);
351:     globe.add(cities);
352:     disposables.push(cityGeo, cityMat);
353: 
354:     // ── 7. Glowing great-circle arcs + travelling pulses ───────────────────
355:     const arcGroup = new THREE.Group();
356:     globe.add(arcGroup);
357:     const pulses: {
358:       curve: THREE.QuadraticBezierCurve3;
359:       mesh: THREE.Mesh;
360:       speed: number;
361:       offset: number;
362:     }[] = [];
363: 
364:     ROUTES.forEach(([a, b], i) => {
365:       const start = latLonToVec3(CITIES[a].lat, CITIES[a].lon, RADIUS * 1.014);
366:       const end = latLonToVec3(CITIES[b].lat, CITIES[b].lon, RADIUS * 1.014);
367:       const dist = start.distanceTo(end);
368:       const lift = 1 + 0.16 + (dist / (RADIUS * 2)) * 0.4;
369:       const ctrl = start
370:         .clone()
371:         .add(end)
372:         .multiplyScalar(0.5)
373:         .normalize()
374:         .multiplyScalar(RADIUS * lift);
375:       const curve = new THREE.QuadraticBezierCurve3(start, ctrl, end);
376: 
377:       const accentArc = i % 3 === 0;
378:       const color = accentArc ? COL_ACCENT : COL_DOT;
379: 
380:       const arcGeo = new THREE.BufferGeometry().setFromPoints(curve.getPoints(64));
381:       const arcMat = new THREE.LineBasicMaterial({
382:         color,
383:         transparent: true,
384:         opacity: accentArc ? 0.26 : 0.16,
385:         depthWrite: false,
386:       });
387:       arcGroup.add(new THREE.Line(arcGeo, arcMat));
388:       disposables.push(arcGeo, arcMat);
389: 
390:       const pulseGeo = new THREE.SphereGeometry(accentArc ? 0.03 : 0.024, 8, 8);
391:       const pulseMat = new THREE.MeshBasicMaterial({
392:         color,
393:         transparent: true,
394:         blending: THREE.AdditiveBlending,
395:         depthWrite: false,
396:       });
397:       const pulse = new THREE.Mesh(pulseGeo, pulseMat);
398:       arcGroup.add(pulse);
399:       disposables.push(pulseGeo, pulseMat);
400: 
401:       pulses.push({
402:         curve,
403:         mesh: pulse,
404:         speed: 0.1 + (i % 3) * 0.03,
405:         offset: (i / ROUTES.length) % 1,
406:       });
407:     });
408: 
409:     // ── 8. Inclined orbit rings + travelling satellites ────────────────────
410:     const orbits: { mat: THREE.LineBasicMaterial; sat: THREE.Mesh; speed: number; r: number }[] = [];
411:     const orbitConfigs = [
412:       { r: RADIUS * 1.45, tilt: 0.5, speed: 0.32, color: COL_ATMO },
413:       { r: RADIUS * 1.7, tilt: -0.9, speed: -0.22, color: COL_ACCENT },
414:       { r: RADIUS * 1.95, tilt: 1.35, speed: 0.16, color: COL_DOT },
415:     ];
416:     orbitConfigs.forEach(({ r, tilt, speed, color }) => {
417:       const segs = 128;
418:       const pts: number[] = [];
419:       for (let i = 0; i <= segs; i++) {
420:         const a = (i / segs) * Math.PI * 2;
421:         pts.push(Math.cos(a) * r, 0, Math.sin(a) * r);
422:       }
423:       const ringGeo = new THREE.BufferGeometry();
424:       ringGeo.setAttribute('position', new THREE.BufferAttribute(new Float32Array(pts), 3));
425:       const ringMat = new THREE.LineBasicMaterial({
426:         color,
427:         transparent: true,
428:         opacity: 0.1,
429:         depthWrite: false,
430:       });
431:       const ring = new THREE.Line(ringGeo, ringMat);
432:       ring.rotation.x = tilt;
433:       globe.add(ring);
434:       disposables.push(ringGeo, ringMat);
435: 
436:       const satGeo = new THREE.SphereGeometry(0.03, 12, 12);
437:       const satMat = new THREE.MeshBasicMaterial({ color });
438:       const sat = new THREE.Mesh(satGeo, satMat);
439:       ring.add(sat);
440:       disposables.push(satGeo, satMat);
441:       orbits.push({ mat: ringMat, sat, speed, r });
442:     });
443: 
444:     // ── 9. Deep starfield ──────────────────────────────────────────────────
445:     const starCount = isMobile ? 800 : 1400;
446:     const starPos = new Float32Array(starCount * 3);
447:     const starRand = new Float32Array(starCount);
448:     for (let i = 0; i < starCount; i++) {
449:       const i3 = i * 3;
450:       starPos[i3] = (Math.random() - 0.5) * 60;
451:       starPos[i3 + 1] = (Math.random() - 0.5) * 40;
452:       starPos[i3 + 2] = -10 - Math.random() * 30;
453:       starRand[i] = Math.random();
454:     }
455:     const starGeo = new THREE.BufferGeometry();
456:     starGeo.setAttribute('position', new THREE.BufferAttribute(starPos, 3));
457:     starGeo.setAttribute('aRand', new THREE.BufferAttribute(starRand, 1));
458:     const starMat = new THREE.ShaderMaterial({
459:       uniforms: { uTime: { value: 0 }, uPixel: { value: PIXEL } },
460:       vertexShader: `
461:         attribute float aRand;
462:         uniform float uTime;
463:         uniform float uPixel;
464:         varying float vT;
465:         void main() {
466:           vT = 0.4 + 0.6 * sin(uTime * 0.9 + aRand * 25.0);
467:           vec4 mv = modelViewMatrix * vec4(position, 1.0);
468:           gl_PointSize = (1.0 + aRand * 2.0) * uPixel;
469:           gl_Position = projectionMatrix * mv;
470:         }
471:       `,
472:       fragmentShader: `
473:         varying float vT;
474:         void main() {
475:           float d = length(gl_PointCoord - vec2(0.5));
476:           if (d > 0.5) discard;
477:           gl_FragColor = vec4(0.78, 0.86, 1.0, smoothstep(0.5, 0.0, d) * vT * 0.7);
478:         }
479:       `,
480:       transparent: true,
481:       depthWrite: false,
482:       blending: THREE.AdditiveBlending,
483:     });
484:     const stars = new THREE.Points(starGeo, starMat);
485:     scene.add(stars);
486:     disposables.push(starGeo, starMat);
487: 
488:     // ── 10. Mouse parallax ─────────────────────────────────────────────────
489:     let mouseX = 0;
490:     let mouseY = 0;
491:     const onMouseMove = (e: MouseEvent) => {
492:       mouseX = (e.clientX / window.innerWidth) * 2 - 1;
493:       mouseY = -(e.clientY / window.innerHeight) * 2 + 1;
494:     };
495:     window.addEventListener('mousemove', onMouseMove, { passive: true });
496: 
497:     // ── 11. Animation loop (pauses when offscreen / tab hidden) ────────────
498:     let animId = 0;
499:     let running = false;
500:     const clock = new THREE.Clock();
501:     const rotSpeed = prefersReducedMotion ? 0.01 : 0.04;
502:     const tmp = new THREE.Vector3();
503: 
504:     const animate = () => {
505:       const t = clock.getElapsedTime();
506: 
507:       dotMat.uniforms.uTime.value = t;
508:       cityMat.uniforms.uTime.value = t;
509:       starMat.uniforms.uTime.value = t;
510: 
511:       globe.rotation.y = t * rotSpeed;
512:       stars.rotation.y = t * 0.006;
513: 
514:       orbits.forEach(({ mat, sat, speed, r }) => {
515:         const a = t * speed;
516:         sat.position.set(Math.cos(a) * r, 0, Math.sin(a) * r);
517:         mat.opacity = 0.08 + 0.04 * Math.sin(t * 0.8 + r);
518:       });
519: 
520:       pulses.forEach(({ curve, mesh, speed, offset }) => {
521:         const tt = (t * speed + offset) % 1;
522:         curve.getPointAt(tt, tmp);
523:         mesh.position.copy(tmp);
524:         const fade = Math.sin(tt * Math.PI); // dim near the endpoints
525:         (mesh.material as THREE.MeshBasicMaterial).opacity = 0.25 + 0.75 * fade;
526:         const s = 0.7 + 0.5 * fade;
527:         mesh.scale.setScalar(s);
528:       });
529: 
530:       // smooth camera + group parallax (the depth illusion)
531:       const tx = mouseX * 0.5;
532:       const ty = mouseY * 0.32;
533:       camera.position.x += (tx - camera.position.x) * 0.04;
534:       camera.position.y += (ty + -0.15 - camera.position.y) * 0.04;
535:       camera.lookAt(0, -0.15, 0);
536: 
537:       globe.rotation.x += (mouseY * 0.12 - globe.rotation.x) * 0.04;
538: 
539:       renderer.render(scene, camera);
540:       animId = requestAnimationFrame(animate);
541:     };
542: 
543:     const start = () => {
544:       if (running) return;
545:       running = true;
546:       clock.getDelta(); // swallow the paused gap so rotation doesn't jump
547:       animId = requestAnimationFrame(animate);
548:     };
549:     const stop = () => {
550:       running = false;
551:       cancelAnimationFrame(animId);
552:     };
553: 
554:     // Pause render when the hero scrolls out of view.
555:     const io = new IntersectionObserver(
556:       ([entry]) => {
557:         if (entry.isIntersecting && !document.hidden) start();
558:         else stop();
559:       },
560:       { threshold: 0.01 },
561:     );
562:     io.observe(mount);
563: 
564:     const onVisibility = () => {
565:       if (document.hidden) stop();
566:       else start();
567:     };
568:     document.addEventListener('visibilitychange', onVisibility);
569: 
570:     start();
571: 
572:     // ── 12. Resize ─────────────────────────────────────────────────────────
573:     const onResize = () => {
574:       camera.aspect = mount.clientWidth / mount.clientHeight;
575:       camera.updateProjectionMatrix();
576:       renderer.setSize(mount.clientWidth, mount.clientHeight);
577:     };
578:     window.addEventListener('resize', onResize, { passive: true });
579: 
580:     // ── Cleanup ────────────────────────────────────────────────────────────
581:     return () => {
582:       stop();
583:       io.disconnect();
584:       document.removeEventListener('visibilitychange', onVisibility);
585:       window.removeEventListener('mousemove', onMouseMove);
586:       window.removeEventListener('resize', onResize);
587:       img.onload = null;
588:       img.onerror = null;
589:       disposables.forEach((d) => d.dispose());
590:       renderer.dispose();
591:       renderer.domElement.remove();
592:     };
593:   }, []);
594: 
595:   return (
596:     <div
597:       ref={mountRef}
598:       className="absolute inset-0 w-full h-full pointer-events-none"
599:       aria-hidden="true"
600:     />
601:   );
602: };
603: 
604: export default GlobeCanvas;
</file>

