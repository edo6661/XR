<file path="src/components/ui/MagneticWrapper.tsx">
 1: // src/components/ui/MagneticWrapper.tsx
 2: import { useRef } from 'react';
 3: import { motion, useMotionValue, useSpring } from 'framer-motion';
 4: 
 5: interface MagneticWrapperProps {
 6:   children: React.ReactNode;
 7:   strength?: number;
 8:   className?: string;
 9: }
10: 
11: const MagneticWrapper = ({ children, strength = 0.3, className = "" }: MagneticWrapperProps) => {
12:   const ref = useRef<HTMLDivElement>(null);
13:   // Cache dimensi untuk menghindari Layout Thrashing
14:   const bounds = useRef<{ left: number; top: number; width: number; height: number } | null>(null);
15: 
16:   const x = useMotionValue(0);
17:   const y = useMotionValue(0);
18: 
19:   const springConfig = { stiffness: 150, damping: 15, mass: 0.1 };
20:   const springX = useSpring(x, springConfig);
21:   const springY = useSpring(y, springConfig);
22: 
23:   // Ambil dimensi HANYA saat mouse mulai masuk
24:   const handleMouseEnter = () => {
25:     if (ref.current) {
26:       bounds.current = ref.current.getBoundingClientRect();
27:     }
28:   };
29: 
30:   const handleMouseMove = (e: React.MouseEvent<HTMLDivElement>) => {
31:     if (!bounds.current) return;
32: 
33:     const { left, top, width, height } = bounds.current;
34:     const centerX = left + width / 2;
35:     const centerY = top + height / 2;
36: 
37:     x.set((e.clientX - centerX) * strength);
38:     y.set((e.clientY - centerY) * strength);
39:   };
40: 
41:   const handleMouseLeave = () => {
42:     bounds.current = null; // Reset cache
43:     x.set(0);
44:     y.set(0);
45:   };
46: 
47:   return (
48:     <motion.div
49:       ref={ref}
50:       onMouseEnter={handleMouseEnter}
51:       onMouseMove={handleMouseMove}
52:       onMouseLeave={handleMouseLeave}
53:       style={{ x: springX, y: springY }}
54:       className={`inline-block ${className}`}
55:     >
56:       {children}
57:     </motion.div>
58:   );
59: };
60: 
61: export default MagneticWrapper;
</file>

<file path="src/components/ui/ScrambleText.tsx">
 1: // src/components/ui/ScrambleText.tsx
 2: import { useRef, useEffect } from 'react';
 3: 
 4: const CHARS = '!<>-_\\/[]{}—=+*^?#010101';
 5: 
 6: const ScrambleText = ({ text }: { text: string }) => {
 7:   const textRef = useRef<HTMLSpanElement>(null);
 8:   const intervalRef = useRef<number | null>(null);
 9: 
10:   const handleMouseEnter = () => {
11:     if (!textRef.current) return;
12:     let iteration = 0;
13: 
14:     // Bersihkan interval sebelumnya jika ada
15:     if (intervalRef.current) clearInterval(intervalRef.current);
16: 
17:     intervalRef.current = window.setInterval(() => {
18:       // Mutasi DOM langsung, TANPA trigger React re-render
19:       textRef.current!.textContent = text
20:         .split('')
21:         .map((_, index) => {
22:           if (index < iteration) return text[index];
23:           return CHARS[Math.floor(Math.random() * CHARS.length)];
24:         })
25:         .join('');
26: 
27:       iteration += 1 / 2.5;
28: 
29:       if (iteration >= text.length) clearInterval(intervalRef.current!);
30:     }, 30);
31:   };
32: 
33:   const handleMouseLeave = () => {
34:     if (intervalRef.current) clearInterval(intervalRef.current);
35:     if (textRef.current) textRef.current.textContent = text; // Kembalikan ke teks asli
36:   };
37: 
38:   useEffect(() => {
39:     return () => {
40:       if (intervalRef.current) clearInterval(intervalRef.current);
41:     };
42:   }, []);
43: 
44:   return (
45:     <span
46:       ref={textRef}
47:       onMouseEnter={handleMouseEnter}
48:       onMouseLeave={handleMouseLeave}
49:       className="inline-block whitespace-nowrap"
50:     >
51:       {text}
52:     </span>
53:   );
54: };
55: 
56: export default ScrambleText;
</file>

