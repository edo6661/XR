 54: const HeroGatewayTiles = ({ active }: HeroGatewayTilesProps) => {
 55:   const reduce = useReducedMotion();
 56: 
 57:   return (
 58:     <div
 59:       className="relative z-20 w-full max-w-4xl mt-1 sm:mt-2"
 60:       style={{ perspective: '1200px', pointerEvents: active ? 'auto' : 'none' }}
 61:     >
 62:       <div className="grid grid-cols-1 sm:grid-cols-3 gap-4 sm:gap-5 items-stretch">
 63:         {TILES.map((tile, i) => (
 64:           <TileCard
 65:             key={tile.title + i}
 66:             tile={tile}
 67:             index={i}
 68:             active={active}
 69:             isCenter={i === 1}
 70:             reduce={!!reduce}
 71:           />
 72:         ))}
 73:       </div>
 74:     </div>
 75:   );
 76: };
