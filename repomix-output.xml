<file path="src/hooks/useScrollAnimations.ts">
  1: import { useEffect, useRef } from "react";
  2: import gsap from "gsap";
  3: import { ScrollTrigger } from "gsap/ScrollTrigger";
  4: 
  5: gsap.registerPlugin(ScrollTrigger);
  6: 
  7: // ── Fade + slide up on scroll ─────────────────────────────────────────────
  8: export const useScrollReveal = (options?: {
  9:   y?: number;
 10:   delay?: number;
 11:   stagger?: number;
 12:   threshold?: string;
 13: }) => {
 14:   const ref = useRef<HTMLDivElement>(null);
 15: 
 16:   useEffect(() => {
 17:     const el = ref.current;
 18:     if (!el) return;
 19: 
 20:     const targets = el.querySelectorAll("[data-reveal]");
 21:     if (!targets.length) return;
 22: 
 23:     gsap.set(targets, { y: options?.y ?? 50, opacity: 0 });
 24: 
 25:     const ctx = gsap.context(() => {
 26:       gsap.to(targets, {
 27:         y: 0,
 28:         opacity: 1,
 29:         duration: 1,
 30:         stagger: options?.stagger ?? 0.12,
 31:         delay: options?.delay ?? 0,
 32:         ease: "power3.out",
 33:         scrollTrigger: {
 34:           trigger: el,
 35:           start: options?.threshold ?? "top 78%",
 36:           toggleActions: "play none none none",
 37:         },
 38:       });
 39:     }, el);
 40: 
 41:     return () => ctx.revert();
 42:   }, [options?.y, options?.delay, options?.stagger, options?.threshold]);
 43: 
 44:   return ref;
 45: };
 46: 
 47: // ── Counting number animation ─────────────────────────────────────────────
 48: export const useCountUp = (target: number, suffix = "", duration = 2.2) => {
 49:   const ref = useRef<HTMLSpanElement>(null);
 50: 
 51:   useEffect(() => {
 52:     const el = ref.current;
 53:     if (!el) return;
 54: 
 55:     const obj = { val: 0 };
 56: 
 57:     const ctx = gsap.context(() => {
 58:       gsap.to(obj, {
 59:         val: target,
 60:         duration,
 61:         ease: "power2.out",
 62:         scrollTrigger: {
 63:           trigger: el,
 64:           start: "top 85%",
 65:           toggleActions: "play none none none",
 66:         },
 67:         onUpdate: () => {
 68:           el.textContent = Math.round(obj.val) + suffix;
 69:         },
 70:       });
 71:     });
 72: 
 73:     return () => ctx.revert();
 74:   }, [target, suffix, duration]);
 75: 
 76:   return ref;
 77: };
 78: 
 79: // ── Horizontal parallax for a container ───────────────────────────────────
 80: export const useParallaxX = (speed = 0.15) => {
 81:   const ref = useRef<HTMLDivElement>(null);
 82: 
 83:   useEffect(() => {
 84:     const el = ref.current;
 85:     if (!el) return;
 86: 
 87:     const ctx = gsap.context(() => {
 88:       gsap.to(el, {
 89:         x: () => -speed * window.innerWidth,
 90:         ease: "none",
 91:         scrollTrigger: {
 92:           trigger: el,
 93:           start: "top bottom",
 94:           end: "bottom top",
 95:           scrub: 1.5,
 96:         },
 97:       });
 98:     });
 99: 
100:     return () => ctx.revert();
101:   }, [speed]);
102: 
103:   return ref;
104: };
105: 
106: // ── Vertical parallax ─────────────────────────────────────────────────────
107: export const useParallaxY = (speed = 0.2) => {
108:   const ref = useRef<HTMLDivElement>(null);
109: 
110:   useEffect(() => {
111:     const el = ref.current;
112:     if (!el) return;
113: 
114:     const ctx = gsap.context(() => {
115:       gsap.to(el, {
116:         y: () => speed * 200,
117:         ease: "none",
118:         scrollTrigger: {
119:           trigger: el,
120:           start: "top bottom",
121:           end: "bottom top",
122:           scrub: 2,
123:         },
124:       });
125:     });
126: 
127:     return () => ctx.revert();
128:   }, [speed]);
129: 
130:   return ref;
131: };
</file>

