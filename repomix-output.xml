  5: const ProgramCard = ({ program, index }: { program: XrasProgram; index: number }) => (
  6:   <motion.article
  7:     initial={{ opacity: 0, y: 20 }}
  8:     whileInView={{ opacity: 1, y: 0 }}
  9:     viewport={{ once: true, amount: 0.2 }}
 10:     transition={{ delay: (index % 4) * 0.05, duration: 0.6, ease: [0.16, 1, 0.3, 1] }}
 11:     className={`relative flex flex-col h-full rounded-xl overflow-hidden transition-all duration-400 ${
 12:       program.featured ? 'md:col-span-1' : ''
 13:     }`}
 14:     style={{
 15:       background: program.featured
 16:         ? 'linear-gradient(155deg, rgba(22,38,62,0.85) 0%, rgba(13,27,46,0.92) 100%)'
 17:         : 'rgba(10, 20, 36, 0.72)',
 18:       border: `1px solid ${program.featured ? `${XRAS_KL_ACCENT}28` : 'rgba(255,255,255,0.07)'}`,
 19:       boxShadow: program.featured ? `0 0 40px ${XRAS_KL_ACCENT}08` : 'none',
 20:     }}
 21:   >
 22:     <div
 23:       className="absolute top-0 inset-x-0 h-px"
 24:       style={{
 25:         background: `linear-gradient(90deg, transparent, ${XRAS_KL_ACCENT}${program.featured ? '55' : '25'}, transparent)`,
 26:       }}
 27:       aria-hidden="true"
 28:     />
 29: 
 30:     <div className="p-6 flex flex-col flex-1 gap-4">
 31:       <div className="flex items-center justify-between gap-2">
 32:         <span
 33:           className="font-bold tracking-[0.32em] uppercase px-2.5 py-1 rounded-sm"
 34:           style={{
 35:             fontSize: '0.5rem',
 36:             color: XRAS_KL_ACCENT,
 37:             background: `${XRAS_KL_ACCENT}12`,
 38:             border: `1px solid ${XRAS_KL_ACCENT}22`,
 39:           }}
 40:         >
 41:           {program.category}
 42:         </span>
 43:         <span
 44:           className="font-mono text-[0.48rem] tracking-[0.25em]"
 45:           style={{ color: 'rgba(107,127,163,0.35)' }}
 46:         >
 47:           {String(index + 1).padStart(2, '0')}
 48:         </span>
 49:       </div>
 50: 
 51:       <h3
 52:         className="font-heading font-bold text-foreground leading-snug"
 53:         style={{ fontSize: program.featured ? '1.15rem' : '1rem' }}
 54:       >
 55:         {program.title}
 56:       </h3>
 57: 
 58:       <p
 59:         className="text-foreground-muted flex-1 leading-relaxed"
 60:         style={{ fontSize: '0.8rem', lineHeight: 1.75 }}
 61:       >
 62:         {program.description}
 63:       </p>
 64:     </div>
 65:   </motion.article>
 66: );
