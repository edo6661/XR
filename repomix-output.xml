<file path="src/components/ui/StackedSection.tsx">
 1: import { useEffect, useLayoutEffect, useRef, type ReactNode } from 'react';
 2: import gsap from 'gsap';
 3: import { ScrollTrigger } from 'gsap/ScrollTrigger';
 4: import { killScrollTriggersIn } from '../../lib/scrollTriggerCleanup';
 5: 
 6: gsap.registerPlugin(ScrollTrigger);
 7: 
 8: interface StackedSectionProps {
 9:   children: ReactNode;
10:   zIndex: number;
11:   isLast?: boolean;
12: }
13: 
14: const StackedSection = ({ children, zIndex, isLast = false }: StackedSectionProps) => {
15:   const outerRef = useRef<HTMLDivElement>(null);
16:   const sectionRef = useRef<HTMLDivElement>(null);
17:   const contentRef = useRef<HTMLDivElement>(null);
18: 
19:   useEffect(() => {
20:     const section = sectionRef.current;
21:     const content = contentRef.current;
22:     if (!section || !content || isLast) return;
23: 
24:     const ctx = gsap.context(() => {
25:       const handleResize = () => {
26:         const isTall = section.offsetHeight > window.innerHeight;
27:         gsap.set(content, { transformOrigin: isTall ? 'center bottom' : 'center top' });
28:       };
29: 
30:       handleResize();
31:       window.addEventListener('resize', handleResize);
32: 
33:       gsap.to(content, {
34:         scale: 0.94,         // 1. Skala tidak mengecil terlalu jauh (hanya efek depth halus)
35:         opacity: 0.3,        // 2. Jangan diturunkan sampai 0, biarkan tersisa sedikit agar seperti tertumpuk bayangan
36:         ease: 'power3.in',   // 3. KUNCI UTAMA: Animasi ditahan di awal scroll, meredupnya perlahan nanti di akhir
37:         scrollTrigger: {
38:           trigger: section,
39:           start: () =>
40:             section.offsetHeight > window.innerHeight
41:               ? 'bottom bottom'
42:               : 'top top',
43:           end: () => `+=${window.innerHeight}`, // 4. Set persis 1 tinggi layar agar sinkron dengan section bawah yang naik
44:           scrub: true,       // 5. Ganti ke true (tanpa delay angka) agar animasinya responsif dan solid menempel dengan posisi jari/mouse
45:           pin: true,
46:           pinSpacing: false,
47:           invalidateOnRefresh: true,
48:         },
49:       });
50: 
51:       return () => {
52:         window.removeEventListener('resize', handleResize);
53:       };
54:     }, outerRef);
55: 
56:     return () => ctx.revert();
