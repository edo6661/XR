<file path="src/components/layout/Layout.tsx">
 1: import { useEffect, useLayoutEffect, useRef } from 'react';
 2: import { Outlet, useLocation } from 'react-router-dom';
 3: import Lenis from 'lenis';
 4: import gsap from 'gsap';
 5: import { ScrollTrigger } from 'gsap/ScrollTrigger';
 6: import Navbar from './Navbar';
 7: import Footer from './Footer';
 8: import CustomCursor from '../ui/CustomCursor';
 9: import ScrollProgress from '../ui/ScrollProgress';
10: import FilmGrain from '../ui/FilmGrain';
11: import BackgroundElements from '../ui/BackgroundElements';
12: import { lenisInstance } from '../../lib/lenisInstance';
13: import { killPinnedScrollTriggers } from '../../lib/scrollTriggerCleanup';
14: 
15: gsap.registerPlugin(ScrollTrigger);
16: 
17: const Layout = () => {
18:   const lenisRef = useRef<Lenis | null>(null);
19:   const location = useLocation();
20: 
21:   useEffect(() => {
22:     const lenis = new Lenis({
23:       duration: 1.4,
24:       easing: (t: number) => Math.min(1, 1.001 - Math.pow(2, -10 * t)),
25:       orientation: 'vertical',
26:       smoothWheel: true,
27:       touchMultiplier: 2,
28:     });
29: 
30:     lenisRef.current = lenis;
31:     lenisInstance.current = lenis;
32: 
33:     lenis.on('scroll', ScrollTrigger.update);
34: 
35:     const onTick = (time: number) => {
36:       lenis.raf(time * 1000);
37:     };
38: 
39:     gsap.ticker.add(onTick);
40:     gsap.ticker.lagSmoothing(0);
41: 
42:     return () => {
43:       gsap.ticker.remove(onTick);
44:       lenis.destroy();
45:       lenisInstance.current = null;
46:     };
47:   }, []);
48: 
49:   useLayoutEffect(() => {
50:     killPinnedScrollTriggers();
51:     lenisInstance.current?.scrollTo(0, { immediate: true });
52: 
53:     return () => {
54:       killPinnedScrollTriggers();
55:     };
56:   }, [location.pathname]);
57: 
58:   useEffect(() => {
59:     const refreshId = window.setTimeout(() => {
60:       ScrollTrigger.refresh();
61:     }, 100);
62: 
63:     return () => window.clearTimeout(refreshId);
64:   }, [location.pathname]);
65: 
66:   return (
67:     <div className="relative min-h-screen w-full overflow-x-hidden text-foreground flex flex-col selection:bg-accent/30 selection:text-white">
68:       <BackgroundElements />
69:       <FilmGrain />
70: 
71:       <CustomCursor />
72:       <ScrollProgress />
73:       <Navbar />
74: 
75:       <div className="relative z-10 bg-background shadow-[0_20px_50px_rgba(0,0,0,0.9)]">
76:         <main className="flex-1 flex flex-col">
77:           <Outlet />
78:         </main>
79:       </div>
80: 
81:       <div className="sticky bottom-0 z-0 h-auto">
82:         <Footer />
83:       </div>
84:     </div>
85:   );
86: };
87: 
88: export default Layout;
</file>

