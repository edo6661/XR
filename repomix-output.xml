  1: import { useEffect, useState, useRef } from 'react';
  2: import { motion, AnimatePresence } from 'framer-motion';
  3: import gsap from 'gsap';
  4: 
  5: interface PreloaderProps {
  6:   onComplete: () => void;
  7: }
  8: 
  9: const LOADING_STEPS = [
 10:   'Initialising spatial engine',
 11:   'Loading immersive assets',
 12:   'Calibrating XR environment',
 13:   'Ready',
 14: ];
 15: 
 16: const Preloader = ({ onComplete }: PreloaderProps) => {
 17:   const [progress, setProgress] = useState(0);
 18:   const [stepIndex, setStepIndex] = useState(0);
 19:   const [done, setDone] = useState(false);
 20:   const barRef = useRef<HTMLDivElement>(null);
 21:   const counterRef = useRef<HTMLSpanElement>(null);
 22: 
 23:   useEffect(() => {
 24:     const totalDuration = 2200;
 25:     const interval = 18;
 26:     const stepSize = 100 / (totalDuration / interval);
 27:     let current = 0;
 28: 
 29:     const timer = setInterval(() => {
 30:       current += stepSize;
 31:       const clamped = Math.min(Math.floor(current), 100);
 32:       setProgress(clamped);
 33: 
 34:       // Update step label at 25 / 55 / 80 / 100
 35:       if (clamped >= 100) setStepIndex(3);
 36:       else if (clamped >= 80) setStepIndex(2);
 37:       else if (clamped >= 55) setStepIndex(1);
 38:       else if (clamped >= 25) setStepIndex(0);
 39: 
 40:       if (clamped >= 100) {
 41:         clearInterval(timer);
 42:         setTimeout(() => {
 43:           setDone(true);
 44:           setTimeout(onComplete, 900);
 45:         }, 300);
 46:       }
 47:     }, interval);
 48: 
 49:     return () => clearInterval(timer);
 50:   }, [onComplete]);
 51: 
 52:   // Animate bar width
 53:   useEffect(() => {
 54:     if (barRef.current) {
 55:       gsap.to(barRef.current, {
 56:         width: `${progress}%`,
 57:         duration: 0.15,
 58:         ease: 'none',
 59:       });
 60:     }
 61:   }, [progress]);
 62: 
 63:   return (
 64:     <AnimatePresence>
 65:       {!done && (
 66:         <motion.div
 67:           key="preloader"
 68:           className="fixed inset-0 z-[99999] flex flex-col items-center justify-center overflow-hidden select-none"
 69:           style={{ background: '#050b18' }}
 70:           exit={{
 71:             clipPath: ['inset(0% 0% 0% 0%)', 'inset(0% 0% 100% 0%)'],
 72:             transition: { duration: 0.85, ease: [0.76, 0, 0.24, 1] },
 73:           }}
 74:         >
 75:           {/* Atmospheric glow */}
 76:           <div
 77:             className="absolute inset-0 pointer-events-none"
 78:             style={{
 79:               background:
 80:                 'radial-gradient(ellipse 60% 40% at 50% 50%, rgba(251,146,60,0.06) 0%, transparent 70%)',
 81:             }}
 82:             aria-hidden="true"
 83:           />
 84: 
 85:           {/* Grid texture */}
 86:           <div
 87:             className="absolute inset-0 opacity-[0.015] pointer-events-none"
 88:             style={{
 89:               backgroundImage:
 90:                 'linear-gradient(rgba(255,255,255,0.6) 1px, transparent 1px), linear-gradient(90deg, rgba(255,255,255,0.6) 1px, transparent 1px)',
 91:               backgroundSize: '64px 64px',
 92:             }}
 93:             aria-hidden="true"
 94:           />
 95: 
 96:           {/* Top-left meta */}
 97:           <div
 98:             className="absolute top-8 left-8 flex flex-col gap-1"
 99:             aria-hidden="true"
100:           >
101:             <span
102:               className="font-mono tracking-[0.35em] uppercase"
103:               style={{ fontSize: '0.48rem', color: 'rgba(107,127,163,0.4)' }}
104:             >
105:               XRAS · 2026
106:             </span>
107:             <span
108:               className="font-mono tracking-[0.35em] uppercase"
109:               style={{ fontSize: '0.48rem', color: 'rgba(107,127,163,0.25)' }}
110:             >
111:               KUL · 03°08′N
112:             </span>
113:           </div>
114: 
115:           {/* Bottom-right version */}
116:           <div className="absolute bottom-8 right-8" aria-hidden="true">
117:             <span
118:               className="font-mono tracking-[0.35em] uppercase"
119:               style={{ fontSize: '0.48rem', color: 'rgba(107,127,163,0.3)' }}
120:             >
121:               v4.0
122:             </span>
123:           </div>
124: 
125:           {/* Center content */}
126:           <div className="relative z-10 flex flex-col items-center gap-8 w-full max-w-xs px-8">
127: 
128:             {/* Logo mark */}
129:             <motion.div
130:               initial={{ scale: 0.7, opacity: 0 }}
131:               animate={{ scale: 1, opacity: 1 }}
132:               transition={{ duration: 0.7, ease: [0.16, 1, 0.3, 1] }}
133:               className="relative"
134:             >
135:               <div
136:                 className="absolute inset-[-12px] rounded-full opacity-30 animate-pulse"
137:                 style={{
138:                   background: 'radial-gradient(circle, rgba(251,146,60,0.5) 0%, transparent 65%)',
139:                   animationDuration: '2.5s',
140:                 }}
141:                 aria-hidden="true"
142:               />
143:               <img
144:                 src="/logo-278x262-removebg.png"
145:                 alt="XR Summits"
146:                 className="relative h-14 w-auto object-contain"
147:                 style={{ filter: 'drop-shadow(0 0 12px rgba(251,146,60,0.45))' }}
148:               />
149:             </motion.div>
150: 
151:             {/* Counter */}
152:             <div className="flex flex-col items-center gap-1 w-full">
153:               <div className="flex items-end justify-center gap-1.5">
154:                 <span
155:                   ref={counterRef}
156:                   className="font-heading font-black tabular-nums leading-none"
157:                   style={{
158:                     fontSize: 'clamp(4.5rem, 16vw, 7rem)',
159:                     background: 'linear-gradient(135deg, #f0f4ff 30%, #fb923c 100%)',
160:                     WebkitBackgroundClip: 'text',
161:                     WebkitTextFillColor: 'transparent',
162:                     backgroundClip: 'text',
163:                     minWidth: '3.2ch',
