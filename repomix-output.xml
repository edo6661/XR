<file path="src/components/sponsors/SponsorsSection.tsx">
  1: import { useRef } from 'react';
  2: import { Link } from 'react-router-dom';
  3: import { motion, useReducedMotion } from 'framer-motion';
  4: import SectionEyebrow from '../ui/SectionEyebrow';
  5: 
  6: /**
  7:  * Partner logos — derived from the actual assets in /public/all-partner-logos/
  8:  * Group 1: Government / Ecosystem Partners
  9:  * Group 2: Technology Partners
 10:  * All merged into one infinite slider.
 11:  */
 12: type Partner = {
 13:   name: string;
 14:   src: string;
 15:   needsInvert?: boolean;
 16: };
 17: 
 18: const GOVERNMENT_PARTNERS: Partner[] = [
 19:   { name: 'Broadcast Elements (BE)', src: '/all-partner-logos/Logo_BE_Malaysia.png' },
 20:   { name: 'Centre of Excellence (COE)', src: '/all-partner-logos/COE LOGO_PNG_Med res.png' },
 21:   { name: 'Digital Content Creation (DCC)', src: '/all-partner-logos/DCC-Logo_OP.png' },
 22:   { name: 'FINAS', src: '/all-partner-logos/FINAS.png' },
 23:   { name: 'MDEC', src: '/all-partner-logos/MDEC_logo.png' },
 24:   { name: 'POSTAM', src: '/all-partner-logos/postamsmall.png' },
 25: ];
 26: 
 27: const TECH_PARTNERS: Partner[] = [
 28:   { name: 'AOTO', src: '/all-partner-logos/AOTO LOGO2.png' },
 29:   { name: 'Artixium', src: '/all-partner-logos/artixium.jpg' },
 30:   { name: 'Aximmetry', src: '/all-partner-logos/aximmetry.png', needsInvert: true },
 31:   { name: 'Blackcam Robotics', src: '/all-partner-logos/blackcam robotics.jpg' },
 32:   { name: 'Brompton Technology', src: '/all-partner-logos/brompton_technology_logo.jpg' },
 33:   { name: 'Eztrack', src: '/all-partner-logos/logo_eztrack-noir.png', needsInvert: true },
 34:   { name: 'Huawei', src: '/all-partner-logos/Huawei new Logo.png', needsInvert: true },
 35:   { name: 'Infiled', src: '/all-partner-logos/infiled.webp' },
 36:   { name: 'Korad', src: '/all-partner-logos/korad.png', needsInvert: true },
 37:   { name: 'OARO', src: '/all-partner-logos/OARO.jpeg' },
 38:   { name: 'Object Matrix', src: '/all-partner-logos/Object-Matrix-Logo-e1610495539370.webp', needsInvert: true },
 39:   { name: 'Ortana', src: '/all-partner-logos/ortana-omg-wide-logo-with-new-tagline-sml.png', needsInvert: true },
 40:   { name: 'Smode', src: '/all-partner-logos/logo_smode.png', needsInvert: true },
 41:   { name: 'STYPE', src: '/all-partner-logos/STYPE-logo-black.png', needsInvert: true },
 42:   { name: 'Unreal Engine', src: '/all-partner-logos/unreal logo.png', needsInvert: true },
 43: 
 44:   { name: 'Vivemars', src: '/all-partner-logos/vivemars_logo.jpg' },
 45: ];
 46: 
 47: // Merge all partners into one flat list for the slider
 48: const ALL_PARTNERS: Partner[] = [...GOVERNMENT_PARTNERS, ...TECH_PARTNERS];
 49: 
 50: // ─── Single Logo Card (for slider) ──────────────────────────────────────────
 51: const SliderLogoCard = ({ partner }: { partner: Partner }) => {
 52:   const reduce = useReducedMotion();
 53:   const imgRef = useRef<HTMLImageElement>(null);
 54:   const cardRef = useRef<HTMLDivElement>(null);
 55: 
 56:   return (
 57:     <div
 58:       ref={cardRef}
 59:       className="relative flex-shrink-0 flex items-center justify-center rounded-xl overflow-hidden transition-all duration-400"
 60:       style={{
 61:         width: '140px',
 62:         minHeight: '72px',
 63:         background: 'rgba(255,255,255,0.025)',
 64:         border: '1px solid rgba(255,255,255,0.07)',
 65:         padding: '16px 20px',
 66:       }}
 67:       onMouseEnter={(e) => {
 68:         if (reduce) return;
 69:         const el = e.currentTarget as HTMLDivElement;
 70:         el.style.borderColor = 'rgba(251,146,60,0.35)';
 71:         el.style.background = 'rgba(251,146,60,0.05)';
 72:         el.style.boxShadow = '0 0 28px rgba(251,146,60,0.10)';
 73:         if (imgRef.current) {
 74:           imgRef.current.style.filter = partner.needsInvert
 75:             ? 'invert(1) brightness(1.1) grayscale(0)'
 76:             : 'grayscale(0) brightness(1.05)';
 77:           imgRef.current.style.opacity = '1';
 78:         }
 79:       }}
 80:       onMouseLeave={(e) => {
 81:         if (reduce) return;
 82:         const el = e.currentTarget as HTMLDivElement;
 83:         el.style.borderColor = 'rgba(255,255,255,0.07)';
 84:         el.style.background = 'rgba(255,255,255,0.025)';
 85:         el.style.boxShadow = 'none';
 86:         if (imgRef.current) {
 87:           imgRef.current.style.filter = partner.needsInvert
 88:             ? 'invert(1) brightness(0.85) grayscale(0.2)'
 89:             : 'grayscale(0.35) brightness(0.85)';
 90:           imgRef.current.style.opacity = '0.7';
 91:         }
 92:       }}
 93:     >
 94:       {/* Top shimmer line on hover */}
 95:       <div
 96:         className="absolute top-0 inset-x-0 h-px opacity-0 hover:opacity-100 transition-opacity duration-400"
 97:         style={{ background: 'linear-gradient(90deg, transparent, rgba(251,146,60,0.55), transparent)' }}
 98:         aria-hidden="true"
 99:       />
100:       <img
101:         ref={imgRef}
102:         src={partner.src}
103:         alt={partner.name}
104:         title={partner.name}
105:         className="max-h-9 w-full object-contain transition-all duration-400"
106:         style={{
107:           filter: partner.needsInvert
108:             ? 'invert(1) brightness(0.85) grayscale(0.2)'
109:             : 'grayscale(0.35) brightness(0.85)',
110:           opacity: 0.7,
111:         }}
112:         loading="lazy"
113:         onError={(e) => {
114:           const img = e.currentTarget;
115:           img.style.display = 'none';
116:           const parent = img.parentElement;
117:           if (parent) {
118:             const fallback = document.createElement('span');
119:             fallback.style.cssText =
120:               'font-size:0.55rem;font-weight:700;letter-spacing:0.18em;text-transform:uppercase;color:rgba(107,127,163,0.55);text-align:center;line-height:1.4;';
121:             fallback.textContent = partner.name;
122:             parent.appendChild(fallback);
123:           }
124:         }}
125:       />
126:     </div>
127:   );
128: };
129: 
130: // ─── Infinite Slider ─────────────────────────────────────────────────────────
131: // Uses pure CSS animation — no JS scroll loop, no RAF, GPU-friendly.
132: // We duplicate the list once to create the seamless loop illusion.
133: const InfiniteSlider = ({ partners }: { partners: Partner[] }) => {
134:   const reduce = useReducedMotion();
135:   // Duplicate for seamless loop
136:   const doubled = [...partners, ...partners];
137: 
138:   // Each card is 140px wide + 12px gap = 152px per item
139:   const itemWidth = 152;
140:   const totalWidth = partners.length * itemWidth;
141: 
142:   return (
143:     <div
144:       className="relative w-full overflow-hidden"
145:       aria-label="Partner logos slider"
146:       // Fade edges
147:       style={{
148:         maskImage:
149:           'linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%)',
150:         WebkitMaskImage:
151:           'linear-gradient(to right, transparent 0%, black 8%, black 92%, transparent 100%)',
152:       }}
153:     >
154:       <div
155:         className="flex gap-3"
156:         style={{
157:           width: `${totalWidth * 2}px`,
158:           animation: reduce ? 'none' : `xr-marquee 38s linear infinite`,
159:           willChange: 'transform',
160:         }}
161:       >
162:         {doubled.map((partner, i) => (
163:           <SliderLogoCard key={`${partner.name}-${i}`} partner={partner} />
164:         ))}
165:       </div>
166: 
167:       {/* Inline keyframe injected via style tag — avoids needing global CSS change */}
168:       <style>{`
169:         @keyframes xr-marquee {
170:           0%   { transform: translateX(0); }
171:           100% { transform: translateX(-${totalWidth}px); }
172:         }
173:         @media (prefers-reduced-motion: reduce) {
174:           @keyframes xr-marquee { 0%, 100% { transform: none; } }
175:         }
176:       `}</style>
177:     </div>
178:   );
179: };
180: 
181: // ─── Section ─────────────────────────────────────────────────────────────────
182: const SponsorsSection = () => (
183:   <section
184:     className="relative w-full overflow-hidden"
185:     style={{
186:       borderTop: '1px solid rgba(255,255,255,0.055)',
187:       paddingTop: 'var(--section-padding-y)',
188:       paddingBottom: 'var(--section-padding-y)',
189:     }}
190:     aria-labelledby="partners-heading"
191:   >
192:     {/* Subtle background tint */}
193:     <div
194:       className="absolute inset-0 pointer-events-none"
195:       style={{ background: 'rgba(13,27,46,0.35)' }}
196:       aria-hidden="true"
197:     />
