 45:   { at: (INTRO_LINE_ENTER_MS + INTRO_LINE_READ_MS) * 2 + INTRO_ZAP_MS + 1380, step: 5 },
 46: ];
 47: const LAST_STEP = 5;
 48: 
 49: function hasSeenHeroIntro(): boolean {
 50:   try {
 51:     return sessionStorage.getItem(HERO_INTRO_SEEN_KEY) === '1';
 52:   } catch {
 53:     return false;
 54:   }
 55: }
