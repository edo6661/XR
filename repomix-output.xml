<file path="src/components/ui/SectionEyebrow.tsx">
 1: import { motion } from 'framer-motion';
 2: 
 3: interface SectionEyebrowProps {
 4:   children: React.ReactNode;
 5:   align?: 'left' | 'center';
 6:   className?: string;
 7:   /** 'dark' = di atas background gelap (default), 'light' = di atas surface terang */
 8:   tone?: 'dark' | 'light';
 9: }
10: 
11: const EyebrowLine = ({
12:   tone,
13:   mirrored = false,
14: }: {
15:   tone: 'dark' | 'light';
16:   mirrored?: boolean;
17: }) => (
18:   <span
19:     className={[
20:       'eyebrow-line',
21:       tone === 'light' ? 'eyebrow-line--light' : '',
22:       mirrored ? 'eyebrow-line--center-right' : '',
23:     ]
24:       .filter(Boolean)
25:       .join(' ')}
26:     aria-hidden="true"
27:   />
28: );
29: 
30: /**
31:  * Shared eyebrow label — accent gradient line + text.
32:  */
33: const SectionEyebrow = ({
34:   children,
35:   align = 'left',
36:   className = '',
37:   tone = 'dark',
38: }: SectionEyebrowProps) => (
39:   <motion.div
40:     initial={{ opacity: 0, x: align === 'left' ? -16 : 0, y: align === 'center' ? -8 : 0 }}
41:     whileInView={{ opacity: 1, x: 0, y: 0 }}
42:     viewport={{ once: true, amount: 0.6 }}
43:     transition={{ duration: 0.6, ease: [0.16, 1, 0.3, 1] }}
44:     className={`flex items-center gap-3 mb-10 ${align === 'center' ? 'justify-center' : ''} ${className}`}
45:   >
46:     <EyebrowLine tone={tone} />
47:     <span
48:       className={tone === 'light' ? 'section-eyebrow-text section-eyebrow-text--light' : 'section-eyebrow-text'}
49:     >
50:       {children}
51:     </span>
52:     {align === 'center' && <EyebrowLine tone={tone} mirrored />}
53:   </motion.div>
54: );
55: 
56: export default SectionEyebrow;
</file>

