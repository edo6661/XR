217:     const buildDots = (isLand: ((lat: number, lon: number) => boolean) | null) => {
218:       const SAMPLES = isMobile ? 11000 : 22000;
219:       const goldenPhi = Math.PI * (3 - Math.sqrt(5));
220:       const pos: number[] = [];
221:       const rand: number[] = [];
222:       const accent: number[] = [];
223: 
224:       for (let i = 0; i < SAMPLES; i++) {
225:         const uy = 1 - (i / (SAMPLES - 1)) * 2;
226:         const r = Math.sqrt(Math.max(0, 1 - uy * uy));
227:         const theta = goldenPhi * i;
228:         const ux = Math.cos(theta) * r;
229:         const uz = Math.sin(theta) * r;
230: 
231:         if (isLand) {
232:           const lat = Math.asin(uy) / DEG;
233:           const lon = Math.atan2(uz, ux) / DEG;
234:           if (!isLand(lat, lon)) continue;
235:         }
236: 
237:         pos.push(ux * RADIUS * 1.01, uy * RADIUS * 1.01, uz * RADIUS * 1.01);
238:         rand.push(Math.random());
239:         accent.push(Math.random() > 0.94 ? 1 : 0); // sparse warm nodes
240:       }
241: 
242:       const geo = new THREE.BufferGeometry();
243:       geo.setAttribute('position', new THREE.BufferAttribute(new Float32Array(pos), 3));
244:       geo.setAttribute('aRand', new THREE.BufferAttribute(new Float32Array(rand), 1));
245:       geo.setAttribute('aAccent', new THREE.BufferAttribute(new Float32Array(accent), 1));
246:       dots = new THREE.Points(geo, dotMat);
247:       globe.add(dots);
248:       disposables.push(geo);
249:     };
