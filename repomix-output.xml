  8: // Host / partner cities — the "global network" the arcs trace.
  9: const CITIES: { lat: number; lon: number; hub?: boolean }[] = [
 10:   { lat: 3.14, lon: 101.69, hub: true }, // Kuala Lumpur (flagship host)
 11:   { lat: 1.35, lon: 103.82 }, // Singapore
 12:   { lat: 35.68, lon: 139.69 }, // Tokyo
 13:   { lat: 37.57, lon: 126.98 }, // Seoul
 14:   { lat: 31.23, lon: 121.47 }, // Shanghai
 15:   { lat: 19.08, lon: 72.88 }, // Mumbai
 16:   { lat: 25.2, lon: 55.27 }, // Dubai
 17:   { lat: -33.87, lon: 151.21 }, // Sydney
 18:   { lat: 51.51, lon: -0.13 }, // London
 19:   { lat: 37.77, lon: -122.42 }, // San Francisco
 20: ];
 21: 
 22: // Routes radiate from the KL hub (0) + a couple of cross links.
 23: const ROUTES: [number, number][] = [
 24:   [0, 2],
 25:   [0, 6],
 26:   [0, 8],
 27:   [0, 9],
 28:   [0, 3],
 29:   [1, 5],
 30:   [4, 7],
 31: ];
 32: 
 33: const LAND_THRESHOLD = 0.07; // earth-dark.jpg: solid-black continents read darkest
 34: 
 35: function latLonToVec3(lat: number, lon: number, r: number) {
 36:   const phi = lat * DEG;
 37:   const lambda = lon * DEG;
 38:   return new THREE.Vector3(
 39:     r * Math.cos(phi) * Math.cos(lambda),
 40:     r * Math.sin(phi),
 41:     r * Math.cos(phi) * Math.sin(lambda),
 42:   );
 43: }
 44: 
 45: const GlobeCanvas = () => {
 46:   const mountRef = useRef<HTMLDivElement>(null);
 47: 
 48:   useEffect(() => {
 49:     const mount = mountRef.current;
 50:     if (!mount) return;
 51: 
 52:     const prefersReducedMotion = window.matchMedia(
 53:       '(prefers-reduced-motion: reduce)',
 54:     ).matches;
 55:     const isMobile = window.innerWidth < 768;
 56:     const PIXEL = Math.min(window.devicePixelRatio, 1.0);
 57: 
 58:     // ── 1. Scene · Camera · Renderer ───────────────────────────────────────
 59:     const scene = new THREE.Scene();
 60:     const camera = new THREE.PerspectiveCamera(
 61:       45,
 62:       mount.clientWidth / mount.clientHeight,
 63:       0.1,
 64:       100,
 65:     );
 66:     camera.position.set(0, 0, 6.2);
 67: 
 68:     const renderer = new THREE.WebGLRenderer({
 69:       antialias: true,
 70:       alpha: true,
 71:       powerPreference: 'high-performance',
 72:     });
 73:     renderer.setSize(mount.clientWidth, mount.clientHeight);
 74:     renderer.setPixelRatio(PIXEL);
 75:     mount.appendChild(renderer.domElement);
 76: 
 77:     // Brand-aligned palette
 78:     const COL_ATMO = new THREE.Color('#38bdf8'); // cyan atmosphere
 79:     const COL_DOT = new THREE.Color('#7dd3fc'); // light cyan land dots
 80:     const COL_ACCENT = new THREE.Color('#fb923c'); // warm brand orange
 81:     const COL_GRID = new THREE.Color('#2b6f9e');
 82: 
 83:     // Group lets us tilt + parallax everything together
 84:     const globe = new THREE.Group();
 85:     globe.rotation.z = 0.18; // gentle axial tilt
 86:     globe.position.y = -0.15;
 87:     scene.add(globe);
 88: 
 89:     const disposables: { dispose: () => void }[] = [];
 90: 
 91:     // ── 2. Solid planet body (dark fill + fresnel limb) ────────────────────
 92:     const bodyMat = new THREE.ShaderMaterial({
 93:       uniforms: {
 94:         uDark: { value: new THREE.Color('#040c1a') },
 95:         uRim: { value: COL_ATMO },
 96:       },
 97:       vertexShader: `
 98:         varying vec3 vNormal;
 99:         varying vec3 vView;
100:         void main() {
101:           vNormal = normalize(normalMatrix * normal);
102:           vec4 mv = modelViewMatrix * vec4(position, 1.0);
103:           vView = normalize(-mv.xyz);
104:           gl_Position = projectionMatrix * mv;
105:         }
106:       `,
107:       fragmentShader: `
108:         uniform vec3 uDark;
109:         uniform vec3 uRim;
110:         varying vec3 vNormal;
111:         varying vec3 vView;
112:         void main() {
113:           float fres = 1.0 - max(dot(vNormal, vView), 0.0);
114:           float limb = pow(fres, 2.6);
115:           vec3 col = mix(uDark, uRim * 0.55, limb);
116:           gl_FragColor = vec4(col, 1.0);
117:         }
118:       `,
119:     });
120:     const bodyGeo = new THREE.SphereGeometry(RADIUS, 64, 64);
121:     const body = new THREE.Mesh(bodyGeo, bodyMat);
122:     globe.add(body);
123:     disposables.push(bodyGeo, bodyMat);
124: 
125:     // ── 3. Atmospheric glow shell (back-side fresnel, additive) ────────────
126:     const atmoMat = new THREE.ShaderMaterial({
127:       uniforms: { uColor: { value: COL_ATMO } },
128:       vertexShader: `
129:         varying vec3 vNormal;
130:         varying vec3 vView;
131:         void main() {
132:           vNormal = normalize(normalMatrix * normal);
133:           vec4 mv = modelViewMatrix * vec4(position, 1.0);
134:           vView = normalize(-mv.xyz);
135:           gl_Position = projectionMatrix * mv;
136:         }
137:       `,
138:       fragmentShader: `
139:         uniform vec3 uColor;
140:         varying vec3 vNormal;
141:         varying vec3 vView;
142:         void main() {
143:           float fres = pow(1.0 - max(dot(vNormal, vView), 0.0), 3.2);
144:           gl_FragColor = vec4(uColor, fres * 0.9);
145:         }
146:       `,
147:       transparent: true,
148:       side: THREE.BackSide,
149:       blending: THREE.AdditiveBlending,
150:       depthWrite: false,
151:     });
152:     const atmoGeo = new THREE.SphereGeometry(RADIUS * 1.16, 64, 64);
153:     const atmosphere = new THREE.Mesh(atmoGeo, atmoMat);
154:     globe.add(atmosphere);
155:     disposables.push(atmoGeo, atmoMat);
156: 
157:     // ── 4. Holographic lat/long grid (kept very faint) ─────────────────────
158:     const gridGeo = new THREE.WireframeGeometry(
159:       new THREE.SphereGeometry(RADIUS * 1.002, 36, 18),
160:     );
161:     const gridMat = new THREE.LineBasicMaterial({
162:       color: COL_GRID,
163:       transparent: true,
164:       opacity: 0.07,
165:       depthWrite: false,
166:     });
167:     const grid = new THREE.LineSegments(gridGeo, gridMat);
168:     globe.add(grid);
169:     disposables.push(gridGeo, gridMat);
170: 
171:     // ── 5. Continent dot-field (sampled from a real world map) ─────────────
172:     // Built async after the land-mask image decodes; falls back to a uniform
173:     // shimmer if the texture cannot be read.
174:     const dotMat = new THREE.ShaderMaterial({
175:       uniforms: {
176:         uTime: { value: 0 },
177:         uColor: { value: COL_DOT },
178:         uAccent: { value: COL_ACCENT },
179:         uSize: { value: 7.0 * PIXEL },
180:       },
181:       vertexShader: `
182:         attribute float aRand;
183:         attribute float aAccent;
184:         uniform float uTime;
185:         uniform float uSize;
186:         varying float vTwinkle;
187:         varying float vAccent;
188:         void main() {
189:           vAccent = aAccent;
190:           vTwinkle = 0.5 + 0.5 * sin(uTime * 1.3 + aRand * 30.0);
191:           vec4 mv = modelViewMatrix * vec4(position, 1.0);
192:           gl_PointSize = uSize * (0.7 + 0.3 * vTwinkle) / -mv.z * 2.0;
193:           gl_Position = projectionMatrix * mv;
194:         }
195:       `,
196:       fragmentShader: `
197:         uniform vec3 uColor;
198:         uniform vec3 uAccent;
199:         varying float vTwinkle;
200:         varying float vAccent;
201:         void main() {
202:           float d = length(gl_PointCoord - vec2(0.5));
203:           if (d > 0.5) discard;
204:           float soft = smoothstep(0.5, 0.0, d);
205:           vec3 c = mix(uColor, uAccent, vAccent);
206:           gl_FragColor = vec4(c, soft * (0.55 + 0.45 * vTwinkle) * 0.9);
207:         }
208:       `,
209:       transparent: true,
210:       depthTest: true, // back-side dots are hidden behind the opaque body
211:       depthWrite: false,
212:       blending: THREE.AdditiveBlending,
213:     });
214:     disposables.push(dotMat);
215:     let dots: THREE.Points | null = null;
