192:             style={{ fontSize: isFeatured ? '1.42rem' : '1.02rem' }}
193:           >
194:             {title}
195:           </h3>
196:           <p
197:             className="leading-relaxed line-clamp-2"
198:             style={{ fontSize: '0.73rem', color: 'rgba(107,127,163,0.82)' }}
199:           >
200:             {description}
201:           </p>
202:         </div>
203: 
204:         {/* Meta row */}
205:         <div
206:           className="flex items-center gap-5 pt-3 border-t"
207:           style={{ borderColor: 'rgba(255,255,255,0.06)' }}
