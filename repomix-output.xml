 95:     gsap.to(glowRef.current, { opacity: 0, duration: 0.45, overwrite: 'auto' });
 96: 
 97:     if (contentRef.current) {
 98:       gsap.to(contentRef.current, { y: 0, duration: 0.65, ease: 'power3.out' });
 99:     }
100:     if (arrowRef.current) {
101:       gsap.to(arrowRef.current, { x: 0, opacity: 0.5, duration: 0.35 });
102:     }
103:     if (borderRef.current) {
104:       borderRef.current.style.borderColor = `${accentColor}${isCenter ? '30' : '18'}`;
105:       borderRef.current.style.boxShadow = isCenter
106:         ? `0 0 48px ${accentColor}0e, 0 24px 48px rgba(0,0,0,0.35)`
