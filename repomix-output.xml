327: const AixrActivationsSection = ({
328:   onDownloadBrochure,
329:   onRegister,
330: }: AixrActivationsSectionProps) => {
331:   const [activeId, setActiveId] = useState<string>(ACTIVATIONS[0].id);
332:   const sectionRef = useRef<HTMLElement>(null);
333:   const tabsRef = useRef<HTMLDivElement>(null);
334:   const [isTabsSticky, setIsTabsSticky] = useState(false);
335: 
336:   const activeActivation = ACTIVATIONS.find((a) => a.id === activeId)!;
337: 
338:   const handleTabClick = useCallback((id: string) => {
339:     setActiveId(id);
340:   }, []);
341: 
342:   /* Observe when the tabs bar becomes sticky */
343:   useEffect(() => {
344:     const sentinel = tabsRef.current;
345:     if (!sentinel) return;
346: 
347:     const observer = new IntersectionObserver(
348:       ([entry]) => {
349:         setIsTabsSticky(!entry.isIntersecting);
350:       },
351:       { threshold: 1, rootMargin: '-65px 0px 0px 0px' }
352:     );
353:     observer.observe(sentinel);
354:     return () => observer.disconnect();
355:   }, []);
356: 
357:   return (
358:     <section
359:       ref={sectionRef}
360:       className="relative w-full overflow-visible px-6"
361:       style={{
362:         paddingTop: 'var(--section-padding-y)',
363:         paddingBottom: 'var(--section-padding-y)',
364:       }}
365:       aria-labelledby="aixr-activations-heading"
366:     >
367:       <div className="max-w-7xl mx-auto">
368:         <SectionEyebrow>6 Experiences</SectionEyebrow>
