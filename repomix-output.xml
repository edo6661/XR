 45:     if (!isMounted) return;
 46: 
 47:     const ctx = gsap.context(() => { });
 48: 
 49:     const initScrollAnimation = () => {
 50:       const anchor = document.getElementById('nav-logo-anchor');
 51:       if (!placeholderRef.current || !flyingRef.current || !anchor) return;
 52: 
 53:       ctx.revert();
 54:       setHasLanded(false);
 55: 
 56:       ctx.add(() => {
 57:         const startRect = placeholderRef.current!.getBoundingClientRect();
 58: 
 59:         // Kalkulasi posisi final anchor (force max-w-7xl state)
 60:         const navContainer = anchor.closest('.mx-auto') as HTMLElement | null;
 61:         let finalRect: DOMRect;
 62: 
 63:         if (navContainer) {
 64:           const orig = navContainer.style.transition;
 65:           navContainer.style.transition = 'none';
 66:           navContainer.classList.add('max-w-7xl');
 67:           void navContainer.offsetHeight;
 68:           finalRect = anchor.getBoundingClientRect();
 69: 
 70:           navContainer.style.transition = orig;
 71:         } else {
 72:           finalRect = anchor.getBoundingClientRect();
 73:         }
 74: 
 75:         // Setup awal portal
 76:         gsap.set(flyingRef.current, {
 77:           x: startRect.left,
 78:           y: startRect.top,
 79:           width: startRect.width,
 80:           height: startRect.height,
 81:           opacity: 1,
 82:         });
 83:         gsap.set(placeholderRef.current, { opacity: 0 });
 84: 
 85:         // Animasi terbang
 86:         gsap.to(flyingRef.current, {
 87:           x: finalRect.left,
 88:           y: finalRect.top,
 89:           width: finalRect.width,
 90:           height: finalRect.height,
 91:           ease: 'none',
 92:           scrollTrigger: {
 93:             trigger: document.documentElement,
 94:             start: 'top top',
 95:             end: () => `+=${window.innerHeight * 0.75}`,
 96:             scrub: true,
 97:             invalidateOnRefresh: true,
 98:             onLeave: () => {
 99:               // Logo sudah landing: stop animasi, aktifkan pointer events
100:               setHasLanded(true);
101:               if (flyingRef.current) {
102:                 flyingRef.current.style.pointerEvents = 'auto';
103:                 flyingRef.current.style.cursor = 'pointer';
104:               }
105:             },
106:             onEnterBack: () => {
