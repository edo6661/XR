  4: import gsap from 'gsap';
  5: 
  6: interface SpotlightCardProps {
  7:   index: number;
  8:   title: string;
  9:   date?: string;
 10:   location?: string;
 11:   description: string;
 12:   accentColor: string;
 13:   tag: string;
 14:   to?: string;
 15:   imageSrc?: string;
 16:   isFeatured?: boolean;
 17:   imagePosition?: string;
 18:   imageDark?: boolean;
 19:   imageTransform?: string;
 20: }
 21: 
 22: const SpotlightCard = ({
 23:   index,
 24:   title,
 25:   date,
 26:   location,
 27:   description,
 28:   accentColor,
 29:   tag,
 30:   to,
 31:   imageSrc,
 32:   isFeatured = false,
 33:   imagePosition = 'center',
 34:   imageDark = true,
 35:   imageTransform = 'none',
 36: 
 37: }: SpotlightCardProps) => {
 38:   const cardRef = useRef<HTMLDivElement>(null);
 39:   const shineRef = useRef<HTMLDivElement>(null);
 40:   const imgRef = useRef<HTMLImageElement>(null);
 41:   const borderRef = useRef<HTMLDivElement>(null);
 42:   const titleRef = useRef<HTMLHeadingElement>(null);
 43:   const descriptionRef = useRef<HTMLParagraphElement>(null);
 44: 
 45:   const handleMouseMove = useCallback((e: React.MouseEvent<HTMLDivElement>) => {
 46:     if (!cardRef.current || !shineRef.current) return;
 47:     const rect = cardRef.current.getBoundingClientRect();
 48:     const x = e.clientX - rect.left;
 49:     const y = e.clientY - rect.top;
 50:     const cx = rect.width / 2;
 51:     const cy = rect.height / 2;
 52: 
 53:     gsap.to(cardRef.current, {
 54:       rotateX: ((y - cy) / cy) * -4,
 55:       rotateY: ((x - cx) / cx) * 4,
 56:       duration: 0.5,
 57:       ease: 'power2.out',
 58:       transformPerspective: 1000,
 59:     });
 60: 
 61:     gsap.to(shineRef.current, {
 62:       x: x - cx,
 63:       y: y - cy,
 64:       opacity: isFeatured ? 0.14 : 0.09,
 65:       duration: 0.38,
 66:       ease: 'power2.out',
 67:       overwrite: 'auto',
 68:     });
 69:   }, [isFeatured]);
 70: 
 71:   const handleMouseEnter = useCallback(() => {
 72:     if (imgRef.current) {
 73:       gsap.to(imgRef.current, { scale: 1.04, duration: 0.7, ease: 'power3.out' });
 74:     }
 75:     if (borderRef.current) {
 76:       borderRef.current.style.borderColor = `${accentColor}42`;
 77:       borderRef.current.style.boxShadow = `0 0 52px ${accentColor}14, inset 0 0 32px ${accentColor}04`;
 78:     }
 79: 
 80:     if (titleRef.current) {
 81:       gsap.to(titleRef.current, {
 82:         duration: 0.5,
 83:         ease: 'power3.out',
 84:       });
 85:     }
 86:     if (descriptionRef.current) {
 87:       gsap.to(descriptionRef.current, {
 88:         color: 'rgba(255, 255, 255, 0.95)',
 89:         duration: 0.5,
 90:         ease: 'power3.out',
 91:         fontSize: '0.83rem',
 92:         fontWeight: 'bold',
 93:         delay: 0.02,
 94:       });
 95:     }
 96:   }, [accentColor]);
 97: 
