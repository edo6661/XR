<file path="src/components/ui/CustomCursor.tsx">
 1: // src/components/ui/CustomCursor.tsx
 2: import { useEffect, useState } from 'react';
 3: import { motion, useMotionValue, useSpring } from 'framer-motion';
 4: 
 5: const CustomCursor = () => {
 6:   const [isHovering, setIsHovering] = useState(false);
 7:   const [isTouchDevice] = useState(
 8:     () => typeof window !== 'undefined' && window.matchMedia('(pointer: coarse)').matches
 9:   );
10: 
11:   const cursorX = useMotionValue(-100);
12:   const cursorY = useMotionValue(-100);
13: 
14:   const springConfigOuter = { stiffness: 600, damping: 30, mass: 0.5 };
15:   const outerX = useSpring(cursorX, springConfigOuter);
16:   const outerY = useSpring(cursorY, springConfigOuter);
17: 
18:   useEffect(() => {
19:     if (isTouchDevice) return;
20: 
21:     const onMouseMove = (e: MouseEvent) => {
22:       cursorX.set(e.clientX);
23:       cursorY.set(e.clientY);
24:     };
25: 
26:     const onMouseOver = (e: MouseEvent) => {
27:       const target = e.target as HTMLElement;
28:       // Gunakan tagName atau class khusus untuk deteksi yang lebih ringan daripada closest()
29:       const isInteractable =
30:         target.tagName === 'A' ||
31:         target.tagName === 'BUTTON' ||
32:         target.closest('a, button');
33: 
34:       setIsHovering(!!isInteractable);
35:     };
36: 
37:     window.addEventListener('mousemove', onMouseMove, { passive: true });
38:     window.addEventListener('mouseover', onMouseOver, { passive: true });
39: 
40:     return () => {
41:       window.removeEventListener('mousemove', onMouseMove);
42:       window.removeEventListener('mouseover', onMouseOver);
43:     };
44:   }, [cursorX, cursorY, isTouchDevice]);
45: 
46:   if (isTouchDevice) return null;
47: 
48:   return (
49:     <>
50:       <motion.div
51:         className="fixed top-0 left-0 w-2 h-2 bg-accent rounded-full pointer-events-none z-[100001]"
52:         style={{
53:           x: cursorX,
54:           y: cursorY,
55:           translateX: '-50%',
56:           translateY: '-50%',
57:           willChange: 'transform'
58:         }}
59:         animate={{ opacity: isHovering ? 0 : 1 }}
60:         transition={{ duration: 0.15 }}
61:       />
62:       <motion.div
63:         className="fixed top-0 left-0 w-8 h-8 border border-accent rounded-full pointer-events-none z-[100000] flex items-center justify-center"
64:         style={{
65:           x: outerX,
66:           y: outerY,
67:           translateX: '-50%',
68:           translateY: '-50%',
69:           willChange: 'transform'
70:         }}
71:         animate={{
72:           scale: isHovering ? 1.5 : 1,
73:           backgroundColor: isHovering ? 'rgba(251, 146, 60, 0.15)' : 'transparent',
74:           borderColor: isHovering ? 'rgba(251, 146, 60, 0.8)' : 'rgba(251, 146, 60, 0.4)',
75:         }}
76:         transition={{ duration: 0.2 }}
77:       />
78:     </>
79:   );
80: };
81: 
82: export default CustomCursor;
</file>

