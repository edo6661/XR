 27:   tag,
 28:   icon,
 29:   isCenter = false,
 30: }: GatewayCardProps) => {
 31:   const cardRef = useRef<HTMLDivElement>(null);
 32:   const glowRef = useRef<HTMLDivElement>(null);
 33:   const contentRef = useRef<HTMLDivElement>(null);
 34:   const arrowRef = useRef<HTMLSpanElement>(null);
 35:   const borderRef = useRef<HTMLDivElement>(null);
 36: 
 37:   // Referensi untuk GSAP quickTo agar tidak membuat instance baru setiap mouse geser
 38:   const xTo = useRef<gsap.QuickToFunc | null>(null);
 39:   const yTo = useRef<gsap.QuickToFunc | null>(null);
 40:   const glowXTo = useRef<gsap.QuickToFunc | null>(null);
 41:   const glowYTo = useRef<gsap.QuickToFunc | null>(null);
 42: 
 43:   useEffect(() => {
 44:     if (!cardRef.current || !glowRef.current) return;
 45: 
 46:     // Membangun animasi di awal (hanya 1 kali eksekusi saat mount)
 47:     xTo.current = gsap.quickTo(cardRef.current, "rotateY", { duration: 0.55, ease: "power2.out" });
 48:     yTo.current = gsap.quickTo(cardRef.current, "rotateX", { duration: 0.55, ease: "power2.out" });
 49:     glowXTo.current = gsap.quickTo(glowRef.current, "x", { duration: 0.4, ease: "power2.out" });
 50:     glowYTo.current = gsap.quickTo(glowRef.current, "y", { duration: 0.4, ease: "power2.out" });
 51:   }, []);
 52: 
 53:   const handleMouseMove = useCallback((e: React.MouseEvent<HTMLDivElement>) => {
 54:     if (!cardRef.current || !glowRef.current) return;
 55:     const rect = cardRef.current.getBoundingClientRect();
 56:     const x = e.clientX - rect.left;
 57:     const y = e.clientY - rect.top;
 58:     const cx = rect.width / 2;
 59:     const cy = rect.height / 2;
 60: 
 61:     // Masukkan angka/koordinat baru ke dalam instance yang sudah dibuat
 62:     if (xTo.current) xTo.current(((x - cx) / cx) * (isCenter ? 4 : 3.5));
 63:     if (yTo.current) yTo.current(((y - cy) / cy) * (isCenter ? -4 : -3.5));
 64:     if (glowXTo.current) glowXTo.current(x - cx);
 65:     if (glowYTo.current) glowYTo.current(y - cy);
 66: 
 67:     // Opacity cukup pakai gsap.to biasa dan tambahkan overwrite auto
 68:     gsap.to(glowRef.current, {
 69:       opacity: isCenter ? 0.14 : 0.09,
 70:       duration: 0.4,
 71:       overwrite: 'auto'
 72:     });
 73:   }, [isCenter]);
 74: 
 75:   const handleMouseEnter = useCallback(() => {
 76:     if (contentRef.current) {
 77:       gsap.to(contentRef.current, { y: -4, duration: 0.5, ease: 'power3.out' });
 78:     }
 79:     if (arrowRef.current) {
 80:       gsap.to(arrowRef.current, { x: 5, opacity: 1, duration: 0.35, ease: 'power2.out' });
 81:     }
 82:     if (borderRef.current) {
 83:       borderRef.current.style.borderColor = `${accentColor}3a`;
 84:       borderRef.current.style.boxShadow = `0 0 40px ${accentColor}12, 0 28px 56px rgba(0,0,0,0.45)`;
 85:     }
 86:   }, [accentColor]);
 87: 
 88:   const handleMouseLeave = useCallback(() => {
 89:     if (!cardRef.current || !glowRef.current) return;
 90: 
 91:     // Reset rotasi posisi 3D ke 0 melalui quickTo
 92:     if (xTo.current) xTo.current(0);
 93:     if (yTo.current) yTo.current(0);
