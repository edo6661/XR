 40: const STEP_TIMELINE: { at: number; step: number }[] = [
 41:   { at: INTRO_LINE_ENTER_MS + INTRO_LINE_READ_MS, step: 1 },
 42:   { at: (INTRO_LINE_ENTER_MS + INTRO_LINE_READ_MS) * 2, step: 2 },
