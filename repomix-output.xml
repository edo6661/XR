 4: 
 5: const CustomCursor = () => {
 6:   const [isHovering, setIsHovering] = useState(false);
 7:   const [isTouchDevice] = useState(
 8:     () => typeof window !== 'undefined' && window.matchMedia('(pointer: coarse)').matches
 9:   );
10: 
11:   const cursorX = useMotionValue(-100);
12:   const cursorY = useMotionValue(-100);
13: 
14:   const springConfigOuter = { stiffness: 600, damping: 30, mass: 0.5 };
15:   const outerX = useSpring(cursorX, springConfigOuter);
16:   const outerY = useSpring(cursorY, springConfigOuter);
17: 
18:   const requestRef = useRef<number>(0);
19:   const mousePos = useRef({ x: -100, y: -100 });
20: 
21:   useEffect(() => {
22:     if (isTouchDevice) return;
23: 
24:     // Pisahkan logic update dari event listener
25:     const updateCursor = () => {
26:       cursorX.set(mousePos.current.x);
27:       cursorY.set(mousePos.current.y);
28:       requestRef.current = requestAnimationFrame(updateCursor);
29:     };
30:     requestRef.current = requestAnimationFrame(updateCursor);
31: 
32:     const onMouseMove = (e: MouseEvent) => {
33:       mousePos.current.x = e.clientX;
34:       mousePos.current.y = e.clientY;
35:     };
36: 
37:     const onMouseOver = (e: MouseEvent) => {
38:       const target = e.target as HTMLElement;
39:       // Gunakan tagName atau class khusus untuk deteksi yang lebih ringan daripada closest()
40:       const isInteractable =
41:         target.tagName === 'A' ||
42:         target.tagName === 'BUTTON' ||
43:         target.closest('a, button');
