        }),
    }}
    aria-hidden="true"
  >
    {text}
  </span>
);

// ── Separator diamond ──────────────────────────────────────────────────────
const Diamond = ({ color = 'rgba(251,146,60,0.3)' }: { color?: string }) => (
  <span
    className="flex-shrink-0 mx-8"
    style={{
      width: '5px',
