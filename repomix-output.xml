  1: import { useRef, useCallback } from 'react';
  2: import { Link } from 'react-router-dom';
  3: import { motion } from 'framer-motion';
  4: import gsap from 'gsap';
  5: 
  6: interface SpotlightCardProps {
  7:   index: number;
  8:   title: string;
  9:   subtitle: string;
 10:   date: string;
 11:   location: string;
 12:   description: string;
 13:   accentColor: string;
 14:   tag: string;
 15:   to?: string;
 16:   imageSrc?: string;
 17:   isFeatured?: boolean;
 18: }
 19: 
 20: const SpotlightCard = ({
 21:   index,
 22:   title,
 23:   subtitle,
 24:   date,
 25:   location,
 26:   description,
 27:   accentColor,
 28:   tag,
 29:   to,
 30:   imageSrc,
 31:   isFeatured = false,
 32: }: SpotlightCardProps) => {
 33:   const cardRef = useRef<HTMLDivElement>(null);
 34:   const shineRef = useRef<HTMLDivElement>(null);
 35:   const imgRef = useRef<HTMLImageElement>(null);
 36:   const borderRef = useRef<HTMLDivElement>(null);
 37: 
 38:   const handleMouseMove = useCallback((e: React.MouseEvent<HTMLDivElement>) => {
 39:     if (!cardRef.current || !shineRef.current) return;
 40:     const rect = cardRef.current.getBoundingClientRect();
 41:     const x = e.clientX - rect.left;
 42:     const y = e.clientY - rect.top;
 43:     const cx = rect.width / 2;
 44:     const cy = rect.height / 2;
 45: 
 46:     gsap.to(cardRef.current, {
 47:       rotateX: ((y - cy) / cy) * -4,
 48:       rotateY: ((x - cx) / cx) * 4,
 49:       duration: 0.5,
 50:       ease: 'power2.out',
 51:       transformPerspective: 1000,
 52:     });
 53: 
 54:     gsap.to(shineRef.current, {
 55:       x: x - cx,
 56:       y: y - cy,
 57:       opacity: isFeatured ? 0.14 : 0.09,
 58:       duration: 0.38,
 59:       ease: 'power2.out',
 60:       overwrite: 'auto',
 61:     });
 62:   }, [isFeatured]);
 63: 
 64:   const handleMouseEnter = useCallback(() => {
 65:     if (imgRef.current) {
 66:       gsap.to(imgRef.current, { scale: 1.04, duration: 0.7, ease: 'power3.out' });
 67:     }
 68:     if (borderRef.current) {
 69:       borderRef.current.style.borderColor = `${accentColor}42`;
 70:       borderRef.current.style.boxShadow = `0 0 52px ${accentColor}14, inset 0 0 32px ${accentColor}04`;
 71:     }
 72:   }, [accentColor]);
 73: 
 74:   const handleMouseLeave = useCallback(() => {
 75:     if (!cardRef.current || !shineRef.current) return;
 76:     gsap.to(cardRef.current, { rotateX: 0, rotateY: 0, duration: 0.8, ease: 'power3.out' });
 77:     gsap.to(shineRef.current, { opacity: 0, duration: 0.4 });
 78:     if (imgRef.current) {
 79:       gsap.to(imgRef.current, { scale: 1, duration: 0.7, ease: 'power3.out' });
 80:     }
 81:     if (borderRef.current) {
 82:       borderRef.current.style.borderColor = `${accentColor}20`;
 83:       borderRef.current.style.boxShadow = 'none';
 84:     }
 85:   }, [accentColor]);
 86: 
 87:   const inner = (
 88:     <div
 89:       ref={cardRef}
 90:       onMouseMove={handleMouseMove}
 91:       onMouseEnter={handleMouseEnter}
 92:       onMouseLeave={handleMouseLeave}
 93:       style={{ transformStyle: 'preserve-3d' }}
 94:       className={[
 95:         'relative overflow-hidden rounded-xl group cursor-pointer h-full will-change-transform',
 96:         isFeatured ? 'min-h-[460px]' : 'min-h-[300px]',
 97:       ].join(' ')}
 98:     >
 99:       {/* ── Background ── */}
100:       <div className="absolute inset-0 overflow-hidden">
101:         {imageSrc ? (
102:           <>
103:             <img
104:               ref={imgRef}
105:               src={imageSrc}
106:               alt={title}
107:               className="w-full h-full object-cover"
108:               loading="lazy"
109:             />
110:             <div
111:               className="absolute inset-0"
112:               style={{
113:                 background: `linear-gradient(to top, rgba(5,11,24,0.97) 0%, rgba(5,11,24,0.65) 40%, rgba(5,11,24,0.22) 100%)`,
114:               }}
115:             />
116:           </>
117:         ) : (
118:           <div
119:             className="w-full h-full"
120:             style={{ background: `linear-gradient(148deg, rgba(13,27,46,0.96) 0%, ${accentColor}10 100%)` }}
121:           />
122:         )}
123:       </div>
124: 
125:       {/* ── Border ── */}
126:       <div
127:         ref={borderRef}
128:         className="absolute inset-0 rounded-xl pointer-events-none"
129:         style={{
130:           border: `1px solid ${accentColor}20`,
131:           transition: 'border-color 0.4s ease, box-shadow 0.4s ease',
132:         }}
133:       />
134: 
135:       {/* ── Top edge glow ── */}
136:       <div
137:         className="absolute top-0 left-10 right-10 h-px pointer-events-none"
138:         style={{ background: `linear-gradient(90deg, transparent, ${accentColor}${isFeatured ? '70' : '45'}, transparent)` }}
139:         aria-hidden="true"
140:       />
141: 
142:       {/* ── Corner brackets ── */}
143:       <div className="absolute top-4 left-4 w-4 h-4 border-t border-l pointer-events-none" style={{ borderColor: `${accentColor}48` }} aria-hidden="true" />
144:       <div className="absolute bottom-4 right-4 w-4 h-4 border-b border-r pointer-events-none" style={{ borderColor: `${accentColor}48` }} aria-hidden="true" />
145: 
146:       {/* ── Cursor shine ── */}
147:       <div
148:         ref={shineRef}
149:         className="absolute w-56 h-56 rounded-full pointer-events-none opacity-0 z-[1] will-change-transform"
150:         style={{
151:           background: `radial-gradient(circle, ${accentColor}50 0%, transparent 65%)`,
152:           left: '50%', top: '50%',
153:           transform: 'translate(-50%, -50%)',
154:         }}
155:         aria-hidden="true"
156:       />
157: 
158:       {/* ── Content ── */}
159:       <div className="relative z-10 flex flex-col justify-end h-full p-5 gap-3">
160: 
161:         {/* Tag + index */}
162:         <div className="flex items-center justify-between mb-0.5">
163:           <span
164:             className="text-[0.56rem] font-bold tracking-[0.32em] uppercase px-2.5 py-1 rounded-sm"
165:             style={{
166:               color: accentColor,
167:               background: `${accentColor}16`,
168:               border: `1px solid ${accentColor}28`,
169:             }}
170:           >
171:             {tag}
172:           </span>
173:           <span
174:             className="font-mono text-[0.5rem] tracking-[0.3em]"
175:             style={{ color: `${accentColor}48` }}
176:             aria-hidden="true"
177:           >
178:             {String(index + 1).padStart(2, '0')}
179:           </span>
180:         </div>
181: 
182:         {/* Text */}
183:         <div>
184:           <p
185:             className="font-semibold tracking-[0.26em] uppercase mb-1.5"
186:             style={{ fontSize: '0.58rem', color: `${accentColor}80` }}
187:           >
188:             {subtitle}
189:           </p>
190:           <h3
