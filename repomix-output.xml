            }}
            aria-label="Back to top"
          >
            <span className="font-bold tracking-[0.24em] uppercase">Back to top</span>
            <motion.span
              animate={{ y: [0, -3, 0] }}
              transition={{ duration: 1.8, repeat: Infinity, ease: 'easeInOut' }}
              aria-hidden="true"
            >
              ↑
            </motion.span>
          </button>
        </div>
      </div>
    </footer>
  );
};

export default Footer;
