119:   const showHint = step >= LAST_STEP;
120: 
121:   // Background focus-pull: blurred while veiled → punchy boot → settle.
122:   const hudPhase: Phase = step < 3 ? 'globe' : step === 3 ? 'boot' : 'reveal';
123:   // const bgBlur = step >= 4 ? 1.4 : step === 3 ? 7 : 5;
124:   const bgBrightness = step >= 4 ? 0.82 : 0.76;
