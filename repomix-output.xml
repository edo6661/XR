import { motion, useScroll, useTransform, useSpring } from 'framer-motion';
import { useRef } from 'react';

// ── Text block ─────────────────────────────────────────────────────────────
const Word = ({ text, outline = false }: { text: string; outline?: boolean }) => (
  <span
    className="font-heading font-black tracking-[0.06em] uppercase flex-shrink-0"
    style={{
      fontSize: 'clamp(2.2rem, 6vw, 5rem)',
      ...(outline
        ? {
          color: 'transparent',
          WebkitTextStroke: '1px rgba(251,146,60,0.22)',
        }
        : {
          color: 'rgba(240,244,255,0.07)',
        }),
    }}
    aria-hidden="true"
  >
    {text}
  </span>
);

// ── Separator diamond ──────────────────────────────────────────────────────
const Diamond = ({ color = 'rgba(251,146,60,0.3)' }: { color?: string }) => (
  <span
    className="flex-shrink-0 mx-8"
    style={{
      width: '5px',
      height: '5px',
      background: color,
      transform: 'rotate(45deg)',
      display: 'inline-block',
      verticalAlign: 'middle',
    }}
    aria-hidden="true"
  />
);

// ── ScrollMarquee ──────────────────────────────────────────────────────────
const ScrollMarquee = () => {
  const containerRef = useRef<HTMLDivElement>(null);

  const { scrollYProgress } = useScroll({
    target: containerRef,
    offset: ['start end', 'end start'],
  });

  const spring = useSpring(scrollYProgress, { stiffness: 300, damping: 45 });

  // Row 1 moves left, Row 2 moves right — reduced range for subtlety
  const x1 = useTransform(spring, [0, 1], ['0px', '-320px']);
  const x2 = useTransform(spring, [0, 1], ['-320px', '0px']);

  const row1Words = ['Future', 'Immersive', 'Spatial', 'Computing'];
  const row2Words = ['AI', '×', 'XR', 'Innovation'];

  return (
    <section
      ref={containerRef}
      className="relative w-full overflow-hidden"
      style={{
        paddingTop: '5rem',
        paddingBottom: '5rem',
        borderTop: '1px solid rgba(255,255,255,0.04)',
        borderBottom: '1px solid rgba(255,255,255,0.04)',
      }}
      aria-hidden="true"
    >
      {/* Subtle center glow */}
      <div
        className="absolute top-1/2 left-1/2 -translate-x-1/2 -translate-y-1/2 w-full pointer-events-none"
        style={{
          height: '200px',
          background: 'radial-gradient(ellipse, rgba(251,146,60,0.04) 0%, transparent 68%)',
        }}
      />

      <div
        className="flex flex-col gap-4"
        style={{ transform: 'rotate(-1.5deg) scale(1.06)', transformOrigin: 'center' }}
      >
        {/* Row 1 */}
        <motion.div style={{ x: x1 }} className="flex items-center whitespace-nowrap">
          {[...Array(3)].map((_, gi) =>
            row1Words.map((word, wi) => (
              <div key={`r1-${gi}-${wi}`} className="flex items-center">
                <div className="px-6">
                  <Word text={word} outline={wi % 2 === 0} />
                </div>
                <Diamond color={wi % 2 === 0 ? 'rgba(251,146,60,0.25)' : 'rgba(34,211,238,0.2)'} />
              </div>
            ))
          )}
        </motion.div>

        {/* Row 2 */}
        <motion.div style={{ x: x2 }} className="flex items-center whitespace-nowrap">
          {[...Array(3)].map((_, gi) =>
            row2Words.map((word, wi) => (
              <div key={`r2-${gi}-${wi}`} className="flex items-center">
                <div className="px-6">
                  <Word text={word} outline={wi % 2 !== 0} />
                </div>
                <Diamond color={wi % 2 !== 0 ? 'rgba(167,139,250,0.22)' : 'rgba(251,146,60,0.2)'} />
              </div>
            ))
          )}
        </motion.div>
      </div>
    </section>
  );
};

export default ScrollMarquee;
</file>

<file path="src/index.css">
@import "tailwindcss";
@plugin "@tailwindcss/typography";

/* ── Lenis smooth scroll ───────────────────────────────────────────────── */
html.lenis,
html.lenis body {
  height: auto;
}
.lenis.lenis-smooth {
  scroll-behavior: auto !important;
}
.lenis.lenis-smooth [data-lenis-prevent] {
  overscroll-behavior: contain;
}
.lenis.lenis-stopped {
  overflow: hidden;
}

/* ── Theme tokens ───────────────────────────────────────────────────────── */
@theme {
  --font-sans: "Montserrat", system-ui, sans-serif;
  --font-heading: "Orbitron", var(--font-sans);
  --font-mono: "JetBrains Mono", "Fira Code", ui-monospace, monospace;

  --color-primary: var(--theme-primary);
  --color-secondary: var(--theme-secondary);
  --color-accent: var(--theme-accent);
  --color-background: var(--theme-background);
  --color-surface: var(--theme-surface);
  --color-foreground: var(--theme-foreground);
  --color-foreground-muted: var(--theme-foreground-muted);
  --color-border: var(--theme-border);

  --radius-btn: 3px;
  --radius-card: 10px;

  --shadow-card:
    0 4px 6px -1px rgba(0, 0, 0, 0.32), 0 2px 4px -1px rgba(0, 0, 0, 0.22);
  --shadow-hover:
    0 12px 20px -3px rgba(0, 0, 0, 0.45), 0 4px 8px -2px rgba(0, 0, 0, 0.24);
}

/* ── Design tokens ─────────────────────────────────────────────────────── */
:root {
  /* Brand palette */
  --theme-primary: #1e3a8a;
  --theme-secondary: #7e22ce;
  --theme-accent: #fb923c;
  --theme-accent-glow: rgba(251, 146, 60, 0.38);

  /* Surfaces */
  --theme-background: #050b18;
  --theme-surface: #0d1b2e;
  --theme-surface-2: #1a2540;

  /* Text */
  --theme-foreground: #f0f4ff;
  --theme-foreground-muted: #6b7fa3;

  /* Borders */
  --theme-border: rgba(255, 255, 255, 0.07);
  --theme-border-accent: rgba(251, 146, 60, 0.22);

  /* Layout */
  --section-padding-y: clamp(5rem, 8vw, 8rem);
  --content-max-width: 72rem; /* 1152px — max-w-6xl */
  --content-padding-x: 1.5rem; /* px-6    */

  /* Transitions */
  --transition-fast: all 0.2s ease;
  --transition-base: all 0.35s ease;
  --transition-slow: all 0.6s ease;

  /* Typography scale (fluid) */
  --text-display: clamp(3.5rem, 10vw, 8rem);
  --text-h1: clamp(2.4rem, 5.5vw, 4rem);
  --text-h2: clamp(2rem, 4vw, 3rem);
  --text-h3: clamp(1.2rem, 2vw, 1.5rem);
  --text-body-lg: 1rem;
  --text-body: 0.875rem;
  --text-sm: 0.8rem;
  --text-xs: 0.72rem;
  --text-2xs: 0.62rem;
  --text-label: 0.57rem;
  --text-micro: 0.5rem;
}

/* ── Base ─────────────────────────────────────────────────────────────── */
*,
*::before,
*::after {
  box-sizing: border-box;
}

html {
  scroll-behavior: smooth;
  scroll-padding-top: 5rem;
  text-rendering: optimizeLegibility;
  -webkit-text-size-adjust: 100%;
}

body {
  background-color: var(--theme-background);
  color: var(--theme-foreground);
  font-family: var(--font-sans);
  overflow-x: hidden;
  -webkit-font-smoothing: antialiased;
  -moz-osx-font-smoothing: grayscale;
  /* Prevent layout shift from scrollbar appearing */
  scrollbar-gutter: stable;
}

h1,
h2,
h3,
h4,
h5,
h6 {
  font-family: var(--font-heading);
  letter-spacing: 0.04em;
  font-weight: 700;
  line-height: 1.1;
}

p {
  line-height: 1.75;
}

img,
svg {
  display: block;
  max-width: 100%;
}

/* ── Focus visible — accessibility ────────────────────────────────────── */
:focus-visible {
  outline: 2px solid rgba(251, 146, 60, 0.7);
  outline-offset: 3px;
  border-radius: 2px;
}

/* ── Selection ─────────────────────────────────────────────────────────── */
::selection {
  background: rgba(251, 146, 60, 0.28);
  color: #f0f4ff;
}

/* ── Scrollbar ─────────────────────────────────────────────────────────── */
::-webkit-scrollbar {
  width: 3px;
}
::-webkit-scrollbar-track {
  background: var(--theme-background);
}
::-webkit-scrollbar-thumb {
  background: rgba(251, 146, 60, 0.35);
  border-radius: 2px;
}
::-webkit-scrollbar-thumb:hover {
  background: rgba(251, 146, 60, 0.6);
}

/* ── Glass utilities ───────────────────────────────────────────────────── */
.glass {
  background: rgba(13, 27, 46, 0.55);
  backdrop-filter: blur(16px);
  -webkit-backdrop-filter: blur(16px);
  border: 1px solid var(--theme-border);
}

.glass-accent {
  background: rgba(13, 27, 46, 0.65);
  backdrop-filter: blur(20px);
  -webkit-backdrop-filter: blur(20px);
  border: 1px solid var(--theme-border-accent);
  box-shadow: 0 0 30px rgba(251, 146, 60, 0.05);
}

/* ── Glow utilities ────────────────────────────────────────────────────── */
.glow-accent {
  box-shadow:
    0 0 20px rgba(251, 146, 60, 0.28),
    0 0 60px rgba(251, 146, 60, 0.08);
}

.glow-text-accent {
  text-shadow:
    0 0 20px rgba(251, 146, 60, 0.55),
    0 0 40px rgba(251, 146, 60, 0.25);
}

/* ── Gradient text utility ─────────────────────────────────────────────── */
.gradient-text-accent {
  background: linear-gradient(130deg, #fb923c 0%, #f0f4ff 85%);
  -webkit-background-clip: text;
  -webkit-text-fill-color: transparent;
  background-clip: text;
}

/* ── Scanlines overlay ─────────────────────────────────────────────────── */
.scanlines::after {
  content: "";
  position: absolute;
  inset: 0;
  background: repeating-linear-gradient(
    0deg,
    transparent,
    transparent 2px,
    rgba(0, 0, 0, 0.025) 2px,
    rgba(0, 0, 0, 0.025) 4px
  );
  pointer-events: none;
  z-index: 1;
}

/* ── Custom cursor (desktop pointer devices only) ──────────────────────── */
@media (pointer: fine) {
  body,
  a,
  button,
  [role="button"],
  input,
  select,
  textarea {
    cursor: none;
  }
}

/* ── Reduced motion ────────────────────────────────────────────────────── */
@media (prefers-reduced-motion: reduce) {
  *,
  *::before,
  *::after {
    animation-duration: 0.01ms !important;
    animation-iteration-count: 1 !important;
    transition-duration: 0.01ms !important;
    scroll-behavior: auto !important;
  }
}

/* ── Print ─────────────────────────────────────────────────────────────── */
@media print {
  body {
    background: #fff;
    color: #000;
  }
  .no-print {
    display: none !important;
  }
}
</file>

