<file path="src/components/hero/HeroVideoBackdrop.tsx">
  1: import { useEffect, useRef } from 'react';
  2: import { motion, useReducedMotion } from 'framer-motion';
  3: 
  4: 
  5: export interface HeroVideoConfig {
  6:   /** Public path to the mp4 (e.g. `/hero/videos/3d_digital_globe.mp4`). */
  7:   src: string;
  8:   /** Optional still shown before the first frame decodes. */
  9:   poster?: string;
 10:   /** Framing of the focal point, e.g. `'50% 35%'` to favour the upper third. */
 11:   objectPosition?: string;
 12:   /** CSS filter that grades the raw clip toward the brand palette. */
 13:   filter?: string;
 14: }
 15: 
 16: const HeroVideoBackdrop = ({
 17:   src,
 18:   poster,
 19:   objectPosition = '50% 50%',
 20:   filter = 'brightness(0.9) contrast(1.05) saturate(1.04)',
 21: }: HeroVideoConfig) => {
 22:   const videoRef = useRef<HTMLVideoElement>(null);
 23:   const reduce = useReducedMotion();
 24: 
 25:   useEffect(() => {
 26:     const v = videoRef.current;
 27:     if (!v) return;
 28:     // Some browsers defer autoplay until interaction; swallow the rejection.
 29:     const tryPlay = () => v.play().catch(() => { });
 30:     tryPlay();
 31:     v.addEventListener('canplay', tryPlay, { once: true });
 32:     return () => v.removeEventListener('canplay', tryPlay);
 33:   }, [src]);
 34: 
 35:   return (
 36:     <div
 37:       className="absolute inset-0 overflow-hidden"
 38:       style={{ isolation: 'isolate' }}
 39:       aria-hidden="true"
 40:     >
 41:       {/* Ken-burns wrapper — never drops below 1.06 so parent parallax + drift
 42:           can never expose a hard edge. */}
 43:       <motion.div
 44:         className="absolute inset-0"
 45:         initial={reduce ? { scale: 1.06 } : { scale: 1.14 }}
 46:         animate={
 47:           reduce
 48:             ? { scale: 1.06 }
 49:             : { scale: 1.06, x: ['-1.4%', '1.4%', '-1.4%'], y: ['1%', '-1%', '1%'] }
 50:         }
 51:         transition={{
 52:           scale: { duration: 2.6, ease: [0.16, 1, 0.3, 1] },
 53:           x: { duration: 40, repeat: Infinity, ease: 'easeInOut' },
 54:           y: { duration: 52, repeat: Infinity, ease: 'easeInOut' },
 55:         }}
 56:         // TAMBAHKAN transform: translateZ(0) di sini
 57:         style={{ willChange: 'transform', transform: 'translateZ(0)' }}
 58:       >
 59:         <video
 60:           ref={videoRef}
 61:           className="absolute inset-0 h-full w-full object-cover"
 62:           // Kurangi manipulasi filter berat di sini jika memungkinkan
 63:           style={{ objectPosition, filter, transform: 'translateZ(0)' }}
 64:           src={src}
 65:           poster={poster}
 66:           autoPlay
 67:           muted
 68:           loop
 69:           playsInline
 70:           // HAPUS preload="auto", ganti ke "metadata" agar memori tidak bengkak
 71:           preload="metadata"
 72:           disablePictureInPicture
 73:         />
 74:       </motion.div>
 75: 
 76:       {/* Deep-navy floor (multiply) — sinks the blacks into the brand background
 77:           so the clip never reads as a bright stock loop. */}
 78:       <div
 79:         className="absolute inset-0 mix-blend-multiply"
 80:         style={{
 81:           background: 'linear-gradient(180deg, #0b1730 0%, #050b18 100%)',
 82:           opacity: 0.42,
 83:         }}
 84:       />
 85: 
 86:       {/* Cyan-top / orange-floor HUD tint (screen) — the "next-worldly" glow. */}
 87:       <div
 88:         className="absolute inset-0 mix-blend-screen"
 89:         style={{
 90:           background:
 91:             'radial-gradient(120% 85% at 50% 14%, rgba(56,189,248,0.14) 0%, transparent 55%), radial-gradient(100% 80% at 50% 102%, rgba(251,146,60,0.12) 0%, transparent 58%)',
 92:         }}
 93:       />
 94: 
 95:       {/* Cinematic vignette — focuses the eye centre-stage for the reveal. */}
 96:       <div
 97:         className="absolute inset-0"
 98:         style={{ boxShadow: 'inset 0 0 240px 48px rgba(5,11,24,0.82)' }}
 99:       />
100:     </div>
101:   );
102: };
103: 
104: export default HeroVideoBackdrop;
</file>

