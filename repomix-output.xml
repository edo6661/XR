<file path="src/components/hero/SplatField.tsx">
  1: import { useEffect, useRef } from 'react';
  2: import * as THREE from 'three';
  3: 
  4: 
  5: const SplatField = () => {
  6:   const mountRef = useRef<HTMLDivElement>(null);
  7: 
  8:   useEffect(() => {
  9:     const mount = mountRef.current;
 10:     if (!mount) return;
 11: 
 12:     const prefersReducedMotion = window.matchMedia(
 13:       '(prefers-reduced-motion: reduce)',
 14:     ).matches;
 15:     const isMobile = window.innerWidth < 768;
 16:     const PIXEL = Math.min(window.devicePixelRatio, 1.0);
 17: 
 18:     // ── Scene · Camera · Renderer ──────────────────────────────────────────
 19:     const scene = new THREE.Scene();
 20:     const camera = new THREE.PerspectiveCamera(
 21:       55,
 22:       mount.clientWidth / mount.clientHeight,
 23:       0.1,
 24:       100,
 25:     );
 26:     camera.position.set(0, 0, 8);
 27: 
 28:     const renderer = new THREE.WebGLRenderer({
 29:       antialias: false,
 30:       alpha: true, // transparent — the video shows through behind the splats
 31:       powerPreference: 'high-performance',
 32:     });
 33:     renderer.setSize(mount.clientWidth, mount.clientHeight);
 34:     renderer.setPixelRatio(PIXEL);
 35:     mount.appendChild(renderer.domElement);
 36: 
 37:     // Brand-aligned palette (deep navy world, cyan + warm-orange highlights)
 38:     const COL_CYAN = new THREE.Color('#7dd3fc');
 39:     const COL_ATMO = new THREE.Color('#38bdf8');
 40:     const COL_ACCENT = new THREE.Color('#fb923c');
 41:     const COL_PALE = new THREE.Color('#e7f2ff');
 42: 
 43:     const cloud = new THREE.Group();
 44:     scene.add(cloud);
 45: 
 46:     const disposables: { dispose: () => void }[] = [];
 47: 
 48:     // ── Volumetric splat cloud ─────────────────────────────────────────────
 49:     // Points are biased toward clustered "filaments" rather than uniform noise
 50:     // so it reads as a captured structure, not TV static.
 51:     const COUNT = isMobile ? 1600 : 3200;
 52:     const HALF_X = 11;
 53:     const HALF_Y = 6.5;
 54:     const Z_NEAR = 3.0; // closest splats (in front of camera focal plane)
 55:     const Z_FAR = -22.0; // deep background splats
 56: 
 57:     const pos = new Float32Array(COUNT * 3);
 58:     const rand = new Float32Array(COUNT);
 59:     const size = new Float32Array(COUNT);
 60:     const colorMix = new Float32Array(COUNT); // 0..1 → palette lerp key
 61:     const tmpColor = new THREE.Color();
 62:     const colors = new Float32Array(COUNT * 3);
 63: 
 64:     const cluster = new THREE.Vector3();
 65:     let clusterLife = 0;
 66:     for (let i = 0; i < COUNT; i++) {
 67:       const i3 = i * 3;
 68: 
 69:       // Occasionally reseed a cluster centre; nearby points share it → filaments
 70:       if (clusterLife <= 0) {
 71:         cluster.set(
 72:           (Math.random() - 0.5) * 2 * HALF_X,
 73:           (Math.random() - 0.5) * 2 * HALF_Y,
 74:           Z_FAR + Math.random() * (Z_NEAR - Z_FAR),
 75:         );
 76:         clusterLife = 6 + Math.floor(Math.random() * 22);
 77:       }
 78:       clusterLife--;
 79: 
 80:       const spread = 1.6 + Math.random() * 2.4;
 81:       pos[i3] = cluster.x + (Math.random() - 0.5) * spread;
 82:       pos[i3 + 1] = cluster.y + (Math.random() - 0.5) * spread * 0.7;
 83:       pos[i3 + 2] = cluster.z + (Math.random() - 0.5) * spread * 1.4;
 84: 
 85:       rand[i] = Math.random();
 86:       // A few large, very soft "bokeh" splats; most are small grains.
 87:       size[i] = Math.random() > 0.9 ? 2.2 + Math.random() * 2.6 : 0.7 + Math.random() * 1.1;
 88: 
 89:       // Colour: mostly cool cyan, a cool-bright minority, sparse warm accents.
 90:       const r = Math.random();
 91:       let key: number;
 92:       if (r > 0.93) {
 93:         tmpColor.copy(COL_ACCENT);
 94:         key = 1.0;
 95:       } else if (r > 0.7) {
 96:         tmpColor.copy(COL_PALE);
 97:         key = 0.6;
 98:       } else if (r > 0.4) {
 99:         tmpColor.copy(COL_CYAN);
100:         key = 0.35;
101:       } else {
102:         tmpColor.copy(COL_ATMO);
103:         key = 0.15;
104:       }
105:       colorMix[i] = key;
106:       colors[i3] = tmpColor.r;
107:       colors[i3 + 1] = tmpColor.g;
108:       colors[i3 + 2] = tmpColor.b;
109:     }
110: 
111:     const geo = new THREE.BufferGeometry();
112:     geo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
113:     geo.setAttribute('aRand', new THREE.BufferAttribute(rand, 1));
114:     geo.setAttribute('aSize', new THREE.BufferAttribute(size, 1));
115:     geo.setAttribute('aColor', new THREE.BufferAttribute(colors, 3));
116:     geo.setAttribute('aMix', new THREE.BufferAttribute(colorMix, 1));
117:     disposables.push(geo);
118: 
119:     const mat = new THREE.ShaderMaterial({
120:       uniforms: {
121:         uTime: { value: 0 },
122:         uSize: { value: 26.0 * PIXEL },
123:         uDrift: { value: prefersReducedMotion ? 0.0 : 1.0 },
124:         uZNear: { value: Z_NEAR },
125:         uZFar: { value: Z_FAR },
126:       },
127:       vertexShader: `
128:         attribute float aRand;
129:         attribute float aSize;
130:         attribute vec3 aColor;
131:         attribute float aMix;
132:         uniform float uTime;
133:         uniform float uSize;
134:         uniform float uDrift;
135:         varying float vTwinkle;
136:         varying float vFog;
137:         varying vec3 vColor;
138:         void main() {
139:           vColor = aColor;
140:           float ph = aRand * 6.2831853;
141: 
142:           // Gentle volumetric drift — GPU-side so it costs ~nothing.
143:           vec3 p = position;
144:           p.x += sin(uTime * 0.16 + ph) * 0.9 * uDrift;
145:           p.y += cos(uTime * 0.13 + ph * 1.3) * 0.6 * uDrift;
146:           p.z += sin(uTime * 0.10 + ph * 0.7) * 1.1 * uDrift;
147: 
148:           vec4 mv = modelViewMatrix * vec4(p, 1.0);
149:           float depth = -mv.z;
150: 
151:           // Near splats bigger & brighter; far ones fade into the navy fog.
152:           vTwinkle = 0.55 + 0.45 * sin(uTime * 1.1 + ph * 4.0);
153:           vFog = clamp((depth - 3.0) / 24.0, 0.0, 1.0); // 0 near → 1 far
154: 
155:           gl_PointSize = uSize * aSize * (0.6 + 0.4 * vTwinkle) / depth;
156:           gl_Position = projectionMatrix * mv;
157:         }
158:       `,
159:       fragmentShader: `
160:         varying float vTwinkle;
161:         varying float vFog;
162:         varying vec3 vColor;
163:         void main() {
164:           // Soft gaussian falloff = the "splat".
165:           float d = length(gl_PointCoord - vec2(0.5));
166:           float a = exp(-d * d * 7.0);
167:           if (a < 0.01) discard;
168: 
169:           // Fade far splats out (depth fog) and dim with twinkle.
170:           float fog = 1.0 - vFog;
171:           float alpha = a * fog * (0.32 + 0.5 * vTwinkle) * 0.9;
172:           gl_FragColor = vec4(vColor, alpha);
173:         }
174:       `,
175:       transparent: true,
176:       depthTest: false,
177:       depthWrite: false,
178:       blending: THREE.AdditiveBlending,
179:     });
180:     disposables.push(mat);
181: 
182:     const splats = new THREE.Points(geo, mat);
183:     cloud.add(splats);
184: 
185:     // ── Animation loop ──────────────────────────────────────────────────────
186:     let animId = 0;
187:     let running = false;
188:     const clock = new THREE.Clock();
189: 
190:     const animate = () => {
191:       const t = clock.getElapsedTime();
192:       mat.uniforms.uTime.value = t;
193: 
194:       // Slow cloud roll only — mouse parallax removed (was doubling work with hero layer).
195:       if (!prefersReducedMotion) {
196:         cloud.rotation.y = Math.sin(t * 0.05) * 0.06;
197:         cloud.rotation.x = Math.cos(t * 0.04) * 0.04;
198:       }
199: 
200:       camera.position.set(0, 0, 8);
201:       camera.lookAt(0, 0, -6);
202: 
203:       renderer.render(scene, camera);
204:       animId = requestAnimationFrame(animate);
205:     };
206: 
207:     const start = () => {
208:       if (running) return;
209:       running = true;
210:       clock.getDelta(); // swallow paused gap
211:       animId = requestAnimationFrame(animate);
212:     };
213:     const stop = () => {
214:       running = false;
215:       cancelAnimationFrame(animId);
216:     };
217: 
218:     const io = new IntersectionObserver(
219:       ([entry]) => {
220:         if (entry.isIntersecting && !document.hidden) start();
221:         else stop();
222:       },
223:       { threshold: 0.01 },
224:     );
225:     io.observe(mount);
226: 
227:     const onVisibility = () => {
228:       if (document.hidden) stop();
229:       else start();
230:     };
231:     document.addEventListener('visibilitychange', onVisibility);
232:     start();
233: 
234:     // ── Resize ───────────────────────────────────────────────────────────────
235:     const onResize = () => {
236:       camera.aspect = mount.clientWidth / mount.clientHeight;
237:       camera.updateProjectionMatrix();
238:       renderer.setSize(mount.clientWidth, mount.clientHeight);
239:     };
240:     window.addEventListener('resize', onResize, { passive: true });
241: 
242:     // ── Cleanup ──────────────────────────────────────────────────────────────
243:     return () => {
244:       stop();
245:       io.disconnect();
246:       document.removeEventListener('visibilitychange', onVisibility);
247:       window.removeEventListener('resize', onResize);
248:       disposables.forEach((d) => d.dispose());
249:       renderer.dispose();
250:       renderer.domElement.remove();
251:     };
252:   }, []);
253: 
254:   return (
255:     <div
256:       ref={mountRef}
257:       className="absolute inset-0 w-full h-full pointer-events-none"
258:       aria-hidden="true"
259:     />
260:   );
261: };
262: 
263: export default SplatField;
</file>

