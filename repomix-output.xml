<file path="src/lib/scrollTriggerCleanup.ts">
 1: import { ScrollTrigger } from "gsap/ScrollTrigger";
 2: 
 3: /** Tear down GSAP pin spacers before React unmounts (prevents removeChild errors). */
 4: export function killPinnedScrollTriggers() {
 5:   ScrollTrigger.getAll().forEach((st) => {
 6:     if (st.pin || st.vars.pin) {
 7:       st.kill(true);
 8:     }
 9:   });
10: }
11: 
12: /** Kill every ScrollTrigger whose trigger lives inside `root`. */
13: export function killScrollTriggersIn(root: HTMLElement | null) {
14:   if (!root) return;
15: 
16:   ScrollTrigger.getAll().forEach((st) => {
17:     const trigger = st.trigger;
18:     if (trigger instanceof Element && root.contains(trigger)) {
19:       st.kill(true);
20:     }
21:   });
22: }
</file>

