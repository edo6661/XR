130:           : { opacity: 0, y: 44, scale: 0.82, filter: 'blur(10px)' }
131:       }
132:       transition={{
133:         delay: active ? 0.12 + index * 0.1 : 0,
134:         duration: 0.7,
135:         ease: [0.22, 1.4, 0.4, 1], // slight overshoot → the "boom"
136:       }}
137:       style={{ transformStyle: 'preserve-3d' }}
138:     >
139:       {/* Shake wrapper (separate so it composes with the entrance transform) */}
140:       <motion.div
141:         animate={shake}
142:         transition={
143:           reduce || hovered
144:             ? { duration: 0.4, ease: 'easeOut' }
145:             : {
146:               duration: 5.5 + index * 0.8,
147:               repeat: Infinity,
148:               ease: 'easeInOut',
149:             }
150:         }
151:         style={{ transformStyle: 'preserve-3d' }}
152:       >
153:         {/* Tilt wrapper */}
154:         <motion.div style={{ rotateX: rx, rotateY: ry, transformStyle: 'preserve-3d' }}>
155:           <Link
156:             to={tile.to}
