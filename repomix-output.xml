<file path="src/components/hero/HeroVideoBackdrop.tsx">
  1: import { useEffect, useRef } from 'react';
  2: import { motion, useReducedMotion } from 'framer-motion';
  3: 
  4: /**
  5:  * HeroVideoBackdrop — a cinematic, "next-worldly" video layer for the hero.
  6:  *
  7:  * A raw stock clip on its own reads cheap and "gamer". To land the client's
  8:  * "Corporate + Metaverse" brief we do three things on top of the footage:
  9:  *   1. A slow ken-burns push-in + drift so the flat clip gains a sense of 3D
 10:  *      depth (immersive, not 2D-flat) — disabled under reduced-motion.
 11:  *   2. A per-clip colour filter that pulls the footage onto the brand palette.
 12:  *   3. Layered grade passes (deep-navy floor, cyan/orange HUD tint, vignette)
 13:  *      so the result feels like an elegant B2B keynote backdrop, not a loop.
 14:  *
 15:  * The component is intentionally "dumb": phase-driven blur / brightness / scale
 16:  * and the parallax translate are applied by the parent wrapper in HeroSection,
 17:  * so this layer inherits the HoloLens focus-pull for free.
 18:  */
 19: 
 20: export interface HeroVideoConfig {
 21:   /** Public path to the mp4 (e.g. `/hero/videos/3d_digital_globe.mp4`). */
 22:   src: string;
 23:   /** Optional still shown before the first frame decodes. */
 24:   poster?: string;
 25:   /** Framing of the focal point, e.g. `'50% 35%'` to favour the upper third. */
 26:   objectPosition?: string;
 27:   /** CSS filter that grades the raw clip toward the brand palette. */
 28:   filter?: string;
 29: }
 30: 
 31: const HeroVideoBackdrop = ({
 32:   src,
 33:   poster,
 34:   objectPosition = '50% 50%',
 35:   filter = 'brightness(0.9) contrast(1.05) saturate(1.04)',
 36: }: HeroVideoConfig) => {
 37:   const videoRef = useRef<HTMLVideoElement>(null);
 38:   const reduce = useReducedMotion();
 39: 
 40:   useEffect(() => {
 41:     const v = videoRef.current;
 42:     if (!v) return;
 43:     // Some browsers defer autoplay until interaction; swallow the rejection.
 44:     const tryPlay = () => v.play().catch(() => { });
 45:     tryPlay();
 46:     v.addEventListener('canplay', tryPlay, { once: true });
 47:     return () => v.removeEventListener('canplay', tryPlay);
 48:   }, [src]);
 49: 
 50:   return (
 51:     <div
 52:       className="absolute inset-0 overflow-hidden"
 53:       style={{ isolation: 'isolate' }}
 54:       aria-hidden="true"
 55:     >
 56:       {/* Ken-burns wrapper — never drops below 1.06 so parent parallax + drift
 57:           can never expose a hard edge. */}
 58:       <motion.div
 59:         className="absolute inset-0"
 60:         initial={reduce ? { scale: 1.06 } : { scale: 1.14 }}
 61:         animate={
 62:           reduce
 63:             ? { scale: 1.06 }
 64:             : { scale: 1.06, x: ['-1.4%', '1.4%', '-1.4%'], y: ['1%', '-1%', '1%'] }
 65:         }
 66:         transition={{
 67:           scale: { duration: 2.6, ease: [0.16, 1, 0.3, 1] },
 68:           x: { duration: 40, repeat: Infinity, ease: 'easeInOut' },
 69:           y: { duration: 52, repeat: Infinity, ease: 'easeInOut' },
 70:         }}
 71:         style={{ willChange: 'transform' }}
 72:       >
 73:         <video
 74:           ref={videoRef}
 75:           className="absolute inset-0 h-full w-full object-cover"
 76:           style={{ objectPosition, filter }}
 77:           src={src}
 78:           poster={poster}
 79:           autoPlay
 80:           muted
 81:           loop
 82:           playsInline
 83:           preload="auto"
 84:           disablePictureInPicture
 85:         />
 86:       </motion.div>
 87: 
 88:       {/* Deep-navy floor (multiply) — sinks the blacks into the brand background
 89:           so the clip never reads as a bright stock loop. */}
 90:       <div
 91:         className="absolute inset-0 mix-blend-multiply"
 92:         style={{
 93:           background: 'linear-gradient(180deg, #0b1730 0%, #050b18 100%)',
 94:           opacity: 0.42,
 95:         }}
 96:       />
 97: 
 98:       {/* Cyan-top / orange-floor HUD tint (screen) — the "next-worldly" glow. */}
 99:       <div
100:         className="absolute inset-0 mix-blend-screen"
101:         style={{
102:           background:
103:             'radial-gradient(120% 85% at 50% 14%, rgba(56,189,248,0.14) 0%, transparent 55%), radial-gradient(100% 80% at 50% 102%, rgba(251,146,60,0.12) 0%, transparent 58%)',
104:         }}
105:       />
106: 
107:       {/* Cinematic vignette — focuses the eye centre-stage for the reveal. */}
108:       <div
109:         className="absolute inset-0"
110:         style={{ boxShadow: 'inset 0 0 240px 48px rgba(5,11,24,0.82)' }}
111:       />
112:     </div>
113:   );
114: };
115: 
116: export default HeroVideoBackdrop;
</file>

<file path="src/components/hero/SplatField.tsx">
  1: import { useEffect, useRef } from 'react';
  2: import * as THREE from 'three';
  3: 
  4: /**
  5:  * SplatField — a volumetric particle layer that evokes a 3D Gaussian-Splatting
  6:  * viewer (the look Tamil referenced: a real space captured as millions of soft,
  7:  * depth-aware "splats" you fly through).
  8:  *
  9:  * We don't have a trained .splat/.ply asset, so this is a stylised emulation:
 10:  * a cloud of soft gaussian sprites distributed through a depth volume, with
 11:  * perspective-correct sizing (near = big & bright, far = tiny & dim), depth fog,
 12:  * gentle per-point drift, and mouse parallax. Layered IN FRONT of the spatial
 13:  * video it adds genuine 3D depth — turning a flat clip into a volumetric,
 14:  * "captured space" hero that reads as immersive + next-worldly without the
 15:  * gamer/cyberpunk vibe.
 16:  *
 17:  * Built to be cheap and safe: GPU-driven motion (no per-frame CPU loops),
 18:  * capped pixel ratio, pauses when offscreen / tab hidden, full WebGL teardown.
 19:  */
 20: 
 21: const SplatField = () => {
 22:   const mountRef = useRef<HTMLDivElement>(null);
 23: 
 24:   useEffect(() => {
 25:     const mount = mountRef.current;
 26:     if (!mount) return;
 27: 
 28:     const prefersReducedMotion = window.matchMedia(
 29:       '(prefers-reduced-motion: reduce)',
 30:     ).matches;
 31:     const isMobile = window.innerWidth < 768;
 32:     const PIXEL = Math.min(window.devicePixelRatio, 1.5);
 33: 
 34:     // ── Scene · Camera · Renderer ──────────────────────────────────────────
 35:     const scene = new THREE.Scene();
 36:     const camera = new THREE.PerspectiveCamera(
 37:       55,
 38:       mount.clientWidth / mount.clientHeight,
 39:       0.1,
 40:       100,
 41:     );
 42:     camera.position.set(0, 0, 8);
 43: 
 44:     const renderer = new THREE.WebGLRenderer({
 45:       antialias: true,
 46:       alpha: true, // transparent — the video shows through behind the splats
 47:       powerPreference: 'high-performance',
 48:     });
 49:     renderer.setSize(mount.clientWidth, mount.clientHeight);
 50:     renderer.setPixelRatio(PIXEL);
 51:     mount.appendChild(renderer.domElement);
 52: 
 53:     // Brand-aligned palette (deep navy world, cyan + warm-orange highlights)
 54:     const COL_CYAN = new THREE.Color('#7dd3fc');
 55:     const COL_ATMO = new THREE.Color('#38bdf8');
 56:     const COL_ACCENT = new THREE.Color('#fb923c');
 57:     const COL_PALE = new THREE.Color('#e7f2ff');
 58: 
 59:     const cloud = new THREE.Group();
 60:     scene.add(cloud);
 61: 
 62:     const disposables: { dispose: () => void }[] = [];
 63: 
 64:     // ── Volumetric splat cloud ─────────────────────────────────────────────
 65:     // Points are biased toward clustered "filaments" rather than uniform noise
 66:     // so it reads as a captured structure, not TV static.
 67:     const COUNT = isMobile ? 2600 : 6000;
 68:     const HALF_X = 11;
 69:     const HALF_Y = 6.5;
 70:     const Z_NEAR = 3.0; // closest splats (in front of camera focal plane)
 71:     const Z_FAR = -22.0; // deep background splats
 72: 
 73:     const pos = new Float32Array(COUNT * 3);
 74:     const rand = new Float32Array(COUNT);
 75:     const size = new Float32Array(COUNT);
 76:     const colorMix = new Float32Array(COUNT); // 0..1 → palette lerp key
 77:     const tmpColor = new THREE.Color();
 78:     const colors = new Float32Array(COUNT * 3);
 79: 
 80:     let cluster = new THREE.Vector3();
 81:     let clusterLife = 0;
 82:     for (let i = 0; i < COUNT; i++) {
 83:       const i3 = i * 3;
 84: 
 85:       // Occasionally reseed a cluster centre; nearby points share it → filaments
 86:       if (clusterLife <= 0) {
 87:         cluster.set(
 88:           (Math.random() - 0.5) * 2 * HALF_X,
 89:           (Math.random() - 0.5) * 2 * HALF_Y,
 90:           Z_FAR + Math.random() * (Z_NEAR - Z_FAR),
 91:         );
 92:         clusterLife = 6 + Math.floor(Math.random() * 22);
 93:       }
 94:       clusterLife--;
 95: 
 96:       const spread = 1.6 + Math.random() * 2.4;
 97:       pos[i3] = cluster.x + (Math.random() - 0.5) * spread;
 98:       pos[i3 + 1] = cluster.y + (Math.random() - 0.5) * spread * 0.7;
 99:       pos[i3 + 2] = cluster.z + (Math.random() - 0.5) * spread * 1.4;
100: 
101:       rand[i] = Math.random();
102:       // A few large, very soft "bokeh" splats; most are small grains.
103:       size[i] = Math.random() > 0.9 ? 2.2 + Math.random() * 2.6 : 0.7 + Math.random() * 1.1;
104: 
105:       // Colour: mostly cool cyan, a cool-bright minority, sparse warm accents.
106:       const r = Math.random();
107:       let key: number;
108:       if (r > 0.93) {
109:         tmpColor.copy(COL_ACCENT);
110:         key = 1.0;
111:       } else if (r > 0.7) {
112:         tmpColor.copy(COL_PALE);
113:         key = 0.6;
114:       } else if (r > 0.4) {
115:         tmpColor.copy(COL_CYAN);
116:         key = 0.35;
117:       } else {
118:         tmpColor.copy(COL_ATMO);
119:         key = 0.15;
120:       }
121:       colorMix[i] = key;
122:       colors[i3] = tmpColor.r;
123:       colors[i3 + 1] = tmpColor.g;
124:       colors[i3 + 2] = tmpColor.b;
125:     }
126: 
127:     const geo = new THREE.BufferGeometry();
128:     geo.setAttribute('position', new THREE.BufferAttribute(pos, 3));
129:     geo.setAttribute('aRand', new THREE.BufferAttribute(rand, 1));
130:     geo.setAttribute('aSize', new THREE.BufferAttribute(size, 1));
131:     geo.setAttribute('aColor', new THREE.BufferAttribute(colors, 3));
132:     geo.setAttribute('aMix', new THREE.BufferAttribute(colorMix, 1));
133:     disposables.push(geo);
134: 
135:     const mat = new THREE.ShaderMaterial({
136:       uniforms: {
137:         uTime: { value: 0 },
138:         uSize: { value: 26.0 * PIXEL },
139:         uDrift: { value: prefersReducedMotion ? 0.0 : 1.0 },
140:         uZNear: { value: Z_NEAR },
141:         uZFar: { value: Z_FAR },
142:       },
143:       vertexShader: `
144:         attribute float aRand;
145:         attribute float aSize;
146:         attribute vec3 aColor;
147:         attribute float aMix;
148:         uniform float uTime;
149:         uniform float uSize;
150:         uniform float uDrift;
151:         varying float vTwinkle;
152:         varying float vFog;
153:         varying vec3 vColor;
154:         void main() {
155:           vColor = aColor;
156:           float ph = aRand * 6.2831853;
157: 
158:           // Gentle volumetric drift — GPU-side so it costs ~nothing.
159:           vec3 p = position;
160:           p.x += sin(uTime * 0.16 + ph) * 0.9 * uDrift;
161:           p.y += cos(uTime * 0.13 + ph * 1.3) * 0.6 * uDrift;
162:           p.z += sin(uTime * 0.10 + ph * 0.7) * 1.1 * uDrift;
163: 
164:           vec4 mv = modelViewMatrix * vec4(p, 1.0);
165:           float depth = -mv.z;
166: 
167:           // Near splats bigger & brighter; far ones fade into the navy fog.
168:           vTwinkle = 0.55 + 0.45 * sin(uTime * 1.1 + ph * 4.0);
169:           vFog = clamp((depth - 3.0) / 24.0, 0.0, 1.0); // 0 near → 1 far
170: 
171:           gl_PointSize = uSize * aSize * (0.6 + 0.4 * vTwinkle) / depth;
172:           gl_Position = projectionMatrix * mv;
173:         }
174:       `,
175:       fragmentShader: `
176:         varying float vTwinkle;
177:         varying float vFog;
178:         varying vec3 vColor;
179:         void main() {
180:           // Soft gaussian falloff = the "splat".
181:           float d = length(gl_PointCoord - vec2(0.5));
182:           float a = exp(-d * d * 7.0);
183:           if (a < 0.01) discard;
184: 
185:           // Fade far splats out (depth fog) and dim with twinkle.
186:           float fog = 1.0 - vFog;
187:           float alpha = a * fog * (0.32 + 0.5 * vTwinkle) * 0.9;
188:           gl_FragColor = vec4(vColor, alpha);
189:         }
190:       `,
191:       transparent: true,
192:       depthTest: false,
193:       depthWrite: false,
194:       blending: THREE.AdditiveBlending,
195:     });
196:     disposables.push(mat);
197: 
198:     const splats = new THREE.Points(geo, mat);
199:     cloud.add(splats);
200: 
201:     // ── Mouse parallax ─────────────────────────────────────────────────────
202:     let mouseX = 0;
203:     let mouseY = 0;
204:     const onMouseMove = (e: MouseEvent) => {
205:       mouseX = (e.clientX / window.innerWidth) * 2 - 1;
206:       mouseY = -(e.clientY / window.innerHeight) * 2 + 1;
207:     };
208:     window.addEventListener('mousemove', onMouseMove, { passive: true });
209: 
210:     // ── Animation loop ──────────────────────────────────────────────────────
211:     let animId = 0;
212:     let running = false;
213:     const clock = new THREE.Clock();
214: 
215:     const animate = () => {
216:       const t = clock.getElapsedTime();
217:       mat.uniforms.uTime.value = t;
218: 
219:       // Very slow cloud roll for life even when the mouse is still.
220:       if (!prefersReducedMotion) {
221:         cloud.rotation.y = Math.sin(t * 0.05) * 0.06;
222:         cloud.rotation.x = Math.cos(t * 0.04) * 0.04;
223:       }
224: 
225:       // Smooth camera parallax → the depth "fly-through" feel.
226:       const tx = mouseX * 1.1;
227:       const ty = mouseY * 0.7;
228:       camera.position.x += (tx - camera.position.x) * 0.035;
229:       camera.position.y += (ty - camera.position.y) * 0.035;
230:       camera.lookAt(0, 0, -6);
231: 
232:       renderer.render(scene, camera);
233:       animId = requestAnimationFrame(animate);
234:     };
235: 
236:     const start = () => {
237:       if (running) return;
238:       running = true;
239:       clock.getDelta(); // swallow paused gap
240:       animId = requestAnimationFrame(animate);
241:     };
242:     const stop = () => {
243:       running = false;
244:       cancelAnimationFrame(animId);
245:     };
246: 
247:     const io = new IntersectionObserver(
248:       ([entry]) => {
249:         if (entry.isIntersecting && !document.hidden) start();
250:         else stop();
251:       },
252:       { threshold: 0.01 },
253:     );
254:     io.observe(mount);
255: 
256:     const onVisibility = () => {
257:       if (document.hidden) stop();
258:       else start();
259:     };
260:     document.addEventListener('visibilitychange', onVisibility);
261:     start();
262: 
263:     // ── Resize ───────────────────────────────────────────────────────────────
264:     const onResize = () => {
265:       camera.aspect = mount.clientWidth / mount.clientHeight;
266:       camera.updateProjectionMatrix();
267:       renderer.setSize(mount.clientWidth, mount.clientHeight);
268:     };
269:     window.addEventListener('resize', onResize, { passive: true });
270: 
271:     // ── Cleanup ──────────────────────────────────────────────────────────────
272:     return () => {
273:       stop();
274:       io.disconnect();
275:       document.removeEventListener('visibilitychange', onVisibility);
276:       window.removeEventListener('mousemove', onMouseMove);
277:       window.removeEventListener('resize', onResize);
278:       disposables.forEach((d) => d.dispose());
279:       renderer.dispose();
280:       renderer.domElement.remove();
281:     };
282:   }, []);
283: 
284:   return (
285:     <div
286:       ref={mountRef}
287:       className="absolute inset-0 w-full h-full pointer-events-none"
288:       aria-hidden="true"
289:     />
290:   );
291: };
292: 
293: export default SplatField;
</file>

