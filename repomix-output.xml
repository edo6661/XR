<file path="src/components/contact/ContactForm.tsx">
  1: import { useState, type FormEvent } from 'react';
  2: import { motion, AnimatePresence } from 'framer-motion';
  3: import { COMPANY } from '../../core/navigation/routes';
  4: import { CONTACT_SUBJECTS } from '../../core/content/contactPage';
  5: 
  6: interface ContactFormProps {
  7:   initialSubject?: string;
  8: }
  9: 
 10: const ContactForm = ({ initialSubject }: ContactFormProps) => {
 11:   const [submitted, setSubmitted] = useState(false);
 12:   const [subject, setSubject] = useState<string>(initialSubject ?? CONTACT_SUBJECTS[0]);
 13: 
 14:   const isMedia = subject === 'Media Enquiries' || subject === 'Press Accreditation';
 15: 
 16:   const handleSubmit = (e: FormEvent<HTMLFormElement>) => {
 17:     e.preventDefault();
 18:     const form = new FormData(e.currentTarget);
 19:     const subj = encodeURIComponent(`XR Summits — ${String(form.get('subject') ?? 'Enquiry')}`);
 20:     const lines = [
 21:       `Subject: ${form.get('subject')}`,
 22:       `Name: ${form.get('name')}`,
 23:       `Job Title: ${form.get('jobtitle') ?? '—'}`,
 24:       `Email: ${form.get('email')}`,
 25:       `Organisation: ${form.get('organisation')}`,
 26:       `Phone: ${form.get('phone') ?? '—'}`,
 27:     ];
 28:     if (isMedia) {
 29:       lines.push(`Outlet: ${form.get('outlet') ?? '—'}`);
 30:       lines.push(`Coverage Angle: ${form.get('coverage') ?? '—'}`);
 31:     }
 32:     lines.push('', `Message:`, String(form.get('message') ?? ''));
 33:     const body = encodeURIComponent(lines.join('\n'));
 34:     window.location.href = `mailto:${COMPANY.email}?subject=${subj}&body=${body}`;
 35:     setSubmitted(true);
 36:   };
 37: 
 38:   if (submitted) {
 39:     return (
 40:       <motion.div
 41:         initial={{ opacity: 0, y: 12 }}
 42:         animate={{ opacity: 1, y: 0 }}
 43:         className="rounded-xl p-8 text-center callout-accent"
 44:       >
 45:         <p className="text-foreground text-sm font-heading font-bold mb-2">Message composed</p>
 46:         <p className="text-copy-sm mb-4">
 47:           Your email client should open with your message pre-filled. If it didn't, write directly to{' '}
 48:           <a href={`mailto:${COMPANY.email}`} className="text-accent hover:underline">
 49:             {COMPANY.email}
 50:           </a>
 51:           .
 52:         </p>
 53:         <button
 54:           type="button"
 55:           onClick={() => setSubmitted(false)}
 56:           className="mt-4 text-micro-label font-bold text-accent hover:text-foreground transition-colors"
 57:         >
 58:           Send another message
 59:         </button>
 60:       </motion.div>
 61:     );
 62:   }
 63: 
 64:   return (
 65:     <motion.form
 66:       initial={{ opacity: 0, y: 16 }}
 67:       animate={{ opacity: 1, y: 0 }}
 68:       transition={{ duration: 0.6 }}
 69:       onSubmit={handleSubmit}
 70:       className="flex flex-col gap-4"
 71:     >
 72:       <label className="flex flex-col gap-1.5">
 73:         <span className="text-label-ui">Subject</span>
 74:         <select
 75:           name="subject"
 76:           required
 77:           value={subject}
 78:           onChange={(e) => setSubject(e.target.value)}
 79:           className="input-field"
 80:         >
 81:           {CONTACT_SUBJECTS.map((s) => (
 82:             <option key={s} value={s} className="bg-[#0a0a0a]">{s}</option>
 83:           ))}
 84:         </select>
 85:       </label>
 86: 
 87:       <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
 88:         <label className="flex flex-col gap-1.5">
 89:           <span className="text-label-ui">Full name</span>
 90:           <input name="name" type="text" required autoComplete="name" className="input-field" />
 91:         </label>
 92:         <label className="flex flex-col gap-1.5">
 93:           <span className="text-label-ui">Job title</span>
 94:           <input name="jobtitle" type="text" autoComplete="organization-title" className="input-field" />
 95:         </label>
 96:       </div>
 97: 
 98:       <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
 99:         <label className="flex flex-col gap-1.5">
100:           <span className="text-label-ui">Email</span>
101:           <input name="email" type="email" required autoComplete="email" className="input-field" />
102:         </label>
103:         <label className="flex flex-col gap-1.5">
104:           <span className="text-label-ui">Phone (optional)</span>
105:           <input name="phone" type="tel" autoComplete="tel" className="input-field" />
106:         </label>
107:       </div>
108: 
109:       <label className="flex flex-col gap-1.5">
110:         <span className="text-label-ui">Organisation</span>
111:         <input name="organisation" type="text" className="input-field" />
112:       </label>
113: 
114:       <AnimatePresence>
115:         {isMedia && (
116:           <motion.div
117:             key="media-fields"
118:             initial={{ opacity: 0, height: 0 }}
119:             animate={{ opacity: 1, height: 'auto' }}
120:             exit={{ opacity: 0, height: 0 }}
121:             transition={{ duration: 0.3 }}
122:             className="flex flex-col gap-4 overflow-hidden"
123:           >
124:             <div className="callout-accent">
125:               Applying for press accreditation — please provide your outlet and coverage angle below.
126:             </div>
127:             <label className="flex flex-col gap-1.5">
128:               <span className="text-label-ui">Outlet / Publication</span>
129:               <input name="outlet" type="text" className="input-field" />
130:             </label>
131:             <label className="flex flex-col gap-1.5">
132:               <span className="text-label-ui">Coverage angle</span>
133:               <textarea name="coverage" rows={2} className="input-field resize-none" placeholder="What story are you covering?" />
134:             </label>
135:           </motion.div>
136:         )}
137:       </AnimatePresence>
138: 
139:       <label className="flex flex-col gap-1.5">
140:         <span className="text-label-ui">Message</span>
141:         <textarea
142:           name="message"
143:           rows={5}
144:           required
145:           className="input-field resize-y min-h-[120px]"
146:         />
147:       </label>
148: 
149:       <button type="submit" className="btn-orange w-full py-3.5">
150:         {isMedia ? 'Apply for accreditation' : 'Send via email'}
151:       </button>
152:     </motion.form>
153:   );
154: };
155: 
156: export default ContactForm;
</file>

