                    fontSize: 'clamp(2.4rem, 5.2vw, 4rem)',
                    letterSpacing: '0.03em',
                    ...(line.accent
                      ? {
                        background: 'linear-gradient(130deg, #fb923c 0%, #f0f4ff 85%)',
