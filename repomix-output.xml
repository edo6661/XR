215:                     {LOADING_STEPS[stepIndex]}
216:                   </motion.p>
217:                 </AnimatePresence>
218:               </div>
219:             </div>
220:           </div>
221:         </motion.div>
222:       )}
223:     </AnimatePresence>
224:   );
225: };
