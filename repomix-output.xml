227: export default Preloader;
</file>

<file path="src/components/ui/ScrollProgress.tsx">
 1: // src/components/ui/ScrollProgress.tsx
 2: import { useEffect, useRef } from 'react';
 3: import gsap from 'gsap';
 4: import { ScrollTrigger } from 'gsap/ScrollTrigger';
 5: 
 6: gsap.registerPlugin(ScrollTrigger);
 7: 
 8: const ScrollProgress = () => {
 9:   const progressRef = useRef<HTMLDivElement>(null);
10: 
11:   useEffect(() => {
12:     const ctx = gsap.context(() => {
13:       // Skala dari 0 (X) ke 1 sesuai ukuran scroll keseluruhan document
14:       gsap.to(progressRef.current, {
15:         scaleX: 1,
16:         ease: "none",
17:         scrollTrigger: {
18:           trigger: document.documentElement, // Memantau seluruh body
19:           start: "top top",
20:           end: "bottom bottom",
21:           scrub: 0.2, // Nilai kecil untuk memberian sedikit efek delay/smooth (seperti useSpring)
22:         }
23:       });
24:     });
25: 
26:     return () => ctx.revert();
27:   }, []);
28: 
29:   return (
30:     <div
31:       ref={progressRef}
32:       className="fixed top-0 left-0 right-0 h-[2px] bg-accent origin-left z-[9999] will-change-transform"
33:       style={{
34:         transform: 'scaleX(0)', // Inisialisasi awal 0
35:         boxShadow: '0 0 12px rgba(251,146,60,0.8)'
36:       }}
37:     />
38:   );
39: };
40: 
41: export default ScrollProgress;
</file>

