 83:     if (skipIntro) return;
 84: 
 85:     const timers: ReturnType<typeof setTimeout>[] = [];
 86:     STEP_TIMELINE.forEach(({ at, step: s }) => {
 87:       timers.push(setTimeout(() => setStep(s), at));
 88:     });
 89: 
 90:     let skipped = false;
 91:     const fastForward = () => {
 92:       if (skipped) return;
 93:       skipped = true;
 94:       timers.forEach(clearTimeout);
 95:       setStep(LAST_STEP);
 96:       removeListeners();
 97:     };
 98:     const events: (keyof WindowEventMap)[] = ['wheel', 'touchmove', 'pointerdown', 'keydown'];
 99:     const removeListeners = () =>
100:       events.forEach((ev) => window.removeEventListener(ev, fastForward));
101:     events.forEach((ev) => window.addEventListener(ev, fastForward, { passive: true }));
102: 
103:     return () => {
104:       timers.forEach(clearTimeout);
105:       removeListeners();
106:     };
107:   }, [skipIntro]);
