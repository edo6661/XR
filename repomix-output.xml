375:           className="mb-10 max-w-5xl"
376:         >
377:           <h2
378:             id="aixr-activations-heading"
379:             className="font-heading font-bold mb-3"
380:             style={{ fontSize: 'clamp(1.5rem, 3vw, 2.1rem)', color: '#f8faff' }}
381:           >
382:             2 Days. 6 Experiences.{' '}
383:             <span className="gradient-text-accent">
384:               A prelude to XR Asia Summit 2026.
385:             </span>
386:           </h2>
387:           <p
388:             className="leading-relaxed"
389:             style={{ fontSize: 'clamp(1rem, 2.5vw, 1.1rem)', lineHeight: 1.85, color: '#a8b8d0' }}
390:           >
391:             16–17 October 2026 · Borneo Convention Centre (BCCK), Kuching, Sarawak.
392:             <br />
393:             <span className="font-semibold" style={{ color: '#f8faff' }}>Explore what's waiting for you</span>
394:           </p>
395:         </motion.div>
396: 
397:         {/* ── Sticky sentinel + Tab Row ──────────────────────────────── */}
398:         <div
399:           ref={tabsRef}
400:           className="sticky z-40 -mx-6 px-6 py-3 mb-5 transition-all duration-300"
401:           style={{
402:             top: '64px',
403:             background: isTabsSticky
404:               ? 'rgba(5,5,5,0.94)'
405:               : 'transparent',
406:             backdropFilter: isTabsSticky ? 'blur(20px)' : 'none',
407:             WebkitBackdropFilter: isTabsSticky ? 'blur(20px)' : 'none',
408:             borderBottom: isTabsSticky
409:               ? '1px solid rgba(239,120,61,0.15)'
410:               : '1px solid transparent',
411:             boxShadow: isTabsSticky
412:               ? '0 4px 24px rgba(0,0,0,0.4)'
413:               : 'none',
414:           }}
415:         >
416:           <div
417:             className="overflow-x-auto pb-1 -mx-1 px-1"
418:             style={{ scrollbarWidth: 'none' }}
419:           >
420:             <div className="flex gap-2.5 w-max sm:w-auto sm:flex-wrap max-w-7xl">
421:               {ACTIVATIONS.map((activation, index) => (
422:                 <TabButton
423:                   key={activation.id}
424:                   activation={activation}
425:                   isActive={activeId === activation.id}
426:                   index={index}
427:                   onClick={() => handleTabClick(activation.id)}
428:                 />
429:               ))}
430:             </div>
431:           </div>
432:         </div>
433: 
434:         {/* ── Expanded Panel ──────────────────────────────────────────── */}
435:         <AnimatePresence mode="wait">
436:           {activeId && (
437:             <ExpandedPanel
438:               key={activeActivation.id}
439:               activation={activeActivation}
440:             />
441:           )}
442:         </AnimatePresence>
443: 
444:         {/* ── CTA Row ─────────────────────────────────────────────────── */}
445:         <motion.div
446:           initial={{ opacity: 0, y: 16 }}
447:           whileInView={{ opacity: 1, y: 0 }}
448:           viewport={{ once: true, amount: 0.5 }}
449:           transition={{ duration: 0.6, ease: [0.16, 1, 0.3, 1] }}
450:           className="flex flex-col sm:flex-row items-center justify-center gap-3 mt-14 pt-10"
451:           style={{ borderTop: '1px solid rgba(255,255,255,0.07)' }}
452:         >
453:           <button
454:             type="button"
455:             onClick={onDownloadBrochure}
456:             className="w-full sm:w-auto px-8 py-3.5 rounded-sm font-bold tracking-[0.2em] uppercase text-[0.75rem] transition-all duration-300 hover:shadow-[0_0_28px_rgba(239,120,61,0.25)] cursor-none"
457:             style={{
