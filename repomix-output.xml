158:             onMouseLeave={() => {
159:               setHovered(false);
160:               resetTilt();
161:             }}
162:             onMouseMove={handleTilt}
163:             onFocus={() => setHovered(true)}
164:             onBlur={() => setHovered(false)}
165:             className="group relative block cursor-none rounded-2xl overflow-hidden"
166:             style={{
167:               minHeight: isCenter ? 'clamp(150px, 22vh, 188px)' : 'clamp(140px, 20vh, 172px)',
168:               background: 'rgba(13, 27, 46, 0.42)',
169:               backdropFilter: 'blur(18px)',
170:               WebkitBackdropFilter: 'blur(18px)',
171:               border: `1px solid ${tile.accent}${hovered ? '5a' : '2e'}`,
172:               boxShadow: hovered
173:                 ? `0 0 44px ${tile.accent}26, 0 24px 50px rgba(0,0,0,0.5)`
174:                 : `0 12px 34px rgba(0,0,0,0.34)`,
175:               transition: 'border-color 0.4s ease, box-shadow 0.4s ease',
176:             }}
177:           >
178:             {/* Sheen sweep on hover */}
179:             <motion.div
180:               className="absolute inset-0 pointer-events-none"
181:               initial={{ x: '-130%' }}
182:               animate={hovered && !reduce ? { x: ['-130%', '230%'] } : { x: '-130%' }}
183:               transition={{ duration: 0.9, ease: 'easeInOut' }}
184:               style={{
