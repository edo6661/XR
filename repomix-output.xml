  4: import gsap from 'gsap';
  5: 
  6: interface SpotlightCardProps {
  7:   index: number;
  8:   title: string;
  9:   date?: string;
 10:   location?: string;
 11:   description: string;
 12:   accentColor: string;
 13:   tag: string;
 14:   to?: string;
 15:   imageSrc?: string;
 16:   isFeatured?: boolean;
 17:   imagePosition?: string;
 18:   imageDark?: boolean;
 19:   imageTransform?: string;
 20: }
 21: 
 22: const SpotlightCard = ({
 23:   index,
 24:   title,
 25:   date,
 26:   location,
 27:   description,
 28:   accentColor,
 29:   tag,
 30:   to,
 31:   imageSrc,
 32:   isFeatured = false,
 33:   imagePosition = 'center',
 34:   imageDark = true,
 35:   imageTransform = 'none',
 36: 
 37: }: SpotlightCardProps) => {
 38:   const cardRef = useRef<HTMLDivElement>(null);
 39:   const shineRef = useRef<HTMLDivElement>(null);
 40:   const imgRef = useRef<HTMLImageElement>(null);
 41:   const borderRef = useRef<HTMLDivElement>(null);
 42:   const titleRef = useRef<HTMLHeadingElement>(null);
 43:   const descriptionRef = useRef<HTMLParagraphElement>(null);
 44: 
 45:   const handleMouseMove = useCallback((e: React.MouseEvent<HTMLDivElement>) => {
 46:     if (!cardRef.current || !shineRef.current) return;
 47:     const rect = cardRef.current.getBoundingClientRect();
 48:     const x = e.clientX - rect.left;
 49:     const y = e.clientY - rect.top;
 50:     const cx = rect.width / 2;
 51:     const cy = rect.height / 2;
 52: 
 53:     gsap.to(cardRef.current, {
 54:       rotateX: ((y - cy) / cy) * -4,
 55:       rotateY: ((x - cx) / cx) * 4,
 56:       duration: 0.5,
 57:       ease: 'power2.out',
 58:       transformPerspective: 1000,
 59:     });
 60: 
 61:     gsap.to(shineRef.current, {
 62:       x: x - cx,
 63:       y: y - cy,
 64:       opacity: isFeatured ? 0.14 : 0.09,
 65:       duration: 0.38,
 66:       ease: 'power2.out',
 67:       overwrite: 'auto',
 68:     });
 69:   }, [isFeatured]);
 70: 
 71:   const handleMouseEnter = useCallback(() => {
 72:     if (imgRef.current) {
 73:       gsap.to(imgRef.current, { scale: 1.04, duration: 0.7, ease: 'power3.out' });
 74:     }
 75:     if (borderRef.current) {
 76:       borderRef.current.style.borderColor = `${accentColor}42`;
 77:       borderRef.current.style.boxShadow = `0 0 52px ${accentColor}14, inset 0 0 32px ${accentColor}04`;
 78:     }
 79: 
 80:     if (titleRef.current) {
 81:       gsap.to(titleRef.current, {
 82:         duration: 0.5,
 83:         ease: 'power3.out',
 84:       });
 85:     }
 86:     if (descriptionRef.current) {
 87:       gsap.to(descriptionRef.current, {
 88:         color: 'rgba(255, 255, 255, 0.95)',
 89:         duration: 0.5,
 90:         ease: 'power3.out',
 91:         fontSize: '0.83rem',
 92:         fontWeight: 'bold',
 93:         delay: 0.02,
 94:       });
 95:     }
 96:   }, [accentColor]);
 97: 
 98:   const handleMouseLeave = useCallback(() => {
 99:     if (!cardRef.current || !shineRef.current) return;
100:     gsap.to(cardRef.current, { rotateX: 0, rotateY: 0, duration: 0.8, ease: 'power3.out' });
101:     gsap.to(shineRef.current, { opacity: 0, duration: 0.4 });
102:     if (imgRef.current) {
103:       gsap.to(imgRef.current, { scale: 1, duration: 0.7, ease: 'power3.out' });
104:     }
105:     if (borderRef.current) {
106:       borderRef.current.style.borderColor = `${accentColor}20`;
107:       borderRef.current.style.boxShadow = 'none';
108:     }
109: 
110:     if (titleRef.current) {
111:       gsap.to(titleRef.current, {
112:         opacity: 1,
113:         y: 0,
114:         duration: 0.7,
115:         ease: 'power3.out',
116:       });
117:     }
118:     if (descriptionRef.current) {
119:       // PERBAIKAN: Mengembalikan ke fontSize dan fontWeight awal
120:       gsap.to(descriptionRef.current, {
121:         color: 'rgba(200,215,240,0.9)',
122:         fontSize: '0.8rem',
123:         fontWeight: 'normal',
124:         duration: 0.7,
125:         ease: 'power3.out',
126:       });
127:     }
128: 
129:   }, [accentColor]);
130: 
131:   const inner = (
132:     <div
133:       ref={cardRef}
134:       onMouseMove={handleMouseMove}
135:       onMouseEnter={handleMouseEnter}
136:       onMouseLeave={handleMouseLeave}
137:       style={{ transformStyle: 'preserve-3d' }}
138:       className={[
139:         'relative overflow-hidden rounded-xl group cursor-pointer h-full will-change-transform',
140:         isFeatured ? 'min-h-[460px]' : 'min-h-[300px]',
141:       ].join(' ')}
142:     >
143:       {/* ── Background ── */}
144:       <div className="absolute inset-0 overflow-hidden">
145:         {imageSrc ? (
146:           <>
147:             {/* TAMBAHKAN DIV WRAPPER INI UNTUK CUSTOM TRANSFORM */}
148:             <div className="w-full h-full origin-bottom" style={{ transform: imageTransform || 'none' }}>
149:               <img
150:                 ref={imgRef}
151:                 src={imageSrc}
152:                 alt={title}
153:                 className="w-full h-full object-cover"
154:                 style={{ objectPosition: isFeatured ? 'right bottom' : imagePosition }}
155:                 loading="lazy"
156:               />
157:             </div>
158: 
159:             <div
160:               className="absolute inset-0"
161:               style={{
162:                 background: imageDark
163:                   ? `linear-gradient(to top, rgba(5,11,24,0.97) 0%, rgba(5,11,24,0.65) 40%, rgba(5,11,24,0.22) 100%)`
164:                   : `linear-gradient(to top, rgba(5,11,24,0.96) 0%, rgba(5,11,24,0.75) 35%, rgba(5,11,24,0.35) 65%, rgba(5,11,24,0.08) 100%)`,
165:               }}
166:             />
167:           </>
168:         ) : (
169:           <div
170:             className="w-full h-full"
171:             style={{ background: `linear-gradient(148deg, rgba(13,27,46,0.96) 0%, ${accentColor}10 100%)` }}
172:           />
173:         )}
174:       </div>
175: 
176:       {/* ── Border ── */}
177:       <div
178:         ref={borderRef}
179:         className="absolute inset-0 rounded-xl pointer-events-none"
180:         style={{
181:           border: `1px solid ${accentColor}20`,
182:           transition: 'border-color 0.4s ease, box-shadow 0.4s ease',
183:         }}
184:       />
185: 
186:       {/* ── Top edge glow ── */}
187:       <div
188:         className="absolute top-0 left-10 right-10 h-px pointer-events-none"
189:         style={{ background: `linear-gradient(90deg, transparent, ${accentColor}${isFeatured ? '70' : '45'}, transparent)` }}
190:         aria-hidden="true"
191:       />
192: 
193:       {/* ── Corner brackets ── */}
194:       <div className="absolute top-4 left-4 w-4 h-4 border-t border-l pointer-events-none" style={{ borderColor: `${accentColor}48` }} aria-hidden="true" />
195:       <div className="absolute bottom-4 right-4 w-4 h-4 border-b border-r pointer-events-none" style={{ borderColor: `${accentColor}48` }} aria-hidden="true" />
196: 
197:       {/* ── Cursor shine ── */}
198:       <div
199:         ref={shineRef}
200:         className="absolute w-56 h-56 rounded-full pointer-events-none opacity-0 z-[1] will-change-transform"
201:         style={{
202:           background: `radial-gradient(circle, ${accentColor}50 0%, transparent 65%)`,
203:           left: '50%', top: '50%',
204:           transform: 'translate(-50%, -50%)',
205:         }}
206:         aria-hidden="true"
207:       />
208: 
209:       {/* ── Content ── */}
210:       <div className="relative z-10 flex flex-col justify-end h-full p-5 gap-3">
211: 
212:         {/* Tag + index */}
213:         <div className="flex items-center justify-between mb-0.5">
214:           <span
215:             className="text-[0.56rem] font-bold tracking-[0.32em] uppercase px-2.5 py-1 rounded-sm"
216:             style={{
217:               color: accentColor,
218:               background: `${accentColor}16`,
219:               border: `1px solid ${accentColor}28`,
220:             }}
221:           >
222:             {tag}
223:           </span>
224:           <span
225:             className="font-mono text-[0.5rem] tracking-[0.3em]"
226:             style={{ color: `${accentColor}48` }}
227:             aria-hidden="true"
228:           >
229:             {String(index + 1).padStart(2, '0')}
230:           </span>
231:         </div>
232: 
233:         {/* Text */}
234:         <div className="flex flex-col">
235:           <h3
236:             ref={titleRef}
237:             className="font-heading font-bold text-foreground leading-tight mb-2 will-change-transform"
238:             style={{ fontSize: isFeatured ? '1.42rem' : '1.02rem' }}
239:           >
240:             {title}
241:           </h3>
242:           <p
243:             ref={descriptionRef}
244:             className="leading-relaxed line-clamp-4 will-change-transform"
245:             style={{ fontSize: '0.8rem', color: 'rgba(200,215,240,0.9)' }}
246:           >
