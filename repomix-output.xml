  4: import { CONTACT_SUBJECTS } from '../../core/content/contactPage';
  5: 
  6: const INPUT_CLASS =
  7:   'w-full px-4 py-3 rounded-sm bg-[rgba(255,255,255,0.04)] border border-white/10 text-foreground text-sm outline-none focus:border-[rgba(251,146,60,0.45)] transition-colors placeholder:text-foreground-muted/30';
  8: 
  9: interface ContactFormProps {
 10:   initialSubject?: string;
 11: }
 12: 
 13: const ContactForm = ({ initialSubject }: ContactFormProps) => {
 14:   const [submitted, setSubmitted] = useState(false);
 15:   const [subject, setSubject] = useState<string>(initialSubject ?? CONTACT_SUBJECTS[0]);
 16: 
 17:   const isMedia = subject === 'Media Enquiries' || subject === 'Press Accreditation';
 18: 
 19:   const handleSubmit = (e: FormEvent<HTMLFormElement>) => {
 20:     e.preventDefault();
 21:     const form = new FormData(e.currentTarget);
 22:     const subj = encodeURIComponent(`XR Summits — ${String(form.get('subject') ?? 'Enquiry')}`);
 23:     const lines = [
 24:       `Subject: ${form.get('subject')}`,
 25:       `Name: ${form.get('name')}`,
 26:       `Job Title: ${form.get('jobtitle') ?? '—'}`,
 27:       `Email: ${form.get('email')}`,
 28:       `Organisation: ${form.get('organisation')}`,
 29:       `Phone: ${form.get('phone') ?? '—'}`,
 30:     ];
 31:     if (isMedia) {
 32:       lines.push(`Outlet: ${form.get('outlet') ?? '—'}`);
 33:       lines.push(`Coverage Angle: ${form.get('coverage') ?? '—'}`);
 34:     }
 35:     lines.push('', `Message:`, String(form.get('message') ?? ''));
 36:     const body = encodeURIComponent(lines.join('\n'));
 37:     window.location.href = `mailto:${COMPANY.email}?subject=${subj}&body=${body}`;
 38:     setSubmitted(true);
 39:   };
 40: 
 41:   if (submitted) {
 42:     return (
 43:       <motion.div
 44:         initial={{ opacity: 0, y: 12 }}
 45:         animate={{ opacity: 1, y: 0 }}
 46:         className="rounded-xl p-8 text-center"
 47:         style={{
 48:           border: '1px solid rgba(251,146,60,0.25)',
 49:           background: 'rgba(251,146,60,0.04)',
 50:         }}
 51:       >
 52:         <p className="text-foreground text-sm font-heading font-bold mb-2">Message composed</p>
 53:         <p className="text-foreground-muted text-sm leading-relaxed mb-4">
 54:           Your email client should open with your message pre-filled. If it didn't, write directly to{' '}
 55:           <a href={`mailto:${COMPANY.email}`} className="text-accent hover:underline">
 56:             {COMPANY.email}
 57:           </a>
 58:           .
 59:         </p>
 60:         <button
 61:           type="button"
 62:           onClick={() => setSubmitted(false)}
 63:           className="mt-4 text-[0.68rem] font-bold tracking-[0.2em] uppercase text-accent hover:text-foreground transition-colors"
 64:         >
 65:           Send another message
 66:         </button>
 67:       </motion.div>
 68:     );
 69:   }
 70: 
 71:   return (
 72:     <motion.form
 73:       initial={{ opacity: 0, y: 16 }}
 74:       animate={{ opacity: 1, y: 0 }}
 75:       transition={{ duration: 0.6 }}
 76:       onSubmit={handleSubmit}
 77:       className="flex flex-col gap-4"
 78:     >
 79:       {/* Subject */}
 80:       <label className="flex flex-col gap-1.5">
 81:         <span className="font-mono text-[0.5rem] tracking-[0.32em] uppercase text-foreground-muted/60">Subject</span>
 82:         <select
 83:           name="subject"
 84:           required
 85:           value={subject}
 86:           onChange={(e) => setSubject(e.target.value)}
 87:           className={INPUT_CLASS}
 88:         >
 89:           {CONTACT_SUBJECTS.map((s) => (
 90:             <option key={s} value={s} className="bg-[#0a0a0a]">{s}</option>
 91:           ))}
 92:         </select>
 93:       </label>
 94: 
 95:       {/* Name + Job Title */}
 96:       <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
 97:         <label className="flex flex-col gap-1.5">
 98:           <span className="font-mono text-[0.5rem] tracking-[0.32em] uppercase text-foreground-muted/60">Full name</span>
 99:           <input name="name" type="text" required autoComplete="name" className={INPUT_CLASS} />
100:         </label>
101:         <label className="flex flex-col gap-1.5">
102:           <span className="font-mono text-[0.5rem] tracking-[0.32em] uppercase text-foreground-muted/60">Job title</span>
103:           <input name="jobtitle" type="text" autoComplete="organization-title" className={INPUT_CLASS} />
104:         </label>
105:       </div>
106: 
107:       {/* Email + Phone */}
108:       <div className="grid grid-cols-1 sm:grid-cols-2 gap-4">
109:         <label className="flex flex-col gap-1.5">
110:           <span className="font-mono text-[0.5rem] tracking-[0.32em] uppercase text-foreground-muted/60">Email</span>
111:           <input name="email" type="email" required autoComplete="email" className={INPUT_CLASS} />
112:         </label>
113:         <label className="flex flex-col gap-1.5">
114:           <span className="font-mono text-[0.5rem] tracking-[0.32em] uppercase text-foreground-muted/60">Phone (optional)</span>
115:           <input name="phone" type="tel" autoComplete="tel" className={INPUT_CLASS} />
116:         </label>
117:       </div>
118: 
119:       {/* Organisation */}
120:       <label className="flex flex-col gap-1.5">
121:         <span className="font-mono text-[0.5rem] tracking-[0.32em] uppercase text-foreground-muted/60">Organisation</span>
122:         <input name="organisation" type="text" className={INPUT_CLASS} />
123:       </label>
124: 
125:       {/* Media-specific fields */}
126:       <AnimatePresence>
127:         {isMedia && (
128:           <motion.div
129:             key="media-fields"
130:             initial={{ opacity: 0, height: 0 }}
131:             animate={{ opacity: 1, height: 'auto' }}
132:             exit={{ opacity: 0, height: 0 }}
133:             transition={{ duration: 0.3 }}
134:             className="flex flex-col gap-4 overflow-hidden"
135:           >
136:             <div
137:               className="px-4 py-3 rounded-sm text-[0.72rem] text-foreground-muted/70 leading-relaxed"
138:               style={{ border: '1px solid rgba(251,146,60,0.15)', background: 'rgba(251,146,60,0.04)' }}
139:             >
140:               Applying for press accreditation — please provide your outlet and coverage angle below.
141:             </div>
142:             <label className="flex flex-col gap-1.5">
143:               <span className="font-mono text-[0.5rem] tracking-[0.32em] uppercase text-foreground-muted/60">Outlet / Publication</span>
144:               <input name="outlet" type="text" className={INPUT_CLASS} />
145:             </label>
146:             <label className="flex flex-col gap-1.5">
147:               <span className="font-mono text-[0.5rem] tracking-[0.32em] uppercase text-foreground-muted/60">Coverage angle</span>
148:               <textarea name="coverage" rows={2} className={`${INPUT_CLASS} resize-none`} placeholder="What story are you covering?" />
149:             </label>
150:           </motion.div>
151:         )}
152:       </AnimatePresence>
153: 
154:       {/* Message */}
155:       <label className="flex flex-col gap-1.5">
156:         <span className="font-mono text-[0.5rem] tracking-[0.32em] uppercase text-foreground-muted/60">Message</span>
157:         <textarea
158:           name="message"
159:           rows={5}
160:           required
161:           className={`${INPUT_CLASS} resize-y min-h-[120px]`}
162:         />
163:       </label>
164: 
165:       <button
166:         type="submit"
167:         className="w-full py-3.5 rounded-sm font-bold tracking-[0.2em] uppercase text-[0.7rem] text-[#050505] transition-shadow hover:shadow-[0_0_28px_rgba(251,146,60,0.35)] active:scale-[0.99]"
168:         style={{
169:           background: 'linear-gradient(135deg, #fb923c 0%, #f97316 100%)',
170:           border: '1px solid rgba(251,146,60,0.5)',
171:         }}
172:       >
173:         {isMedia ? 'Apply for accreditation' : 'Send via email'}
174:       </button>
175:     </motion.form>
