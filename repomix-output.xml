        const paras = bodyRef.current.querySelectorAll('[data-para]');
        gsap.fromTo(paras,
          { y: 32, opacity: 0 },
          {
            y: 0, opacity: 1,
            duration: 0.85, stagger: 0.14, ease: 'power3.out',
            scrollTrigger: {
              trigger: bodyRef.current,
              start: 'top 78%',
              toggleActions: 'play none none none',
