154:               WebkitBackdropFilter: 'blur(18px)',
155:               border: `1px solid ${tile.accent}${hovered ? '5a' : '2e'}`,
156:               boxShadow: hovered
157:                 ? `0 0 44px ${tile.accent}26, 0 24px 50px rgba(0,0,0,0.5)`
158:                 : `0 12px 34px rgba(0,0,0,0.34)`,
159:               transition: 'border-color 0.4s ease, box-shadow 0.4s ease',
160:             }}
161:           >
162:             {/* Sheen sweep on hover */}
163:             <motion.div
164:               className="absolute inset-0 pointer-events-none"
165:               initial={{ x: '-130%' }}
166:               animate={hovered && !reduce ? { x: ['-130%', '230%'] } : { x: '-130%' }}
167:               transition={{ duration: 0.9, ease: 'easeInOut' }}
168:               style={{
169:                 background:
